const cta = {
  fi: 'Varaa Aika',
  sv: 'Boka Tid',
  en: 'Book Now'
};

const currentMenu = menu[lang] || menu.en;
const currentCta = cta[lang] || cta.en;
const bookingLink = lang === 'fi' ? '/fi/varaus' : lang === 'sv' ? '/sv/bokning' : '/booking';

// Route mapping for language switcher
const routeMap = {
  'consumers': { en: '/consumers', fi: '/fi/kuluttajat', sv: '/sv/konsumenter' },
  'pickup': { en: '/computer-repair-turku', fi: '/fi/tietokoneen-huolto-turku', sv: '/sv/datorservice-abo' },
  'remote': { en: '/remote-support', fi: '/fi/etatuki', sv: '/sv/fjarrsupport' },
  'repair': { en: '/computer-repair', fi: '/fi/tietokonehuolto', sv: '/sv/datorservice' },
  'security': { en: '/security', fi: '/fi/tietoturva', sv: '/sv/sakerhet' },
  'websites': { en: '/websites', fi: '/fi/kotisivut', sv: '/sv/hemsidor' },
  'companies': { en: '/companies', fi: '/fi/yritykset', sv: '/sv/foretag' },
  'it-infra': { en: '/it-infra', fi: '/fi/it-infra', sv: '/sv/it-infra' },
  'it-manager': { en: '/it-manager', fi: '/fi/it-paallikko', sv: '/sv/it-chef' },
  'server': { en: '/server-maintenance', fi: '/fi/serverihuolto', sv: '/sv/serverservice' },
  'support': { en: '/support', fi: '/fi/tuki', sv: '/sv/support' },
  'connectme': { en: '/connectme', fi: '/fi/connectme', sv: '/sv/connectme' },
  'team': { en: '/team', fi: '/fi/tiimi', sv: '/sv/team' },
  'agent': { en: '/agent', fi: '/fi/agentti', sv: '/sv/agent' },
  'agent-material': { en: '/agent-material', fi: '/fi/agentti-materiaali', sv: '/sv/agent-material' },
  'pulseway': { en: '/pulseway', fi: '/fi/pulseway', sv: '/sv/pulseway' },
  'm365': { en: '/m365', fi: '/fi/m365', sv: '/sv/m365' },
  'contact': { en: '/contact', fi: '/fi/yhteystiedot', sv: '/sv/kontakt' },
  'booking': { en: '/booking', fi: '/fi/varaus', sv: '/sv/bokning' },
  'services': { en: '/services', fi: '/fi/palvelut', sv: '/sv/tjanster' }
};

function getLocalizedPath(currentPath: string, targetLang: 'en' | 'fi' | 'sv') {
  const normalizedPath = currentPath.endsWith('/') && currentPath.length > 1 
    ? currentPath.slice(0, -1) 
    : currentPath;
    
  if (normalizedPath === '/' || normalizedPath === '/fi' || normalizedPath === '/sv') {
    return targetLang === 'en' ? '/' : `/${targetLang}`;
  }

  const routeKey = Object.keys(routeMap).find(key => {
    const map = routeMap[key as keyof typeof routeMap];
    return Object.values(map).includes(normalizedPath);
  });

  if (routeKey) {
    return routeMap[routeKey as keyof typeof routeMap][targetLang];
  }

  return targetLang === 'en' ? '/' : `/${targetLang}`;
}

const currentPath = Astro.url.pathname;
const enPath = getLocalizedPath(currentPath, 'en');
const fiPath = getLocalizedPath(currentPath, 'fi');
const svPath = getLocalizedPath(currentPath, 'sv');

const isLangActive = (l: string) => lang === l;
