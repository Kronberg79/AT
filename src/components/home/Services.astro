---
import { content } from '@/i18n/content';

export interface Props {
  lang?: 'en' | 'fi' | 'sv';
}

const { lang = 'en' } = Astro.props;

// Defensive fallback for content access
const defaultServices = content['en']?.services || {};
const currentServices = content[lang]?.services || {};
const t = {
  badge: "What We Do",
  title1: "Tailored IT Services",
  title2: "for Every",
  title3: "Need",
  items: [],
  cta: "Learn More",
  ...defaultServices,
  ...currentServices
};

const icons = [
  `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" /></svg>`,
  `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z" /></svg>`,
  `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 00-2 2zm10-10V7a4 4 0 00-8 0v4h8z" /></svg>`
];

const services = t.items.map((item, i) => ({
  ...item,
  icon: icons[i]
}));
---

<section id="services" class="py-24 bg-white" data-ps="src/components/home/Services.astro:dod6c6">
  <div class="container mx-auto px-6" data-ps="src/components/home/Services.astro:8cm2gx">
    <div class="max-w-3xl mb-16 reveal" data-ps="src/components/home/Services.astro:8cm2gw">
      <div class="text-xs font-black uppercase tracking-[0.3em] text-[#D44000] mb-4" data-ps="src/components/home/Services.astro:j6q9b9">{t.badge}</div>
      <h2 class="text-4xl md:text-5xl font-black text-slate-900 leading-tight" data-ps="src/components/home/Services.astro:ipom6c">
        {t.title1} <span class="italic font-serif" data-ps="src/components/home/Services.astro:4ny1x8">{t.title2}</span> {t.title3}
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8" data-ps="src/components/home/Services.astro:8cm2gv">
      {services.map((service, i) => (
        <div class={`p-10 rounded-3xl bg-slate-50 border border-slate-100 group hover:bg-slate-950 hover:scale-[1.02] transition-all duration-500 reveal reveal-delay-${i+1}`} data-ps="src/components/home/Services.astro:8cm2gu">
          <div class="w-16 h-16 bg-[#D44000] rounded-2xl flex items-center justify-center text-white mb-8 group-hover:rotate-12 transition-transform shadow-lg shadow-[#D44000]/20" data-ps="src/components/home/Services.astro:8cm2gt">
            <Fragment set:html={service.icon} />
          </div>
          <h3 class="text-2xl font-bold text-slate-900 mb-4 group-hover:text-white transition-colors" data-ps="src/components/home/Services.astro:i8mz1f">{service.title}</h3>
          <p class="text-slate-700 group-hover:text-slate-300 transition-colors leading-relaxed" data-ps="src/components/home/Services.astro:amfv8r">
            {service.description}
          </p>
          <div class="mt-8 pt-8 border-t border-slate-200 group-hover:border-white/10" data-ps="src/components/home/Services.astro:8cm2gs">
            <a href="#contact" class="inline-flex items-center gap-2 font-bold text-[#D44000] group-hover:text-white" data-ps="src/components/home/Services.astro:hqdryj">
              {t.cta}
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
