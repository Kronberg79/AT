---
import '@/styles/global.css';
import Navigation from '@/components/Navigation.astro';
import Footer from '@/components/Footer.astro';
import SEOHead from '@/components/SEOHead.astro';
import GoogleAnalytics from '@/components/integrations/GoogleAnalytics.astro';

export interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: string;
  jsonLd?: Record<string, any>;
  lang?: 'en' | 'fi' | 'sv';
}

const { title, description, image, type, jsonLd, lang = 'en' } = Astro.props;

const globalITSchema = {
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  "name": "Archipelago Technics",
  "image": "https://cdn.pagesmith.app/eb31781e/images/atlogo-225-225.webp",
  "description": lang === 'fi' 
    ? "Johtava IT-tuki, kotisivut ja tietotekniikkapalvelut koko Suomessa. Tarjoamme etätukea, Microsoft 365 -ratkaisuja ja IT-ylläpitoa yrityksille." 
    : lang === 'sv' 
      ? "Ledande IT-support och tekniktjänster i hela Sverige och Finland. Vi erbjuder fjärrsupport, Microsoft 365 och IT-underhåll."
      : "Global IT support, managed services, and Microsoft 365 solutions for businesses worldwide. Professional remote IT assistance.",
  "areaServed": lang === 'fi' 
    ? [{ "@type": "Country", "name": "Finland" }]
    : lang === 'sv' 
      ? [{ "@type": "Country", "name": "Sweden" }, { "@type": "Country", "name": "Finland" }]
      : { "@type": "Place", "name": "Worldwide" },
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Turku",
    "addressCountry": "FI"
  }
};

const combinedJsonLd = jsonLd 
  ? (Array.isArray(jsonLd) ? [globalITSchema, ...jsonLd] : [globalITSchema, jsonLd]) 
  : globalITSchema;
---

<!DOCTYPE html>
<html lang={lang}>
  <head>
    <link rel="icon" type="image/png" href="https://cdn.pagesmith.app/eb31781e/favicons/favicon-c33ddcf9.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="https://cdn.pagesmith.app/eb31781e/favicons/apple-touch-icon-c33ddcf9.png" />

    <SEOHead
      title={title}
      description={description}
      image={image}
      type={type}
      jsonLd={combinedJsonLd}
      lang={lang}
    />
    <script is:inline>document.documentElement.classList.add('js');</script>
    <GoogleAnalytics />
  </head>
    <body class="antialiased" data-ps="src/layouts/BaseLayout.astro:4vj8al">
      <!-- Site Layout -->
      <Navigation lang={lang} />
      <main data-ps="src/layouts/BaseLayout.astro:yuyoow">
        <slot />
      </main>
      <Footer lang={lang} />

      <style is:inline>
        .reveal, .reveal-left, .reveal-right, .reveal-scale {
          transition: opacity 1s cubic-bezier(0.22, 1, 0.36, 1), transform 1s cubic-bezier(0.22, 1, 0.36, 1);
        }
        .js .reveal, .js .reveal-left, .js .reveal-right, .js .reveal-scale { opacity: 0; }
        .js .reveal { transform: translateY(40px); }
        .js .reveal-left { transform: translateX(-40px); }
        .js .reveal-right { transform: translateX(40px); }
        .js .reveal-scale { transform: scale(0.92); }
        .js .reveal.active, .js .reveal-left.active, .js .reveal-right.active, .js .reveal-scale.active {
          opacity: 1;
          transform: translate(0) scale(1);
        }
        .reveal-delay-1 { transition-delay: 0.1s; }
        .reveal-delay-2 { transition-delay: 0.2s; }
        .reveal-delay-3 { transition-delay: 0.3s; }
        .hover-lift { transition: transform 0.3s ease, box-shadow 0.3s ease; }
        .hover-lift:hover { transform: translateY(-6px); shadow: 0 20px 40px rgba(0,0,0,0.1); }
      </style>

      <script is:inline>
        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) entry.target.classList.add('active');
          });
        }, { threshold: 0.15 });
        document.querySelectorAll('.reveal, .reveal-left, .reveal-right, .reveal-scale').forEach(el => observer.observe(el));


      </script>
    <script>
  // Emergency failsafe to prevent buttons from getting stuck on "Sending..."
  document.addEventListener('submit', (e) => {
    const btn = e.target.querySelector('button[type="submit"]');
    if (btn) {
      setTimeout(() => {
        if (btn.textContent.includes('Sending')) {
          btn.textContent = 'Server Error - Try Again';
          btn.disabled = false;
        }
      }, 8000);
    }
  });
</script>
</body>
</html>