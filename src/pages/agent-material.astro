                <script is:inline>
                  function setupWebpageConfigurator() {
                    const group = document.querySelector('.group\\/webpage');
                    if (!group) return;

                    const slider = group.querySelector('[data-webpage-slider]');
                    const input = group.querySelector('[data-webpage-input]');
                    const priceDisplay = group.querySelector('[data-webpage-price]');
                    const commissionDisplay = group.querySelector('[data-webpage-commission]');

                    function update() {
                    const pages = parseInt(input.value) || 0;
                    let price = 0;
                    let commission = 0;

                    if (pages === 1) {
                    price = 200;
                    commission = 50;
                    } else if (pages >= 2 && pages <= 4) {
                    price = 400;
                    commission = 100;
                    } else if (pages >= 5 && pages <= 6) {
                    price = 500;
                    commission = 150;
                    } else if (pages >= 7 && pages <= 8) {
                    price = 800;
                    commission = 200;
                    } else if (pages >= 9 && pages <= 10) {
                    price = 1000;
                    commission = 250;
                    }

                    // Multilingual
                    const isMultilingual = group.querySelector('[data-webpage-multilingual-yes]').checked;
                    if (isMultilingual) {
                    const extraLanguages = parseInt(group.querySelector('[data-webpage-languages]').value) || 0;
                    price += (price * 0.1) * extraLanguages;
                    commission += (price * 0.03) * extraLanguages;
                    }

                    // SEO
                    const isSeo = group.querySelector('[data-webpage-seo-yes]').checked;
                    if (isSeo) {
                    price += 100;
                    commission += 10;
                    }

                    // Email
                    const isEmail = group.querySelector('[data-webpage-email-yes]').checked;
                    if (isEmail) {
                    const mailboxes = parseInt(group.querySelector('[data-webpage-mailboxes]').value) || 0;
                    price += mailboxes * 2;
                    }

                    priceDisplay.textContent = `€${price.toFixed(2)}`;
                    commissionDisplay.textContent = `€${commission.toFixed(2)}`;
                    }

                    group.querySelectorAll('input').forEach(el => el.addEventListener('input', update));

                      priceDisplay.textContent = `€${price.toFixed(2)}`;
                      commissionDisplay.textContent = `€${commission.toFixed(2)}`;
                    }

                    slider.addEventListener('input', (e) => {
                      input.value = e.target.value;
                      update();
                    });

                    input.addEventListener('input', (e) => {
                      let val = parseInt(e.target.value);
                      if (isNaN(val)) val = 0;
                      if (val > 100) val = 100;
                      if (val < 0) val = 0;
                      slider.value = val;
                      update();
                    });

                    update();
                  }

                  setupWebpageConfigurator();
                </script>
