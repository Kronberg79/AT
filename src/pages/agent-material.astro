---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHeader from '@/components/PageHeader.astro';
import ConnectMeConfigurator from '@/components/agent/ConnectMeConfigurator.astro';

const title = "Agent Material | Selling Services for Archipelago Technics";
const description = "Learn about the different services you can sell as an A-T Agent and how much commission you can earn. Configurator coming soon!";
---

<BaseLayout title={title} description={description}>
  <PageHeader
    title="Agent Material & Commission Options"
    subtitle="Everything you need to know about the services you can sell and the rewards you will earn."
  />

  <section class="py-20 bg-white" data-ps="src/pages/agent-material.astro:gnomqy">
    <div class="container mx-auto px-4 max-w-4xl" data-ps="src/pages/agent-material.astro:3yj0vj">
      <div class="text-center mb-16" data-ps="src/pages/agent-material.astro:3yj0vk">
        <h2 class="text-3xl font-bold text-slate-900 mb-6" data-ps="src/pages/agent-material.astro:ac6f2c">Service Catalog & Commission Structure</h2>
        <p class="text-lg text-slate-600" data-ps="src/pages/agent-material.astro:zx1zj">
          As an A-T Agent, you have a wide range of services you can offer to your network. Below is an overview of our key services and the earning potential for each successful referral.
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-8 mb-20" data-ps="src/pages/agent-material.astro:3yj0vl">
        <div class="bg-slate-50 p-8 rounded-2xl border border-slate-200" data-ps="src/pages/agent-material.astro:3yj0vm">
          <div class="bg-blue-100 w-12 h-12 rounded-xl flex items-center justify-center mb-6" data-ps="src/pages/agent-material.astro:dmbs8a">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-blue-700"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect><line x1="8" y1="21" x2="16" y2="21"></line><line x1="12" y1="17" x2="12" y2="21"></line></svg>
          </div>
          <h3 class="text-xl font-bold text-slate-900 mb-3" data-ps="src/pages/agent-material.astro:4c8i5a">Website Development</h3>
          <p class="text-slate-600 mb-4" data-ps="src/pages/agent-material.astro:zx1zk">Sell modern, fast, and SEO-optimized websites built on Astro and Tailwind CSS. Perfect for small to medium businesses.</p>
          <ul class="space-y-2 mb-4 text-sm text-slate-700 font-medium">
            <li class="flex items-center gap-2" data-ps="src/pages/agent-material.astro:b35bk3"><svg class="w-4 h-4 text-green-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> Basic Package</li>
            <li class="flex items-center gap-2" data-ps="src/pages/agent-material.astro:b35bk4"><svg class="w-4 h-4 text-green-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> E-commerce integration</li>
            <li class="flex items-center gap-2" data-ps="src/pages/agent-material.astro:b35bk5"><svg class="w-4 h-4 text-green-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> Custom web applications</li>
          </ul>
        </div>

        <div class="bg-slate-50 p-8 rounded-2xl border border-slate-200" data-ps="src/pages/agent-material.astro:dmbs89">
          <div class="bg-blue-100 w-12 h-12 rounded-xl flex items-center justify-center mb-6" data-ps="src/pages/agent-material.astro:dmbs88">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-blue-700"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect><line x1="8" y1="21" x2="16" y2="21"></line><line x1="12" y1="17" x2="12" y2="21"></line></svg>
          </div>
          <h3 class="text-xl font-bold text-slate-900 mb-3" data-ps="src/pages/agent-material.astro:4c8i59">Managed IT & Support</h3>
          <p class="text-slate-600 mb-4" data-ps="src/pages/agent-material.astro:zx1zl">Refer businesses for continuous IT support, Microsoft 365 licensing, and endpoint management through ConnectMe or Pulseway.</p>
          <ul class="space-y-2 mb-4 text-sm text-slate-700 font-medium">
            <li class="flex items-center gap-2" data-ps="src/pages/agent-material.astro:b35bk6"><svg class="w-4 h-4 text-green-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> Monthly maintenance contracts</li>
            <li class="flex items-center gap-2" data-ps="src/pages/agent-material.astro:b35bk7"><svg class="w-4 h-4 text-green-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> M365 Setup & Migration</li>
            <li class="flex items-center gap-2" data-ps="src/pages/agent-material.astro:b35bk8"><svg class="w-4 h-4 text-green-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> Security Audits</li>
          </ul>
        </div>
      </div>

      <div class="bg-slate-900 rounded-3xl p-10 text-center text-white relative overflow-hidden" data-ps="src/pages/agent-material.astro:dmbs87">
        <div class="absolute top-0 right-0 w-64 h-64 bg-blue-500 rounded-full mix-blend-multiply filter blur-3xl opacity-20 transform translate-x-1/2 -translate-y-1/2" data-ps="src/pages/agent-material.astro:dmbs86"></div>
        <div class="absolute bottom-0 left-0 w-64 h-64 bg-orange-500 rounded-full mix-blend-multiply filter blur-3xl opacity-20 transform -translate-x-1/2 translate-y-1/2" data-ps="src/pages/agent-material.astro:dmbs85"></div>
        
        <div class="relative z-10" data-ps="src/pages/agent-material.astro:dmbs84">
          <h2 class="text-3xl font-bold mb-4" data-ps="src/pages/agent-material.astro:ac6f2d">Commission Configurator</h2>
          <div class="inline-block bg-blue-600 text-white text-sm font-bold px-4 py-1 rounded-full mb-6" data-ps="src/pages/agent-material.astro:dmbs83">Coming Soon</div>
          <p class="text-lg text-slate-300 max-w-2xl mx-auto mb-8" data-ps="src/pages/agent-material.astro:zx207">
            We are building an interactive configurator tool right here. Soon, you will be able to select specific services, adjust packages, and instantly see the exact commission you will earn for each sale.
          </p>
          <div class="w-full max-w-2xl mx-auto space-y-4 text-left" data-ps="src/pages/agent-material.astro:dmbs82">
            <!-- Group 1 -->
            <div class="bg-slate-800 rounded-2xl border border-slate-700 overflow-hidden transition-all duration-300 ring-2 ring-blue-500/50 shadow-lg shadow-blue-500/10" data-ps="src/pages/agent-material.astro:3yj0ul">
              <button class="w-full p-6 flex items-center justify-between text-left group configurator-toggle" data-target="group-1" data-ps="src/pages/agent-material.astro:gexvwq">
                <div class="flex items-center gap-4" data-ps="src/pages/agent-material.astro:3yj0um">
                  <div class="w-10 h-10 rounded-lg bg-blue-600/20 flex items-center justify-center text-blue-400 group-hover:bg-blue-600 group-hover:text-white transition-colors" data-ps="src/pages/agent-material.astro:3yj0un">
                    <span class="font-bold" data-ps="src/pages/agent-material.astro:k8adpu">1</span>
                  </div>
                  <div data-ps="src/pages/agent-material.astro:3yj0uo">
                    <h3 class="font-bold text-white" data-ps="src/pages/agent-material.astro:4c8i6s">IT Support for a company</h3>
                    <p class="text-xs text-slate-400 uppercase tracking-wider font-semibold" data-ps="src/pages/agent-material.astro:zx1ym">Group 1</p>
                  </div>
                </div>
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-slate-500 group-hover:text-white transition-transform duration-300"><path d="m6 9 6 6 6-6"></path></svg>
              </button>
              
              <div id="group-1" class="hidden p-8 border-t border-slate-700 bg-slate-800/50 group/support" data-ps="src/pages/agent-material.astro:3yj0up">
                <div class="grid gap-6" data-ps="src/pages/agent-material.astro:3yj0uq">
                  <div data-ps="src/pages/agent-material.astro:3yj0ur">
                    <div class="flex justify-between items-center mb-3" data-ps="src/pages/agent-material.astro:dmbs83">
                      <label class="text-sm font-medium text-slate-300">Number of Employees (0-100)</label>
                      <input type="number" min="0" max="100" value="0" class="w-16 bg-slate-900 border border-slate-700 rounded px-2 py-1 text-xs text-white focus:outline-none focus:ring-1 focus:ring-blue-500" data-support-input="employees" />
                    </div>
                    <input type="range" min="0" max="100" value="0" class="w-full h-2 bg-slate-700 rounded-lg appearance-none cursor-pointer accent-blue-500" data-support-slider="employees" />
                    <div class="flex justify-between text-xs text-slate-500 mt-2" data-ps="src/pages/agent-material.astro:3yj0vd"><span data-ps="src/pages/agent-material.astro:k8adp8">0</span><span data-ps="src/pages/agent-material.astro:k8adp7">50</span><span data-ps="src/pages/agent-material.astro:k8adp6">100</span></div>
                  </div>
                  
                  <div data-ps="src/pages/agent-material.astro:3yj0ve">
                    <div class="flex justify-between items-center mb-3" data-ps="src/pages/agent-material.astro:dmbs82">
                      <label class="text-sm font-medium text-slate-300">Devices to Manage (0-100)</label>
                      <input type="number" min="0" max="100" value="0" class="w-16 bg-slate-900 border border-slate-700 rounded px-2 py-1 text-xs text-white focus:outline-none focus:ring-1 focus:ring-blue-500" data-support-input="devices" />
                    </div>
                    <input type="range" min="0" max="100" value="0" class="w-full h-2 bg-slate-700 rounded-lg appearance-none cursor-pointer accent-blue-500" data-support-slider="devices" />
                    <div class="flex justify-between text-xs text-slate-500 mt-2" data-ps="src/pages/agent-material.astro:3yj0vf"><span data-ps="src/pages/agent-material.astro:k8adp5">0</span><span data-ps="src/pages/agent-material.astro:k8adp4">50</span><span data-ps="src/pages/agent-material.astro:k8adp3">100</span></div>
                  </div>

                  <div data-ps="src/pages/agent-material.astro:3yj0vg">
                    <div class="flex justify-between items-center mb-3" data-ps="src/pages/agent-material.astro:dmbs81">
                      <label class="text-sm font-medium text-slate-300">Mailboxes (0-100)</label>
                      <input type="number" min="0" max="100" value="0" class="w-16 bg-slate-900 border border-slate-700 rounded px-2 py-1 text-xs text-white focus:outline-none focus:ring-1 focus:ring-blue-500" data-support-input="mailboxes" />
                    </div>
                    <input type="range" min="0" max="100" value="0" class="w-full h-2 bg-slate-700 rounded-lg appearance-none cursor-pointer accent-blue-500" data-support-slider="mailboxes" />
                    <div class="flex justify-between text-xs text-slate-500 mt-2" data-ps="src/pages/agent-material.astro:3yj0vh"><span data-ps="src/pages/agent-material.astro:k8adp2">0</span><span data-ps="src/pages/agent-material.astro:k8adp1">50</span><span data-ps="src/pages/agent-material.astro:k8adp0">100</span></div>
                  </div>

                  <div class="pt-4 border-t border-slate-700" data-ps="src/pages/agent-material.astro:3yj0vi">
                    <label class="flex items-start gap-3 cursor-pointer group">
                      <div class="relative flex items-center justify-center mt-1" data-ps="src/pages/agent-material.astro:3yj0vj">
                        <input type="checkbox" class="peer h-5 w-5 appearance-none rounded border border-slate-600 bg-slate-700 checked:bg-blue-600 checked:border-blue-600 transition-all cursor-pointer" />
                        <svg class="absolute w-3.5 h-3.5 text-white opacity-0 peer-checked:opacity-100 transition-opacity pointer-events-none" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
                      </div>
                      <span class="text-sm text-slate-300 group-hover:text-white transition-colors" data-ps="src/pages/agent-material.astro:k8adoz">I don't know, they want you to be in contact with them ASAP</span>
                    </label>
                  </div>
                </div>

                <div class="mt-8 p-4 bg-blue-600/10 rounded-xl border border-blue-500/20 flex items-center justify-between" data-ps="src/pages/agent-material.astro:3yj0vk">
                  <span class="text-sm font-semibold text-blue-300" data-ps="src/pages/agent-material.astro:k8adod">Potential Commission</span>
                  <span class="text-xl font-bold text-white" data-commission-display data-ps="src/pages/agent-material.astro:t4uebo">$0.00</span>
                </div>
              </div>
            </div>

            <script is:inline>
              function setupITSupportConfigurator() {
                const group = document.querySelector('.group\\/support');
                if (!group) return;

                const inputs = {
                  employees: {
                    slider: group.querySelector('[data-support-slider="employees"]'),
                    input: group.querySelector('[data-support-input="employees"]')
                  },
                  devices: {
                    slider: group.querySelector('[data-support-slider="devices"]'),
                    input: group.querySelector('[data-support-input="devices"]')
                  },
                  mailboxes: {
                    slider: group.querySelector('[data-support-slider="mailboxes"]'),
                    input: group.querySelector('[data-support-input="mailboxes"]')
                  }
                };

                const display = group.querySelector('[data-commission-display]');

                function update() {
                  const emp = parseInt(inputs.employees.input.value) || 0;
                  const dev = parseInt(inputs.devices.input.value) || 0;
                  const mail = parseInt(inputs.mailboxes.input.value) || 0;

                  const total = (emp * 8) + (dev * 8) + (mail * 2);
                  display.textContent = `€${total.toFixed(2)}`;
                }

                Object.keys(inputs).forEach(key => {
                  const { slider, input } = inputs[key];
                  
                  slider.addEventListener('input', (e) => {
                    input.value = e.target.value;
                    update();
                  });

                  input.addEventListener('input', (e) => {
                    let val = parseInt(e.target.value);
                    if (isNaN(val)) val = 0;
                    if (val > 100) val = 100;
                    if (val < 0) val = 0;
                    slider.value = val;
                    update();
                  });
                });

                update();
              }

              // Run setup
              setupITSupportConfigurator();
            </script>

            <!-- Group 2 -->
            <div class="bg-slate-800 rounded-2xl border border-slate-700 overflow-hidden transition-all duration-300 ring-2 ring-blue-500/50 shadow-lg shadow-blue-500/10" data-ps="src/pages/agent-material.astro:3yj0vl">
              <button class="w-full p-6 flex items-center justify-between text-left group configurator-toggle" data-target="group-2" data-ps="src/pages/agent-material.astro:gexvwr">
                <div class="flex items-center gap-4" data-ps="src/pages/agent-material.astro:3yj0vm">
                  <div class="w-10 h-10 rounded-lg bg-blue-600/20 flex items-center justify-center text-blue-400 group-hover:bg-blue-600 group-hover:text-white transition-colors" data-ps="src/pages/agent-material.astro:dmbs8a">
                    <span class="font-bold" data-ps="src/pages/agent-material.astro:k8adob">2</span>
                  </div>
                  <div data-ps="src/pages/agent-material.astro:dmbs89">
                    <h3 class="font-bold text-white" data-ps="src/pages/agent-material.astro:4c8i66">Webpage</h3>
                    <p class="text-xs text-slate-400 uppercase tracking-wider font-semibold" data-ps="src/pages/agent-material.astro:zx1yn">Group 2</p>
                  </div>
                </div>
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-slate-500 group-hover:text-white transition-transform duration-300"><path d="m6 9 6 6 6-6"></path></svg>
              </button>

              <div id="group-2" class="hidden p-8 border-t border-slate-700 bg-slate-800/50 group/webpage" data-ps="src/pages/agent-material.astro:3yj0un">
                <div class="grid gap-6" data-ps="src/pages/agent-material.astro:3yj0uo">
                  <!-- How many pages -->
                  <div data-ps="src/pages/agent-material.astro:3yj0up">
                    <div class="flex justify-between items-center mb-3" data-ps="src/pages/agent-material.astro:dmbs83">
                      <label class="text-sm font-medium text-slate-300">How many pages (0-100)</label>
                      <input type="number" min="0" max="100" value="0" class="w-16 bg-slate-900 border border-slate-700 rounded px-2 py-1 text-xs text-white focus:outline-none focus:ring-1 focus:ring-blue-500" data-webpage-input />
                    </div>
                    <input type="range" min="0" max="100" value="0" class="w-full h-2 bg-slate-700 rounded-lg appearance-none cursor-pointer accent-blue-500" data-webpage-slider />
                    <div class="flex justify-between text-xs text-slate-500 mt-2" data-ps="src/pages/agent-material.astro:3yj0uq"><span data-ps="src/pages/agent-material.astro:k8adob">0</span><span data-ps="src/pages/agent-material.astro:k8adoa">50</span><span data-ps="src/pages/agent-material.astro:k8ado9">100</span></div>
                  </div>

                  <!-- Multilingual -->
                  <div class="space-y-4" data-ps="src/pages/agent-material.astro:3yj0ur">
                    <label class="block text-sm font-medium text-slate-300">Multilingual?</label>
                    <div class="flex gap-4" data-ps="src/pages/agent-material.astro:3yj0vd">
                      <label class="flex items-center gap-2 cursor-pointer group">
                        <input type="radio" name="multilingual" value="no" class="peer hidden" checked data-webpage-multilingual-no />
                        <div class="w-4 h-4 rounded-full border border-slate-600 peer-checked:border-blue-500 peer-checked:bg-blue-500 transition-all" data-ps="src/pages/agent-material.astro:3yj0ve"></div>
                        <span class="text-sm text-slate-400 peer-checked:text-white" data-ps="src/pages/agent-material.astro:k8ado8">No</span>
                      </label>
                      <label class="flex items-center gap-2 cursor-pointer group">
                        <input type="radio" name="multilingual" value="yes" class="peer hidden" data-webpage-multilingual-yes />
                        <div class="w-4 h-4 rounded-full border border-slate-600 peer-checked:border-blue-500 peer-checked:bg-blue-500 transition-all" data-ps="src/pages/agent-material.astro:3yj0vf"></div>
                        <span class="text-sm text-slate-400 peer-checked:text-white" data-ps="src/pages/agent-material.astro:k8ado7">Yes</span>
                      </label>
                    </div>
                    <div class="hidden [.group:has(input[value='yes']:checked)_~_&]:block space-y-3 pt-2" data-ps="src/pages/agent-material.astro:3yj0vg">
                      <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider">Number of languages (extra)</label>
                      <input type="number" min="1" value="1" class="w-20 bg-slate-900 border border-slate-700 rounded px-2 py-1 text-xs text-white focus:outline-none focus:ring-1 focus:ring-blue-500" data-webpage-languages />
                      <p class="text-[10px] text-slate-500" data-ps="src/pages/agent-material.astro:6uaxsy">+10% price & +3% commission per extra language</p>
                    </div>
                  </div>

                  <!-- SEO Optimized -->
                  <div class="space-y-4" data-ps="src/pages/agent-material.astro:3yj0vh">
                    <label class="block text-sm font-medium text-slate-300">SEO Optimized for something specific?</label>
                    <div class="flex gap-4" data-ps="src/pages/agent-material.astro:3yj0vi">
                      <label class="flex items-center gap-2 cursor-pointer group">
                        <input type="radio" name="seo" value="no" class="peer hidden" checked data-webpage-seo-no />
                        <div class="w-4 h-4 rounded-full border border-slate-600 peer-checked:border-blue-500 peer-checked:bg-blue-500 transition-all" data-ps="src/pages/agent-material.astro:3yj0vj"></div>
                        <span class="text-sm text-slate-400 peer-checked:text-white" data-ps="src/pages/agent-material.astro:k8ado6">No</span>
                      </label>
                      <label class="flex items-center gap-2 cursor-pointer group">
                        <input type="radio" name="seo" value="yes" class="peer hidden" data-webpage-seo-yes />
                        <div class="w-4 h-4 rounded-full border border-slate-600 peer-checked:border-blue-500 peer-checked:bg-blue-500 transition-all" data-ps="src/pages/agent-material.astro:3yj0vk"></div>
                        <span class="text-sm text-slate-400 peer-checked:text-white" data-ps="src/pages/agent-material.astro:k8ado5">Yes</span>
                      </label>
                    </div>
                    <div class="hidden [.group:has(input[value='yes']:checked)_~_&]:block pt-2 space-y-3" data-ps="src/pages/agent-material.astro:3yj0vl">
                      <textarea placeholder="Describe the SEO goals..." class="w-full bg-slate-900 border border-slate-700 rounded-lg px-4 py-2 text-sm text-white h-20 focus:outline-none focus:ring-2 focus:ring-blue-500/50 transition-all resize-none"></textarea>
                      <p class="text-[10px] text-slate-500" data-ps="src/pages/agent-material.astro:6uaxsx">+100€ price & +10€ commission</p>
                    </div>
                  </div>

                  <!-- Other things -->
                  <div class="space-y-4" data-ps="src/pages/agent-material.astro:3yj0vm">
                    <label class="block text-sm font-medium text-slate-300">Any other things they wish for the page?</label>
                    <div class="flex gap-4" data-ps="src/pages/agent-material.astro:dmbs8a">
                      <label class="flex items-center gap-2 cursor-pointer group">
                        <input type="radio" name="other" value="no" class="peer hidden" checked />
                        <div class="w-4 h-4 rounded-full border border-slate-600 peer-checked:border-blue-500 peer-checked:bg-blue-500 transition-all" data-ps="src/pages/agent-material.astro:dmbs89"></div>
                        <span class="text-sm text-slate-400 peer-checked:text-white" data-ps="src/pages/agent-material.astro:k8ado4">No</span>
                      </label>
                      <label class="flex items-center gap-2 cursor-pointer group">
                        <input type="radio" name="other" value="yes" class="peer hidden" />
                        <div class="w-4 h-4 rounded-full border border-slate-600 peer-checked:border-blue-500 peer-checked:bg-blue-500 transition-all" data-ps="src/pages/agent-material.astro:dmbs88"></div>
                        <span class="text-sm text-slate-400 peer-checked:text-white" data-ps="src/pages/agent-material.astro:k8adni">Yes</span>
                      </label>
                    </div>
                    <div class="hidden [.group:has(input[value='yes']:checked)_~_&]:block pt-2" data-ps="src/pages/agent-material.astro:dmbs87">
                      <textarea placeholder="Additional requirements..." class="w-full bg-slate-900 border border-slate-700 rounded-lg px-4 py-2 text-sm text-white h-20 focus:outline-none focus:ring-2 focus:ring-blue-500/50 transition-all resize-none"></textarea>
                    </div>
                  </div>

                  <!-- Email -->
                  <div class="space-y-4" data-ps="src/pages/agent-material.astro:dmbs86">
                    <label class="block text-sm font-medium text-slate-300">Email hosting?</label>
