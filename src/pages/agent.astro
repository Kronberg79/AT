---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHeader from '@/components/PageHeader.astro';

const title = "Make Money Online: Earn Easy Money as an A-T Agent";
const description = "Want to make money online and earn easy money fast? Join the A-T Agent program. Make money wherever you are by referring IT services. No risk, high rewards.";
---

<BaseLayout title={title} description={description}>
  <PageHeader
    title="Make Money Online as an A-T Agent"
    subtitle="Earn easy money wherever you are by connecting us with new customers. No strings attached."
  />

  <section class="py-20 bg-white" data-ps="src/pages/agent.astro:gwyvvo">
    <div class="container mx-auto px-4" data-ps="src/pages/agent.astro:z1ibtf">
      <div class="grid md:grid-cols-2 gap-12 items-center max-w-6xl mx-auto" data-ps="src/pages/agent.astro:z1ibtg">
        <div data-ps="src/pages/agent.astro:z1ibth">
          <h2 class="text-3xl font-bold text-slate-900 mb-6" data-ps="src/pages/agent.astro:6un6pb">Earn Much Money Fast – Wherever You Are</h2>
          <div class="space-y-4 mb-6" data-ps="src/pages/agent.astro:mo7jpq">
            <p class="text-lg text-slate-600" data-ps="src/pages/agent.astro:wt5k3u">
              Do you have a wide network or know businesses looking for reliable IT services? Join our agent program and learn how to <strong>make money online</strong> by turning those connections into significant extra income.
            </p>
            <p class="text-lg text-slate-600" data-ps="src/pages/agent.astro:wt5k3t">
              Whether you are a tech enthusiast looking to <strong>earn easy money</strong> or a small entrepreneur needing a reliable partner, we have the perfect opportunity for you. You can <strong>make money wherever you are</strong>—from home, your office, or while traveling—simply by referring new customers to our expert IT services.
            </p>
            <p class="text-lg text-slate-600" data-ps="src/pages/agent.astro:wt5k3t">
              With decades of experience in hardware and software repairs, we provide the expertise, tools, and scripts to handle the work while you focus on earning. It's the simplest way to <strong>earn much money fast</strong> without the responsibility of managing projects yourself.
            </p>
          </div>
          <ul class="space-y-4 mb-8">
            <li class="flex items-start gap-3" data-ps="src/pages/agent.astro:63oa7m">
              <div class="mt-1 bg-blue-100 p-1 rounded-full" data-ps="src/pages/agent.astro:z1ibti">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="text-blue-700"><polyline points="20 6 9 17 4 12"></polyline></svg>
              </div>
              <div data-ps="src/pages/agent.astro:z1ibtj">
                <span class="font-bold text-slate-900" data-ps="src/pages/agent.astro:hctrsj">Website Contracts:</span> Help businesses get a modern, fast website and earn a commission.
              </div>
            </li>
            <li class="flex items-start gap-3" data-ps="src/pages/agent.astro:63oa7l">
              <div class="mt-1 bg-blue-100 p-1 rounded-full" data-ps="src/pages/agent.astro:z1ibtk">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="text-blue-700"><polyline points="20 6 9 17 4 12"></polyline></svg>
              </div>
              <div data-ps="src/pages/agent.astro:z1ibtl">
                <span class="font-bold text-slate-900" data-ps="src/pages/agent.astro:hctrsk">PC Repairs & Service:</span> Refer consumers or companies needing technical support.
              </div>
            </li>
            <li class="flex items-start gap-3" data-ps="src/pages/agent.astro:63oa7k">
              <div class="mt-1 bg-blue-100 p-1 rounded-full" data-ps="src/pages/agent.astro:z1ibtm">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="text-blue-700"><polyline points="20 6 9 17 4 12"></polyline></svg>
              </div>
              <div data-ps="src/pages/agent.astro:z1ibtn">
                <span class="font-bold text-slate-900" data-ps="src/pages/agent.astro:hctrsl">ConnectMe Customers:</span> Promote our smart business connectivity solutions.
              </div>
            </li>
            <li class="flex items-start gap-3" data-ps="src/pages/agent.astro:63oa7j">
              <div class="mt-1 bg-blue-100 p-1 rounded-full" data-ps="src/pages/agent.astro:z1ibto">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="text-blue-700"><polyline points="20 6 9 17 4 12"></polyline></svg>
              </div>
              <div data-ps="src/pages/agent.astro:lr2xgs">
                <span class="font-bold text-slate-900" data-ps="src/pages/agent.astro:hctrsm">Business Customers:</span> Secure new managed service contracts for long-term rewards.
              </div>
            </li>
          </ul>
          <p class="text-slate-600 font-medium italic" data-ps="src/pages/agent.astro:mo7jpp">
            "It's simple: you make the introduction, we do the work, you get paid."
          </p>
        </div>
        <div class="relative" data-ps="src/pages/agent.astro:lr2xgt">
          <img 
            src="https://images.unsplash.com/photo-1758599543157-bc1a94fec33c?auto=format&w=800&q=80" 
            srcset="https://images.unsplash.com/photo-1758599543157-bc1a94fec33c?auto=format&w=320&q=80 320w, https://images.unsplash.com/photo-1758599543157-bc1a94fec33c?auto=format&w=480&q=80 480w, https://images.unsplash.com/photo-1758599543157-bc1a94fec33c?auto=format&w=640&q=80 640w, https://images.unsplash.com/photo-1758599543157-bc1a94fec33c?auto=format&w=800&q=80 800w"
            sizes="(max-width: 768px) 100vw, 50vw"
            alt="Business handshake and partnership" 
            class="rounded-2xl shadow-2xl w-full object-cover aspect-[4/3]"
            crossorigin="anonymous" data-ps="src/pages/agent.astro:wj97hb" />
          <div class="absolute -bottom-6 -right-6 bg-blue-600 text-white p-8 rounded-2xl shadow-xl hidden md:block" data-ps="src/pages/agent.astro:lr2xgu">
            <p class="text-2xl font-bold" data-ps="src/pages/agent.astro:mo7jpo">No Risk.</p>
            <p class="text-lg opacity-90" data-ps="src/pages/agent.astro:mo7jpn">Only Opportunity.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 bg-slate-50" data-ps="src/pages/agent.astro:gwyvvp">
    <div class="container mx-auto px-4 max-w-4xl text-center" data-ps="src/pages/agent.astro:lr2xgv">
      <h2 class="text-3xl font-bold text-slate-900 mb-8" data-ps="src/pages/agent.astro:6un6pa">Sign Up as an Agent</h2>
      <div class="bg-white p-8 md:p-12 rounded-3xl shadow-sm border border-slate-200" data-ps="src/pages/agent.astro:lr2xgw">
        <form class="grid md:grid-cols-2 gap-6 text-left">
          <div class="space-y-2" data-ps="src/pages/agent.astro:lr2xgx">
            <label class="block text-sm font-semibold text-slate-700">Full Name</label>
            <input type="text" placeholder="Your Name" class="w-full px-4 py-3 rounded-xl border border-slate-300 focus:ring-2 focus:ring-blue-600 focus:border-transparent outline-none transition-all" />
          </div>
          <div class="space-y-2" data-ps="src/pages/agent.astro:lr2xgy">
            <label class="block text-sm font-semibold text-slate-700">Email Address</label>
            <input type="email" placeholder="your@email.com" class="w-full px-4 py-3 rounded-xl border border-slate-300 focus:ring-2 focus:ring-blue-600 focus:border-transparent outline-none transition-all" />
          </div>
          <div class="space-y-2 md:col-span-2" data-ps="src/pages/agent.astro:lr2xgz">
            <label class="block text-sm font-semibold text-slate-700">Phone Number</label>
            <input type="tel" placeholder="+358..." class="w-full px-4 py-3 rounded-xl border border-slate-300 focus:ring-2 focus:ring-blue-600 focus:border-transparent outline-none transition-all" />
          </div>
          <div class="space-y-2 md:col-span-2" data-ps="src/pages/agent.astro:lr2xh0">
            <label class="block text-sm font-semibold text-slate-700">Tell us a bit about yourself/your network</label>
            <textarea rows="4" placeholder="How do you plan to find customers?" class="w-full px-4 py-3 rounded-xl border border-slate-300 focus:ring-2 focus:ring-blue-600 focus:border-transparent outline-none transition-all resize-none"></textarea>
          </div>
          <div class="md:col-span-2 pt-4" data-ps="src/pages/agent.astro:lr2xh1">
            <button type="submit" class="w-full bg-blue-600 hover:bg-blue-700 text-white font-bold py-4 px-8 rounded-xl transition-all shadow-lg shadow-blue-200" data-ps="src/pages/agent.astro:kvuoj6">
              Sign Up Now & Start Earning
            </button>
            <p class="text-center text-sm text-slate-500 mt-4" data-ps="src/pages/agent.astro:mo7jpm">
              By signing up, you agree to represent Archipelago Technics professionally.
            </p>
          </div>
        </form>
      </div>
    </div>
  </section>
</BaseLayout>
