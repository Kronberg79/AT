---
export const prerender = false;

import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHeader from '@/components/PageHeader.astro';

const title = "Book IT Support | Archipelago Technics";
const description = "Schedule your IT support appointment online. Available Mon-Fri, 10:00-16:00.";

const runtime = Astro.locals.runtime;
let db = runtime?.env?.DB;

let error = '';
let success = false;

// Handle form submission
if (Astro.request.method === 'POST') {
  if (!db) {
    error = "Service unavailable. Please try again later.";
  } else {
    try {
      const formData = await Astro.request.formData();
      const name = formData.get('name')?.toString();
      const email = formData.get('email')?.toString();
      const service = formData.get('service')?.toString();
      const date = formData.get('date')?.toString();
      const time = formData.get('time')?.toString();
      let notes = formData.get('notes')?.toString() || '';
      const pickup = formData.get('pickup');

      if (pickup) {
        notes = `[PICKUP REQUESTED] ${notes}`;
      }

      if (!name || !email || !service || !date || !time) {
        error = "Please fill in all required fields.";
      } else {
        // Validate time slot (server-side check)
        const dayOfWeek = new Date(date).getDay(); // 0=Sun, 6=Sat
        const hour = parseInt(time.split(':')[0]);

        if (dayOfWeek === 0 || dayOfWeek === 6) {
          error = "Bookings are only available Monday to Friday.";
        } else if (hour < 10 || hour > 15) {
          error = "Bookings are only available between 10:00 and 16:00.";
        } else {
            // Check double booking
            const existing = await db.prepare('SELECT id FROM bookings WHERE date = ? AND time = ? AND status != ?')
                .bind(date, time, 'rejected')
                .first();
            
            if (existing) {
                error = "That time slot is already booked. Please choose another.";
            } else {
                const id = crypto.randomUUID();
                await db.prepare('INSERT INTO bookings (id, name, email, service, date, time, notes) VALUES (?, ?, ?, ?, ?, ?, ?)')
                    .bind(id, name, email, service, date, time, notes)
                    .run();
                
                // Send Email Notification via Resend API
                const env = runtime?.env || process?.env || import.meta.env;
                const resendApiKey = env?.RESEND_API_KEY;

                if (resendApiKey) {
                  await fetch('https://api.resend.com/emails', {
                    method: 'POST',
                    headers: {
                      'Content-Type': 'application/json',
                      'Authorization': `Bearer ${resendApiKey}`
                    },
                    body: JSON.stringify({
                      from: 'Website System <onboarding@resend.dev>',
                      to: 'support@a-t.fi',
                      subject: `New Booking Request: ${service} on ${date}`,
                      html: `
                        <h3>New Booking Request</h3>
                        <p><strong>Name:</strong> ${name}</p>
                        <p><strong>Email:</strong> ${email}</p>
                        <p><strong>Service:</strong> ${service}</p>
                        <p><strong>Date & Time:</strong> ${date} at ${time}</p>
                        <hr/>
                        <p><strong>Notes:</strong></p>
                        <p>${notes || 'No additional notes provided.'}</p>
                      `,
                      reply_to: email
                    })
                  }).catch(e => console.error("Resend API fetch failed in booking:", e));
                }

                success = true;
            }
        }
      }
    } catch (e) {
      console.error('Booking error:', e);
      error = "Failed to submit booking. Please try again.";
    }
  }
}
---

<BaseLayout title={title} description={description} lang="en">
  <PageHeader title={title} description={description} />
  
  <div class="max-w-3xl mx-auto px-6 py-12" data-ps="src/pages/booking.astro:h25bxr">
    {success ? (
      <div class="bg-green-50 border border-green-200 text-green-700 p-8 rounded-xl text-center" data-ps="src/pages/booking.astro:h25bxs">
        <h2 class="text-2xl font-bold mb-4" data-ps="src/pages/booking.astro:2acc3f">Booking Request Received!</h2>
        <p class="mb-6" data-ps="src/pages/booking.astro:57463t">Thank you for booking with us. We will confirm your appointment shortly via email.</p>
        <a href="/" class="inline-block bg-primary-600 text-white px-6 py-3 rounded-lg hover:bg-primary-700 transition" data-ps="src/pages/booking.astro:cb22tm">Return Home</a>
      </div>
    ) : (
      <div class="bg-zinc-900 border border-white/10 p-8 rounded-xl shadow-lg" data-ps="src/pages/booking.astro:l675lk">
        <h2 class="text-2xl font-bold text-white mb-6" data-ps="src/pages/booking.astro:2acc3e">Request an Appointment</h2>
        
        {error && (
          <div class="bg-red-500/10 border border-red-500/50 text-red-200 p-4 rounded-lg mb-6" data-ps="src/pages/booking.astro:l675ll">
            {error}
          </div>
        )}

        <form method="POST" class="space-y-6" id="booking-form">
          <div class="grid md:grid-cols-2 gap-6" data-ps="src/pages/booking.astro:l675lm">
            <div data-ps="src/pages/booking.astro:l675ln">
              <label class="block text-sm font-medium text-gray-300 mb-2">Full Name *</label>
              <input type="text" name="name" required class="w-full bg-zinc-800 border border-zinc-700 rounded-lg px-4 py-3 text-white focus:ring-2 focus:ring-primary-500 focus:border-transparent outline-none" />
            </div>
            <div data-ps="src/pages/booking.astro:l675lo">
              <label class="block text-sm font-medium text-gray-300 mb-2">Email Address *</label>
              <input type="email" name="email" required class="w-full bg-zinc-800 border border-zinc-700 rounded-lg px-4 py-3 text-white focus:ring-2 focus:ring-primary-500 focus:border-transparent outline-none" />
            </div>
          </div>

          <div data-ps="src/pages/booking.astro:l675lp">
            <label class="block text-sm font-medium text-gray-300 mb-2">Service Type *</label>
            <select name="service" required class="w-full bg-zinc-800 border border-zinc-700 rounded-lg px-4 py-3 text-white focus:ring-2 focus:ring-primary-500 focus:border-transparent outline-none">
              <option value="">Select a service...</option>
              <option value="Computer Repair">Computer Repair</option>
              <option value="Remote Support">Remote Support</option>
              <option value="IT Consultation">IT Consultation</option>
              <option value="Business IT">Business IT Assessment</option>
            </select>
          </div>

          <div class="grid md:grid-cols-2 gap-6" data-ps="src/pages/booking.astro:l675lq">
            <div data-ps="src/pages/booking.astro:l675lr">
              <label class="block text-sm font-medium text-gray-300 mb-2">Date * (Mon-Fri)</label>
              <input type="date" name="date" id="date-picker" required min={new Date().toISOString().split('T')[0]} class="w-full bg-zinc-800 border border-zinc-700 rounded-lg px-4 py-3 text-white focus:ring-2 focus:ring-primary-500 focus:border-transparent outline-none" />
              <p class="text-xs text-gray-400 mt-1" data-ps="src/pages/booking.astro:57463u">Closed on weekends</p>
            </div>
            <div data-ps="src/pages/booking.astro:l675ls">
              <label class="block text-sm font-medium text-gray-300 mb-2">Time * (10:00 - 16:00)</label>
              <select name="time" id="time-picker" required class="w-full bg-zinc-800 border border-zinc-700 rounded-lg px-4 py-3 text-white focus:ring-2 focus:ring-primary-500 focus:border-transparent outline-none disabled:opacity-50" disabled>
                <option value="">Select date first...</option>
                <!-- Filled by JS -->
              </select>
            </div>
          </div>

          <div data-ps="src/pages/booking.astro:l675lt">
            <div class="mb-6 bg-zinc-800/50 p-4 rounded-lg border border-zinc-700/50" data-ps="src/pages/booking.astro:l675lt">
              <label class="flex items-center space-x-3 cursor-pointer">
                <input type="checkbox" name="pickup" value="yes" class="w-5 h-5 rounded border-zinc-600 bg-zinc-700 text-[#F54a00] focus:ring-[#F54a00] focus:ring-offset-zinc-900" />
                <span class="text-white font-medium" data-ps="src/pages/booking.astro:92dlc7">Request free pickup & return (Turku region only)</span>
              </label>
              <p class="text-sm text-gray-400 mt-2 ml-8" data-ps="src/pages/booking.astro:4exsym">We'll collect your device and bring it back when it's fixed.</p>
            </div>

            <label class="block text-sm font-medium text-gray-300 mb-2">Notes (Optional)</label>
            <textarea name="notes" rows="3" class="w-full bg-zinc-800 border border-zinc-700 rounded-lg px-4 py-3 text-white focus:ring-2 focus:ring-primary-500 focus:border-transparent outline-none"></textarea>
          </div>

          <button type="submit" class="w-full bg-primary-600 hover:bg-primary-700 text-white font-bold py-4 rounded-lg transition-colors" data-ps="src/pages/booking.astro:yemfun">
            Confirm Booking
          </button>
        </form>
      </div>
    )}
  </div>

  <script>
    const dateInput = document.getElementById('date-picker') as HTMLInputElement;
    const timeInput = document.getElementById('time-picker') as HTMLSelectElement;

    // Available hours: 10 to 16 (16:00 is end time, so last slot is 15:00? Or 16:00 slot exists?)
    // User said "slots from 10-16". Usually means 10, 11, 12, 13, 14, 15.
    // I will assume 10:00, 11:00 ... 16:00 is the LAST slot or the END?
    // "1 hour slots from 10-16" -> 10-11, 11-12... 15-16. 
    // If 16 is the end of the day, last slot is 15:00.
    // I will include 15:00 as the last 1-hour slot.
    const timeSlots = ['10:00', '11:00', '12:00', '13:00', '14:00', '15:00'];

    dateInput?.addEventListener('change', async (e) => {
        const date = (e.target as HTMLInputElement).value;
        if (!date) return;

        const day = new Date(date).getDay();
        if (day === 0 || day === 6) {
            alert("We are closed on weekends. Please select a weekday.");
            dateInput.value = '';
            timeInput.disabled = true;
            return;
        }

        timeInput.disabled = true;
        timeInput.innerHTML = '<option>Checking availability...</option>';

        try {
            // Fetch booked slots
            const res = await fetch(`/api/bookings/check?date=${date}`);
            const booked = await res.json(); // returns array of booked times e.g. ['10:00', '14:00']
            
            timeInput.innerHTML = '<option value="">Select a time...</option>';
            
            timeSlots.forEach(time => {
                const isBooked = booked.includes(time);
                const option = document.createElement('option');
                option.value = time;
                option.textContent = time;
                if (isBooked) {
                    option.disabled = true;
                    option.textContent += ' (Booked)';
                }
                timeInput.appendChild(option);
            });
            timeInput.disabled = false;
        } catch (err) {
            console.error(err);
            timeInput.innerHTML = '<option value="">Error loading times</option>';
        }
    });
  </script>
</BaseLayout>
