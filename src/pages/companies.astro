---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { SITE } from '@/config/site';



const solutions = [
  {
    title: "Managed IT Services",
    desc: "Proactive maintenance for your workstations and servers. We prevent issues before they disrupt your business.",
    icon: "M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"
  },
  {
    title: "Cybersecurity",
    desc: "Protect your sensitive data with enterprise-grade security. Firewalls, antivirus, and employee training.",
    icon: "M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"
  },
  {
    title: "Microsoft 365",
    desc: "Seamless collaboration with Teams, Outlook, and OneDrive. We handle migration, licensing, and support.",
    icon: "M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z"
  },
  {
    title: "IT Consulting",
    desc: "Strategic planning for your technology roadmap. Make informed decisions about hardware and software investments.",
    icon: "M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"
  }
];
---

<BaseLayout 
  title="Managed IT Services & Business Solutions | Archipelago Technics" 
  description="Managed IT services, cybersecurity, and cloud solutions for businesses in Turku and Archipelago." 
  lang="en"
>
  <!-- Hero Section -->
  <section class="relative h-[70vh] min-h-[600px] flex items-center overflow-hidden" data-ps="src/pages/companies.astro:hero">
    <div class="absolute inset-0 z-0" data-ps="src/pages/companies.astro:nmf5mz">
      <img 
        crossorigin="anonymous"
        src="https://images.unsplash.com/photo-1770219733996-85ce5b943a18?auto=format&w=1920&q=80" 
        srcset="https://images.unsplash.com/photo-1770219733996-85ce5b943a18?auto=format&w=800&q=80 800w, https://images.unsplash.com/photo-1770219733996-85ce5b943a18?auto=format&w=1200&q=80 1200w, https://images.unsplash.com/photo-1770219733996-85ce5b943a18?auto=format&w=1920&q=80 1920w"
        sizes="100vw"
        alt="Modern IT infrastructure server room" 
        class="w-full h-full object-cover" data-ps="src/pages/companies.astro:l461aw" />
      <div class="absolute inset-0 bg-gradient-to-r from-black/95 via-black/70 to-black/30" data-ps="src/pages/companies.astro:nmf5n0"></div>
    </div>
    
    <div class="relative z-10 max-w-7xl mx-auto px-6 w-full" data-ps="src/pages/companies.astro:nmf5n1">
      <div class="max-w-3xl reveal-left" data-ps="src/pages/companies.astro:nmf5n2">
        <div class="inline-block px-4 py-1 mb-6 border border-[#F54a00]/50 rounded-full bg-[#F54a00]/10 text-[#F54a00] font-bold text-sm tracking-wide uppercase" data-ps="src/pages/companies.astro:nmf5n3">
          Business Solutions
        </div>
        <h1 class="text-5xl md:text-7xl font-black text-white mb-8 leading-tight" data-ps="src/pages/companies.astro:cyd76d">
          Enterprise IT for <br/><span class="text-transparent bg-clip-text bg-gradient-to-r from-[#F54a00] to-orange-400" data-ps="src/pages/companies.astro:hnh3tl">Local Business</span>
        </h1>
        <p class="text-xl text-gray-300 mb-10 leading-relaxed max-w-2xl" data-ps="src/pages/companies.astro:j7xcqa">
          Secure, reliable, and scalable technology infrastructure. We are the local IT department for companies in Turku and the Archipelago.
        </p>
        <div class="flex flex-wrap gap-4" data-ps="src/pages/companies.astro:nmf5n4">
          <a href="/contact" class="px-8 py-4 bg-[#F54a00] text-white rounded-full font-bold hover:bg-[#D43F00] transition-all hover:scale-105 shadow-lg shadow-[#F54a00]/30" data-ps="src/pages/companies.astro:c3zg0k">
            Schedule a Consultation
          </a>
          <a href="#solutions" class="px-8 py-4 bg-white/10 text-white border border-white/20 rounded-full font-bold hover:bg-white/20 transition-all backdrop-blur-sm" data-ps="src/pages/companies.astro:c3zg0j">
            Explore Solutions
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Solutions Grid -->
  <section id="solutions" class="py-24 bg-zinc-950" data-ps="src/pages/companies.astro:solutions">
    <div class="max-w-7xl mx-auto px-6" data-ps="src/pages/companies.astro:nmf5n5">
      <div class="text-center max-w-3xl mx-auto mb-20 reveal" data-ps="src/pages/companies.astro:nmf5n6">
        <h2 class="text-3xl md:text-5xl font-bold text-white mb-6" data-ps="src/pages/companies.astro:rms4e0">Comprehensive IT Management</h2>
        <p class="text-xl text-gray-400" data-ps="src/pages/companies.astro:j7xcq9">From daily support to long-term strategy, we handle every aspect of your business technology.</p>
      </div>

      <div class="grid md:grid-cols-2 gap-8" data-ps="src/pages/companies.astro:nmf5n7">
        {solutions.map((item, index) => (
          <div class={`flex gap-6 p-8 rounded-2xl bg-zinc-900 border border-white/5 hover:border-[#F54a00]/30 transition-all hover:bg-zinc-800 group reveal-delay-${index + 1} reveal`} data-ps="src/pages/companies.astro:nmf5nt">
            <div class="shrink-0" data-ps="src/pages/companies.astro:nmf5nu">
              <div class="w-16 h-16 bg-[#F54a00]/10 rounded-xl flex items-center justify-center text-[#F54a00] group-hover:bg-[#F54a00] group-hover:text-white transition-colors shadow-lg shadow-[#F54a00]/5" data-ps="src/pages/companies.astro:nmf5nv">
                <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={item.icon} /></svg>
              </div>
            </div>
            <div data-ps="src/pages/companies.astro:nmf5nw">
              <h3 class="text-2xl font-bold text-white mb-3 group-hover:text-[#F54a00] transition-colors" data-ps="src/pages/companies.astro:spx0dj">{item.title}</h3>
              <p class="text-gray-400 leading-relaxed text-lg" data-ps="src/pages/companies.astro:j7xcq8">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Trust Section -->
  <section class="py-24 bg-zinc-900 border-y border-white/5" data-ps="src/pages/companies.astro:trust">
    <div class="max-w-7xl mx-auto px-6" data-ps="src/pages/companies.astro:nmf5nx">
      <div class="grid md:grid-cols-2 gap-16 items-center" data-ps="src/pages/companies.astro:nmf5ny">
        <div class="order-2 md:order-1 reveal-left" data-ps="src/pages/companies.astro:nmf5nz">
          <img 
            crossorigin="anonymous"
            src="https://images.unsplash.com/photo-1614064642261-3ccbfafa481b?auto=format&w=800&q=80" 
            srcset="https://images.unsplash.com/photo-1614064642261-3ccbfafa481b?auto=format&w=400&q=80 400w, https://images.unsplash.com/photo-1614064642261-3ccbfafa481b?auto=format&w=800&q=80 800w"
            class="rounded-xl shadow-2xl w-full border border-white/10" 
            alt="Cybersecurity digital shield" data-ps="src/pages/companies.astro:l461bi" />
        </div>
        <div class="order-1 md:order-2 reveal-right" data-ps="src/pages/companies.astro:nmf5o0">
          <h2 class="text-3xl md:text-5xl font-bold text-white mb-8" data-ps="src/pages/companies.astro:rms4dz">Why Local Businesses Trust Us</h2>
          <div class="space-y-8" data-ps="src/pages/companies.astro:nmf5o1">
            <div class="flex gap-4" data-ps="src/pages/companies.astro:nmf5o2">
              <div class="w-12 h-12 bg-green-500/10 rounded-full flex items-center justify-center text-green-500 shrink-0" data-ps="src/pages/companies.astro:gsufpy">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
              </div>
              <div data-ps="src/pages/companies.astro:gsufpz">
                <h4 class="text-xl font-bold text-white mb-2" data-ps="src/pages/companies.astro:e1i35w">Fast Response Time</h4>
                <p class="text-gray-400" data-ps="src/pages/companies.astro:j7xcq7">We prioritize business-critical issues. Our local presence means we can be on-site quickly when remote support isn't enough.</p>
              </div>
            </div>
            <div class="flex gap-4" data-ps="src/pages/companies.astro:gsufq0">
              <div class="w-12 h-12 bg-blue-500/10 rounded-full flex items-center justify-center text-blue-500 shrink-0" data-ps="src/pages/companies.astro:gsufq1">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
              </div>
              <div data-ps="src/pages/companies.astro:gsufq2">
                <h4 class="text-xl font-bold text-white mb-2" data-ps="src/pages/companies.astro:e1i35x">Proactive Security</h4>
                <p class="text-gray-400" data-ps="src/pages/companies.astro:j7xcq6">We don't just fix problems; we prevent them. Our managed services include continuous monitoring and threat detection.</p>
              </div>
            </div>
            <div class="flex gap-4" data-ps="src/pages/companies.astro:gsufq3">
              <div class="w-12 h-12 bg-purple-500/10 rounded-full flex items-center justify-center text-purple-500 shrink-0" data-ps="src/pages/companies.astro:gsufq4">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0z" /></svg>
              </div>
              <div data-ps="src/pages/companies.astro:gsufq5">
                <h4 class="text-xl font-bold text-white mb-2" data-ps="src/pages/companies.astro:e1i35y">Dedicated Partnership</h4>
                <p class="text-gray-400" data-ps="src/pages/companies.astro:j7xcq5">We get to know your business and your team. You'll work with familiar faces, not a random call center agent.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-24 bg-black text-center" data-ps="src/pages/companies.astro:cta">
    <div class="max-w-4xl mx-auto px-6 reveal-scale" data-ps="src/pages/companies.astro:gsufq6">
      <h2 class="text-3xl md:text-5xl font-black text-white mb-8" data-ps="src/pages/companies.astro:rms4dy">Secure your business today</h2>
      <p class="text-xl text-gray-400 mb-10" data-ps="src/pages/companies.astro:j7xcpj">Stop worrying about IT downtime and security breaches. Partner with us for reliable, professional support.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center" data-ps="src/pages/companies.astro:gsufq7">
        <a href="/contact" class="px-10 py-5 bg-[#F54a00] text-white rounded-full font-bold hover:bg-[#D43F00] transition-all hover:scale-105 shadow-lg shadow-[#F54a00]/30 text-lg" data-ps="src/pages/companies.astro:c3zg0i">
          Contact Sales
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
