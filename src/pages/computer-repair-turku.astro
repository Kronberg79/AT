---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHeader from '@/components/PageHeader.astro';

const title = "Computer Repair Turku | Free Pickup and Return Service";
const description = "Looking for computer repair or service in the Turku area? Archipelago Technics offers a hassle-free pickup service: we collect your device from your home and return it fixed.";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Computer Repair and Pickup Service Turku",
  "provider": {
    "@type": "LocalBusiness",
    "name": "Archipelago Technics",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Teollisuuskatu 22",
      "addressLocality": "Parainen",
      "postalCode": "21600",
      "addressRegion": "Turku Region",
      "addressCountry": "FI"
    },
    "telephone": "+358405829704"
  },
  "areaServed": "Turku, Parainen, Kaarina",
  "description": "Computer maintenance and repair with free pickup and return in the Turku area.",
  "serviceType": "Computer Repair Turku"
};
---

<BaseLayout title={title} description={description} lang="en" jsonLd={jsonLd}>
  <PageHeader 
    title="Computer Repair and Service Turku" 
    description="Hassle-free pickup service – we collect your computer from your home, fix it, and bring it back." 
  />

  <section class="py-16 md:py-24" data-ps="src/pages/computer-repair-turku.astro:s3v1">
    <div class="max-w-7xl mx-auto px-6" data-ps="src/pages/computer-repair-turku.astro:d7qx1w">
      <div class="grid md:grid-cols-2 gap-12 items-center" data-ps="src/pages/computer-repair-turku.astro:d7qx1x">
        <div class="prose prose-invert prose-lg" data-ps="src/pages/computer-repair-turku.astro:d7qx2j">
          <h2 class="text-3xl font-bold mb-6" data-ps="src/pages/computer-repair-turku.astro:kmdzaf">Computer Repair Turku: Easy and Fast Pickup Service</h2>
          <p data-ps="src/pages/computer-repair-turku.astro:iixm1d">
            Is your computer slow, not starting, or in need of cleaning? We make the repair process as easy as possible for you. You don't need to carry your machine to a shop – <strong>we will pick it up directly from your doorstep in the Turku region.</strong>
          </p>
          <p data-ps="src/pages/computer-repair-turku.astro:iixm1e">
            Once the service is complete, we return the device to your home at a scheduled time. Pickup and return are completely free in the Turku area when you order a repair service from us.
          </p>
          <div class="mt-8 flex flex-col sm:flex-row gap-4" data-ps="src/pages/computer-repair-turku.astro:d7qx2k">
            <a href="/booking" class="inline-flex justify-center items-center px-6 py-3 border border-transparent text-base font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700 transition-colors shadow-lg shadow-blue-500/20" data-ps="src/pages/computer-repair-turku.astro:pmviqg">
              Book pickup online
            </a>
            <a href="tel:+358405829704" class="inline-flex justify-center items-center px-6 py-3 border border-gray-700 text-base font-medium rounded-md text-white bg-transparent hover:bg-gray-800 transition-colors" data-ps="src/pages/computer-repair-turku.astro:pmvir2">
              Call and arrange pickup: 040 582 9704
            </a>
          </div>
        </div>
        <div class="relative" data-ps="src/pages/computer-repair-turku.astro:d7qx2l">
          <img 
            crossorigin="anonymous"
            src="https://images.unsplash.com/photo-1699905527162-8b932a8e9206?auto=format&w=1200&q=80" 
            srcset="https://images.unsplash.com/photo-1699905527162-8b932a8e9206?auto=format&w=320&q=80 320w, https://images.unsplash.com/photo-1699905527162-8b932a8e9206?auto=format&w=480&q=80 480w, https://images.unsplash.com/photo-1699905527162-8b932a8e9206?auto=format&w=800&q=80 800w, https://images.unsplash.com/photo-1699905527162-8b932a8e9206?auto=format&w=1200&q=80 1200w"
            sizes="(max-width: 768px) 100vw, 50vw"
            alt="Computer repair Turku" 
            class="rounded-2xl shadow-2xl w-full object-cover aspect-4/3" 
            loading="eager" data-ps="src/pages/computer-repair-turku.astro:aphsqf" />
          <div class="absolute -bottom-6 -left-6 bg-blue-600 p-6 rounded-xl hidden lg:block shadow-xl" data-ps="src/pages/computer-repair-turku.astro:d7qx2m">
            <span class="text-white font-bold text-lg block" data-ps="src/pages/computer-repair-turku.astro:3zmpav">Pickup & Return</span>
            <span class="text-blue-50" data-ps="src/pages/computer-repair-turku.astro:3zmpau">0 € in Turku region</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-gray-900/50" data-ps="src/pages/computer-repair-turku.astro:s3v2">
    <div class="max-w-7xl mx-auto px-6 text-center mb-16" data-ps="src/pages/computer-repair-turku.astro:d7qx2n">
      <h2 class="text-3xl font-bold mb-4" data-ps="src/pages/computer-repair-turku.astro:kmdzag">How it works?</h2>
      <p class="text-gray-400 max-w-2xl mx-auto" data-ps="src/pages/computer-repair-turku.astro:iixm1f">Three easy steps to get your computer fixed.</p>
    </div>
    
    <div class="max-w-7xl mx-auto px-6 grid md:grid-cols-3 gap-8" data-ps="src/pages/computer-repair-turku.astro:d7qx2o">
      <div class="p-8 bg-gray-950 rounded-2xl border border-gray-800 hover:border-blue-500 transition-colors text-center group" data-ps="src/pages/computer-repair-turku.astro:d7qx2p">
        <div class="w-16 h-16 bg-blue-600/10 rounded-full flex items-center justify-center mx-auto mb-6 group-hover:bg-blue-600/20 transition-colors" data-ps="src/pages/computer-repair-turku.astro:d7qx2q">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-blue-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
        </div>
        <h3 class="text-xl font-bold mb-4" data-ps="src/pages/computer-repair-turku.astro:5xz223">1. Book a time</h3>
        <p class="text-gray-400" data-ps="src/pages/computer-repair-turku.astro:iixm1g">Book a pickup time directly from our website or call us. We'll agree on a suitable time to collect the device from your home.</p>
      </div>

      <div class="p-8 bg-gray-950 rounded-2xl border border-gray-800 hover:border-blue-500 transition-colors text-center group" data-ps="src/pages/computer-repair-turku.astro:d7qx2r">
        <div class="w-16 h-16 bg-blue-600/10 rounded-full flex items-center justify-center mx-auto mb-6 group-hover:bg-blue-600/20 transition-colors" data-ps="src/pages/computer-repair-turku.astro:d7qx2s">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-blue-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
          </svg>
        </div>
        <h3 class="text-xl font-bold mb-4" data-ps="src/pages/computer-repair-turku.astro:5xz224">2. Repair</h3>
        <p class="text-gray-400" data-ps="src/pages/computer-repair-turku.astro:iixm1h">We pick up the machine and perform the necessary maintenance and repairs professionally at our service center in the Pargas–Turku area.</p>
      </div>

      <div class="p-8 bg-gray-950 rounded-2xl border border-gray-800 hover:border-blue-500 transition-colors text-center group" data-ps="src/pages/computer-repair-turku.astro:l1qfkk">
        <div class="w-16 h-16 bg-blue-600/10 rounded-full flex items-center justify-center mx-auto mb-6 group-hover:bg-blue-600/20 transition-colors" data-ps="src/pages/computer-repair-turku.astro:l1qfkl">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-blue-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
          </svg>
        </div>
        <h3 class="text-xl font-bold mb-4" data-ps="src/pages/computer-repair-turku.astro:5xz225">3. Home delivery</h3>
        <p class="text-gray-400" data-ps="src/pages/computer-repair-turku.astro:iixm23">We bring the serviced and working computer back to your home. You can continue working without unnecessary waiting or traveling.</p>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-24" data-ps="src/pages/computer-repair-turku.astro:s3v3">
    <div class="max-w-4xl mx-auto px-6" data-ps="src/pages/computer-repair-turku.astro:l1qfkm">
      <h2 class="text-3xl font-bold mb-12 text-center" data-ps="src/pages/computer-repair-turku.astro:kmdzah">Frequently Asked Questions – Computer Repair Turku</h2>
      
      <div class="space-y-8" data-ps="src/pages/computer-repair-turku.astro:l1qfkn">
        <div data-ps="src/pages/computer-repair-turku.astro:l1qfko">
          <h3 class="text-xl font-bold mb-3 text-blue-400" data-ps="src/pages/computer-repair-turku.astro:5xz226">Is the pickup service really free?</h3>
          <p class="text-gray-400" data-ps="src/pages/computer-repair-turku.astro:iixm24">Yes, we offer free pickup and return for everyone needing computer service or repair in the Turku, Pargas, and Kaarina areas.</p>
        </div>
        
        <div data-ps="src/pages/computer-repair-turku.astro:l1qfkp">
          <h3 class="text-xl font-bold mb-3 text-blue-400" data-ps="src/pages/computer-repair-turku.astro:5xz22s">How much does computer repair in Turku cost?</h3>
          <p class="text-gray-400" data-ps="src/pages/computer-repair-turku.astro:iixm25">The price of the repair depends on the necessary procedures and possible spare parts. We always give an estimate of the costs before starting the work, so you know exactly what you'll pay.</p>
        </div>
        
        <div data-ps="src/pages/computer-repair-turku.astro:l1qfkq">
          <h3 class="text-xl font-bold mb-3 text-blue-400" data-ps="src/pages/computer-repair-turku.astro:5xz22t">How long does computer service take?</h3>
          <p class="text-gray-400" data-ps="src/pages/computer-repair-turku.astro:iixm26">Typically, repairs are completed within 1–3 business days of pickup, depending on the extent of the repair and the availability of spare parts.</p>
        </div>

        <div data-ps="src/pages/computer-repair-turku.astro:l1qfkr">
          <h3 class="text-xl font-bold mb-3 text-blue-400" data-ps="src/pages/computer-repair-turku.astro:5xz22u">Can you fix the computer on-site at my home?</h3>
          <p class="text-gray-400" data-ps="src/pages/computer-repair-turku.astro:iixm27">Many software issues and network installations can be handled directly during a home visit. If the problem requires more thorough repair or part replacement, we use our pickup service to take the device to our workshop.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-blue-600" data-ps="src/pages/computer-repair-turku.astro:s3v4">
    <div class="max-w-4xl mx-auto px-6 text-center" data-ps="src/pages/computer-repair-turku.astro:l1qfks">
      <h2 class="text-3xl font-bold text-white mb-6" data-ps="src/pages/computer-repair-turku.astro:kmdzai">Need computer repair in Turku?</h2>
      <p class="text-xl text-blue-50 mb-8" data-ps="src/pages/computer-repair-turku.astro:iixm28">Get in touch and order your free pickup today!</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center" data-ps="src/pages/computer-repair-turku.astro:l1qfkt">
        <a href="/booking" class="px-8 py-4 bg-white text-blue-600 font-bold rounded-xl hover:bg-gray-100 transition-colors shadow-lg" data-ps="src/pages/computer-repair-turku.astro:pmvir3">
          Book pickup now
        </a>
        <a href="tel:+358405829704" class="px-8 py-4 border-2 border-white text-white font-bold rounded-xl hover:bg-blue-700 transition-colors" data-ps="src/pages/computer-repair-turku.astro:pmvir4">
          Call: 040 582 9704
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
