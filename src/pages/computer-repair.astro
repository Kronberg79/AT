---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHeader from '@/components/PageHeader.astro';

const title = "Computer Repair & Data Recovery Turku | Archipelago Technics";
const description = "Professional computer repair and data recovery services in Turku. We fix hardware failures, software issues, and recover lost files.";
---

<BaseLayout 
  title={title}
  description={description}
  lang="en"
>
  <PageHeader title={title} description={description} />
  
  <div class="max-w-7xl mx-auto px-6 py-16" data-ps="src/pages/computer-repair.astro:jozoj0">
    <div class="grid lg:grid-cols-2 gap-12 items-center mb-16" data-ps="src/pages/computer-repair.astro:jozoiz">
      <div class="prose prose-lg prose-invert" data-ps="src/pages/computer-repair.astro:jozoiy">
        <h2 class="text-3xl font-bold text-white mb-6" data-ps="src/pages/computer-repair.astro:7hzc5y">Computer Repair & IT Support</h2>
        <p class="lead text-xl text-orange-500 font-semibold" data-ps="src/pages/computer-repair.astro:iz6tow">
          Don't let technology hinder your business growth!
        </p>
        <p data-ps="src/pages/computer-repair.astro:iz6tov">
          We offer comprehensive computer repairs and IT solutions for both companies and consumers.
          We handle hardware failures, software problems, and data recovery with professional skill.
        </p>
        <p data-ps="src/pages/computer-repair.astro:iz6tou">
          We serve in our shop and make company and home visits as needed.
        </p>
        
        <div class="mt-8 not-prose" data-ps="src/pages/computer-repair.astro:1nm7ea">
          <h3 class="text-xl font-bold text-white mb-4" data-ps="src/pages/computer-repair.astro:m6e9dm">Pricing and Services</h3>
          <p class="text-zinc-400 mb-6" data-ps="src/pages/computer-repair.astro:iz6tot">Check detailed prices or request a quote for service.</p>
          <div class="flex gap-4" data-ps="src/pages/computer-repair.astro:1nm7eb">
            <a href="/contact" class="bg-orange-600 hover:bg-orange-700 text-white font-bold py-3 px-6 rounded-lg transition" data-ps="src/pages/computer-repair.astro:bv8wz3">
              Contact Us
            </a>
          </div>
        </div>
      </div>
      <div data-ps="src/pages/computer-repair.astro:1nm7ec">
        <img crossorigin="anonymous" src="https://images.unsplash.com/photo-1758686254545-2e8a33d39adb?auto=format&w=800&q=80" 
          class="rounded-xl shadow-2xl w-full h-full object-cover" 
          alt="Computer Repair" data-ps="src/pages/computer-repair.astro:m78suh" />
      </div>
    </div>

    <div class="grid md:grid-cols-3 gap-8" data-ps="src/pages/computer-repair.astro:1nm7ed">
      <div class="bg-zinc-900 p-6 rounded-xl border border-zinc-800 text-center" data-ps="src/pages/computer-repair.astro:1nm7ee">
        <div class="text-orange-500 text-4xl mb-4" data-ps="src/pages/computer-repair.astro:1nm7ef">💻</div>
        <h3 class="text-xl font-bold text-white mb-2" data-ps="src/pages/computer-repair.astro:m6e9dl">Repairs</h3>
        <p class="text-zinc-400" data-ps="src/pages/computer-repair.astro:iz6tos">Fast and reliable repairs for all brands.</p>
      </div>
      <div class="bg-zinc-900 p-6 rounded-xl border border-zinc-800 text-center" data-ps="src/pages/computer-repair.astro:1nm7eg">
        <div class="text-orange-500 text-4xl mb-4" data-ps="src/pages/computer-repair.astro:1nm7eh">💾</div>
        <h3 class="text-xl font-bold text-white mb-2" data-ps="src/pages/computer-repair.astro:m6e9dk">Data Recovery</h3>
        <p class="text-zinc-400" data-ps="src/pages/computer-repair.astro:iz6tor">We recover your important files from broken devices.</p>
      </div>
      <div class="bg-zinc-900 p-6 rounded-xl border border-zinc-800 text-center" data-ps="src/pages/computer-repair.astro:1nm7ei">
        <div class="text-orange-500 text-4xl mb-4" data-ps="src/pages/computer-repair.astro:1nm7ej">🏠</div>
        <h3 class="text-xl font-bold text-white mb-2" data-ps="src/pages/computer-repair.astro:m6e9dj">Home Visits</h3>
        <p class="text-zinc-400" data-ps="src/pages/computer-repair.astro:iz6to5">We come to you to solve your problems.</p>
      </div>
    </div>
  </div>
</BaseLayout>
