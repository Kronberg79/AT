---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHeader from '@/components/PageHeader.astro';

const lang = 'en';
---

<BaseLayout 
  title="ConnectMe | Proactive IT Security"
  description="ConnectMe is Archipelago Technics' comprehensive security package featuring Bitdefender, Pulseway, and automatic backups."
  lang={lang}
>
  <PageHeader 
    title="ConnectMe" 
    subtitle="Prepare and prevent instead of repair and repent."
  />

  <section class="py-24 bg-zinc-950" data-ps="src/pages/connectme.astro:i6hlew">
    <div class="max-w-7xl mx-auto px-6" data-ps="src/pages/connectme.astro:io7xam">
      <div class="grid lg:grid-cols-2 gap-16 items-center" data-ps="src/pages/connectme.astro:io7xal">
        <div data-ps="src/pages/connectme.astro:io7xak">
          <h2 class="text-4xl font-black text-white mb-6 leading-tight" data-ps="src/pages/connectme.astro:gal79r">
            Why Choose <span class="text-[#F54a00]" data-ps="src/pages/connectme.astro:y17o4w">ConnectMe?</span>
          </h2>
          <p class="text-xl text-white/70 mb-8 leading-relaxed" data-ps="src/pages/connectme.astro:mwjnpl">
            As cyberattacks increase, it's more important than ever to protect your systems. Regular updates and monitoring improve performance and reduce vulnerabilities.
          </p>
          
          <div class="space-y-6" data-ps="src/pages/connectme.astro:io7xaj">
            <div class="flex gap-4" data-ps="src/pages/connectme.astro:io7xai">
              <div class="w-12 h-12 bg-[#F54a00]/10 rounded-xl flex items-center justify-center shrink-0" data-ps="src/pages/connectme.astro:io7xah">
                <svg class="w-6 h-6 text-[#F54a00]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
              </div>
              <div data-ps="src/pages/connectme.astro:io7xag">
                <h3 class="text-xl font-bold text-white mb-2" data-ps="src/pages/connectme.astro:uz04hf">Bitdefender Security</h3>
                <p class="text-white/60" data-ps="src/pages/connectme.astro:mwjnpk">Globally trusted protection against viruses and malware using advanced machine learning.</p>
              </div>
            </div>
            
            <div class="flex gap-4" data-ps="src/pages/connectme.astro:io7xaf">
              <div class="w-12 h-12 bg-[#F54a00]/10 rounded-xl flex items-center justify-center shrink-0" data-ps="src/pages/connectme.astro:d58nov">
                <svg class="w-6 h-6 text-[#F54a00]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" /></svg>
              </div>
              <div data-ps="src/pages/connectme.astro:d58now">
                <h3 class="text-xl font-bold text-white mb-2" data-ps="src/pages/connectme.astro:uz04he">Pulseway Monitoring</h3>
                <p class="text-white/60" data-ps="src/pages/connectme.astro:mwjnpj">Proactive alerts, remote support, and automatic software management keep your PC up to date.</p>
              </div>
            </div>

            <div class="flex gap-4" data-ps="src/pages/connectme.astro:d58nox">
              <div class="w-12 h-12 bg-[#F54a00]/10 rounded-xl flex items-center justify-center shrink-0" data-ps="src/pages/connectme.astro:d58noy">
                <svg class="w-6 h-6 text-[#F54a00]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-3m-1 4l-3 3m0 0l-3-3m3 3V4" /></svg>
              </div>
              <div data-ps="src/pages/connectme.astro:d58noz">
                <h3 class="text-xl font-bold text-white mb-2" data-ps="src/pages/connectme.astro:uz04hd">Automatic Backup</h3>
                <p class="text-white/60" data-ps="src/pages/connectme.astro:mwjnox">We keep your data safe. If your device breaks, we can quickly restore your information.</p>
              </div>
            </div>
          </div>
        </div>
        
        <div class="relative" data-ps="src/pages/connectme.astro:d58np0">
          <div class="absolute inset-0 bg-gradient-to-tr from-[#F54a00]/20 to-transparent rounded-3xl blur-3xl" data-ps="src/pages/connectme.astro:d58np1"></div>
          <div class="relative bg-white/5 border border-white/10 p-12 rounded-3xl backdrop-blur-sm" data-ps="src/pages/connectme.astro:d58np2">
            <h3 class="text-2xl font-bold text-white mb-6" data-ps="src/pages/connectme.astro:uz04hc">Personal Service</h3>
            <p class="text-white/70 mb-8 italic" data-ps="src/pages/connectme.astro:mwjnow">
              "Together we can handle all the challenges the IT world offers."
            </p>
            <p class="text-white/60 mb-8" data-ps="src/pages/connectme.astro:mwjnov">
              At Archipelago Technics, you always talk to a person. We care for every customer personally, avoiding robot commands and automated loops.
            </p>
            <a href="https://connectme.fi" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-[#F54a00] font-bold hover:gap-3 transition-all" data-ps="src/pages/connectme.astro:fslqzv">
              Learn more at ConnectMe.fi
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-24 bg-white" data-ps="src/pages/connectme.astro:i6hlev">
    <div class="max-w-4xl mx-auto px-6 text-center" data-ps="src/pages/connectme.astro:d58np3">
      <h2 class="text-4xl font-black text-zinc-900 mb-6" data-ps="src/pages/connectme.astro:gal79q">Ready to secure your device?</h2>
      <p class="text-xl text-zinc-600 mb-10" data-ps="src/pages/connectme.astro:mwjnou">
        ConnectMe is the easiest way to ensure your computer is always safe, updated, and ready for work.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center" data-ps="src/pages/connectme.astro:d58np4">
        <a href="https://connectme.fi" target="_blank" class="px-8 py-4 bg-[#F54a00] text-zinc-950 rounded-xl font-bold text-lg hover:bg-[#D43F00] transition-colors" data-ps="src/pages/connectme.astro:fslqzu">
          View Pricing
        </a>
        <a href="/booking" class="px-8 py-4 bg-zinc-900 text-white rounded-xl font-bold text-lg hover:bg-zinc-800 transition-colors" data-ps="src/pages/connectme.astro:fslqzt">
          Book Consultation
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
