---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHeader from '@/components/PageHeader.astro';
import ConnectMeConfigurator from '@/components/agent/ConnectMeConfigurator.astro';

const title = "Agenttimateriaali | Myy palveluita ja tienaa Archipelago Technicsillä";
const description = "Lue lisää palveluista, joita voit myydä A-T Agenttina, ja siitä, kuinka paljon provisiota voit ansaita. Konfiguraattori tulossa pian!";
