                  <span class="text-xl font-bold text-white" data-commission-display data-ps="src/pages/fi/agentti-materiaali.astro:wc1d6h">0.00 €</span>
                </div>
              </div>
            </div>

            <script is:inline>
              function setupITSupportConfigurator() {
                const group = document.querySelector('.group\\/support');
                if (!group) return;

                const inputs = {
                  employees: {
                    slider: group.querySelector('[data-support-slider="employees"]'),
                    input: group.querySelector('[data-support-input="employees"]')
                  },
                  devices: {
                    slider: group.querySelector('[data-support-slider="devices"]'),
                    input: group.querySelector('[data-support-input="devices"]')
                  },
                  mailboxes: {
                    slider: group.querySelector('[data-support-slider="mailboxes"]'),
                    input: group.querySelector('[data-support-input="mailboxes"]')
                  }
                };

                const display = group.querySelector('[data-commission-display]');

                function update() {
                  const emp = parseInt(inputs.employees.input.value) || 0;
                  const dev = parseInt(inputs.devices.input.value) || 0;
                  const mail = parseInt(inputs.mailboxes.input.value) || 0;

                  const total = (emp * 8) + (dev * 8) + (mail * 2);
                  display.textContent = `${total.toFixed(2)} €`;
                }

                Object.keys(inputs).forEach(key => {
                  const { slider, input } = inputs[key];
                  
                  slider.addEventListener('input', (e) => {
                    input.value = e.target.value;
                    update();
                  });

                  input.addEventListener('input', (e) => {
                    let val = parseInt(e.target.value);
                    if (isNaN(val)) val = 0;
                    if (val > 100) val = 100;
                    if (val < 0) val = 0;
                    slider.value = val;
                    update();
                  });
                });

                update();
              }

              // Run setup
              setupITSupportConfigurator();
            </script>

