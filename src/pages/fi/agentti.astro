---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHeader from '@/components/PageHeader.astro';

const title = "Ansaitse rahaa netissä: Helppoa tuloa A-T Agenttina";
const description = "Haluatko ansaita rahaa netissä helposti ja nopeasti? Liity A-T Agentiksi. Tienaa rahaa missä tahansa suosittelemalla IT-palveluita. Ei riskiä, hyvät palkkiot.";
---

<BaseLayout title={title} description={description}>
  <PageHeader
    title="Ansaitse rahaa netissä A-T Agenttina"
    subtitle="Tienaa helppoa rahaa missä tahansa yhdistämällä meidät uusiin asiakkaisiin. Ei sitoumuksia."
  />

  <section class="py-20 bg-white" data-ps="src/pages/fi/agentti.astro:js4c0p">
    <div class="container mx-auto px-4" data-ps="src/pages/fi/agentti.astro:no0z7s">
      <div class="grid md:grid-cols-2 gap-12 items-center max-w-6xl mx-auto" data-ps="src/pages/fi/agentti.astro:no0z7t">
        <div data-ps="src/pages/fi/agentti.astro:no0z7u">
          <h2 class="text-3xl font-bold text-slate-900 mb-6" data-ps="src/pages/fi/agentti.astro:lkl4e2">Tienaa paljon rahaa nopeasti – missä tahansa oletkin</h2>
          <div class="space-y-4 mb-6" data-ps="src/pages/fi/agentti.astro:2da2g7">
            <p class="text-lg text-slate-600" data-ps="src/pages/fi/agentti.astro:mu4gtb">
              Onko sinulla laaja verkosto tai tunnetko yrityksiä, jotka etsivät luotettavia IT-palveluita? Liity agenttiohjelmaamme ja opi <strong>ansaitsemaan rahaa netissä</strong> muuttamalla kontaktisi merkittäviksi lisätuloiksi.
            </p>
            <p class="text-lg text-slate-600" data-ps="src/pages/fi/agentti.astro:mu4gta">
              Olitpa tekniikan harrastaja, joka haluaa <strong>tienata helppoa rahaa</strong>, tai pienyrittäjä, joka tarvitsee luotettavan kumppanin, meillä on sinulle täydellinen mahdollisuus. Voit <strong>ansaita rahaa missä tahansa</strong> — kotoa, toimistolta tai matkoilta — yksinkertaisesti suosittelemalla IT-palveluitamme uusille asiakkaille.
            </p>
            <p class="text-lg text-slate-600" data-ps="src/pages/fi/agentti.astro:mu4gta">
              Vuosikymmenten kokemus laitteisto- ja ohjelmistohuolloista takaa, että hoidamme työn ammattitaidolla puolestasi. Tämä on helpoin tapa <strong>tienata paljon rahaa nopeasti</strong> ilman projektinhallinnan vastuuta.
            </p>
          </div>
          <ul class="space-y-4 mb-8">
            <li class="flex items-start gap-3" data-ps="src/pages/fi/agentti.astro:ktm7wd">
              <div class="mt-1 bg-blue-100 p-1 rounded-full" data-ps="src/pages/fi/agentti.astro:no0z7v">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="text-blue-700"><polyline points="20 6 9 17 4 12"></polyline></svg>
              </div>
              <div data-ps="src/pages/fi/agentti.astro:no0z7w">
                <span class="font-bold text-slate-900" data-ps="src/pages/fi/agentti.astro:p80uco">Kotisivusopimukset:</span> Auta yrityksiä saamaan modernit, nopeat kotisivut ja ansaitse komissio.
              </div>
            </li>
            <li class="flex items-start gap-3" data-ps="src/pages/fi/agentti.astro:ktm7wc">
              <div class="mt-1 bg-blue-100 p-1 rounded-full" data-ps="src/pages/fi/agentti.astro:no0z7x">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="text-blue-700"><polyline points="20 6 9 17 4 12"></polyline></svg>
              </div>
              <div data-ps="src/pages/fi/agentti.astro:no0z7y">
                <span class="font-bold text-slate-900" data-ps="src/pages/fi/agentti.astro:p80ucp">PC-huollot & Palvelut:</span> Suosittele kuluttajia tai yrityksiä, jotka tarvitsevat teknistä tukea.
              </div>
            </li>
            <li class="flex items-start gap-3" data-ps="src/pages/fi/agentti.astro:ktm7wb">
              <div class="mt-1 bg-blue-100 p-1 rounded-full" data-ps="src/pages/fi/agentti.astro:no0z7z">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="text-blue-700"><polyline points="20 6 9 17 4 12"></polyline></svg>
              </div>
              <div data-ps="src/pages/fi/agentti.astro:no0z80">
                <span class="font-bold text-slate-900" data-ps="src/pages/fi/agentti.astro:p80ucq">ConnectMe Asiakkaat:</span> Mainosta älykkäitä yritysyhteysratkaisujamme.
              </div>
            </li>
            <li class="flex items-start gap-3" data-ps="src/pages/fi/agentti.astro:ktm7wa">
              <div class="mt-1 bg-blue-100 p-1 rounded-full" data-ps="src/pages/fi/agentti.astro:no0z81">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="text-blue-700"><polyline points="20 6 9 17 4 12"></polyline></svg>
              </div>
              <div data-ps="src/pages/fi/agentti.astro:8egqzt">
                <span class="font-bold text-slate-900" data-ps="src/pages/fi/agentti.astro:p80ucr">Yritysasiakkaat:</span> Hanki uusia ylläpitosopimuksia pitkäaikaisista palkkioista.
              </div>
            </li>
          </ul>
          <p class="text-slate-600 font-medium italic" data-ps="src/pages/fi/agentti.astro:2da2g8">
            "Se on yksinkertaista: sinä teet esittelyn, me teemme työn, sinä saat maksun."
          </p>
        </div>
        <div class="relative" data-ps="src/pages/fi/agentti.astro:8egqzs">
          <img 
            src="https://images.unsplash.com/photo-1758599543157-bc1a94fec33c?auto=format&w=800&q=80" 
            srcset="https://images.unsplash.com/photo-1758599543157-bc1a94fec33c?auto=format&w=320&q=80 320w, https://images.unsplash.com/photo-1758599543157-bc1a94fec33c?auto=format&w=480&q=80 480w, https://images.unsplash.com/photo-1758599543157-bc1a94fec33c?auto=format&w=640&q=80 640w, https://images.unsplash.com/photo-1758599543157-bc1a94fec33c?auto=format&w=800&q=80 800w"
            sizes="(max-width: 768px) 100vw, 50vw"
            alt="Business handshake and partnership" 
            class="rounded-2xl shadow-2xl w-full object-cover aspect-[4/3]"
            crossorigin="anonymous" data-ps="src/pages/fi/agentti.astro:l5ruvo" />
          <div class="absolute -bottom-6 -right-6 bg-blue-600 text-white p-8 rounded-2xl shadow-xl hidden md:block" data-ps="src/pages/fi/agentti.astro:8egqzr">
            <p class="text-2xl font-bold" data-ps="src/pages/fi/agentti.astro:2da2g9">Ei Riskiä.</p>
            <p class="text-lg opacity-90" data-ps="src/pages/fi/agentti.astro:2da2ga">Pelkkä Mahdollisuus.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 bg-slate-50" data-ps="src/pages/fi/agentti.astro:js4c0q">
    <div class="container mx-auto px-4 max-w-4xl text-center" data-ps="src/pages/fi/agentti.astro:8egqzq">
      <h2 class="text-3xl font-bold text-slate-900 mb-8" data-ps="src/pages/fi/agentti.astro:lkl4e1">Rekisteröidy Agentiksi</h2>
      <div class="bg-white p-8 md:p-12 rounded-3xl shadow-sm border border-slate-200" data-ps="src/pages/fi/agentti.astro:8egqzp">
        <form class="grid md:grid-cols-2 gap-6 text-left">
          <div class="space-y-2" data-ps="src/pages/fi/agentti.astro:8egqzo">
            <label class="block text-sm font-semibold text-slate-700">Koko Nimi</label>
            <input type="text" placeholder="Nimesi" class="w-full px-4 py-3 rounded-xl border border-slate-300 focus:ring-2 focus:ring-blue-600 focus:border-transparent outline-none transition-all" />
          </div>
          <div class="space-y-2" data-ps="src/pages/fi/agentti.astro:8egqzn">
            <label class="block text-sm font-semibold text-slate-700">Sähköpostiosoite</label>
            <input type="email" placeholder="sinun@sähköposti.fi" class="w-full px-4 py-3 rounded-xl border border-slate-300 focus:ring-2 focus:ring-blue-600 focus:border-transparent outline-none transition-all" />
          </div>
          <div class="space-y-2 md:col-span-2" data-ps="src/pages/fi/agentti.astro:8egqzm">
            <label class="block text-sm font-semibold text-slate-700">Puhelinnumero</label>
            <input type="tel" placeholder="+358..." class="w-full px-4 py-3 rounded-xl border border-slate-300 focus:ring-2 focus:ring-blue-600 focus:border-transparent outline-none transition-all" />
          </div>
          <div class="space-y-2 md:col-span-2" data-ps="src/pages/fi/agentti.astro:8egqzl">
            <label class="block text-sm font-semibold text-slate-700">Kerro hieman itsestäsi/verkostostasi</label>
            <textarea rows="4" placeholder="Miten aiot löytää asiakkaita?" class="w-full px-4 py-3 rounded-xl border border-slate-300 focus:ring-2 focus:ring-blue-600 focus:border-transparent outline-none transition-all resize-none"></textarea>
          </div>
          <div class="md:col-span-2 pt-4" data-ps="src/pages/fi/agentti.astro:8egqzk">
            <button type="submit" class="w-full bg-blue-600 hover:bg-blue-700 text-white font-bold py-4 px-8 rounded-xl transition-all shadow-lg shadow-blue-200" data-ps="src/pages/fi/agentti.astro:970rvd">
              Rekisteröidy Nyt & Aloita Ansaitseminen
            </button>
            <p class="text-center text-sm text-slate-500 mt-4" data-ps="src/pages/fi/agentti.astro:2da2gb">
              Rekisteröitymällä sitoudut edustamaan Archipelago Technicsiä ammattimaisesti.
            </p>
          </div>
        </form>
      </div>
    </div>
  </section>
</BaseLayout>
