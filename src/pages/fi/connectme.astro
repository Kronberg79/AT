---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHeader from '@/components/PageHeader.astro';

const lang = 'fi';
---

<BaseLayout 
  title="ConnectMe | Ennakoiva IT-turva"
  description="ConnectMe on Archipelago Technicsin kattava tietoturvapaketti, joka sisältää Bitdefenderin, Pulsewayn ja automaattiset varmuuskopiot."
  lang={lang}
>
  <PageHeader 
    title="ConnectMe" 
    subtitle="Parempi ennakoida ja estää kuin katua ja korjata."
  />

  <section class="py-24 bg-zinc-950" data-ps="src/pages/fi/connectme.astro:dht8lk">
    <div class="max-w-7xl mx-auto px-6" data-ps="src/pages/fi/connectme.astro:6j7vce">
      <div class="grid lg:grid-cols-2 gap-16 items-center" data-ps="src/pages/fi/connectme.astro:6j7vcd">
        <div data-ps="src/pages/fi/connectme.astro:6j7vcc">
          <h2 class="text-4xl font-black text-white mb-6 leading-tight" data-ps="src/pages/fi/connectme.astro:gvf60f">
            Miksi valita <span class="text-[#F54a00]" data-ps="src/pages/fi/connectme.astro:hl8ljk">ConnectMe?</span>
          </h2>
          <p class="text-xl text-white/70 mb-8 leading-relaxed" data-ps="src/pages/fi/connectme.astro:3oqj8p">
            Kyberhyökkäysten lisääntyessä on entistäkin tärkeämpää suojata järjestelmäsi. Säännölliset päivitykset ja valvonta parantavat suorituskykyä ja vähentävät haavoittuvuuksia.
          </p>
          
          <div class="space-y-6" data-ps="src/pages/fi/connectme.astro:6j7vcb">
            <div class="flex gap-4" data-ps="src/pages/fi/connectme.astro:6j7vca">
              <div class="w-12 h-12 bg-[#F54a00]/10 rounded-xl flex items-center justify-center shrink-0" data-ps="src/pages/fi/connectme.astro:6j7vc9">
                <svg class="w-6 h-6 text-[#F54a00]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
              </div>
              <div data-ps="src/pages/fi/connectme.astro:6j7vc8">
                <h3 class="text-xl font-bold text-white mb-2" data-ps="src/pages/fi/connectme.astro:vju383">Bitdefender Tietoturva</h3>
                <p class="text-white/60" data-ps="src/pages/fi/connectme.astro:3oqj8o">Maailmanlaajuisesti luotettu suoja viruksia ja haittaohjelmia vastaan hyödyntäen koneoppimista.</p>
              </div>
            </div>
            
            <div class="flex gap-4" data-ps="src/pages/fi/connectme.astro:6j7vc7">
              <div class="w-12 h-12 bg-[#F54a00]/10 rounded-xl flex items-center justify-center shrink-0" data-ps="src/pages/fi/connectme.astro:4sk99t">
                <svg class="w-6 h-6 text-[#F54a00]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" /></svg>
              </div>
              <div data-ps="src/pages/fi/connectme.astro:4sk99s">
                <h3 class="text-xl font-bold text-white mb-2" data-ps="src/pages/fi/connectme.astro:vju382">Pulseway Valvonta</h3>
                <p class="text-white/60" data-ps="src/pages/fi/connectme.astro:3oqj8n">Ennakoivat hälytykset, etäapu ja automaattinen ohjelmistojen hallinta pitävät koneesi ajantasalla.</p>
              </div>
            </div>

            <div class="flex gap-4" data-ps="src/pages/fi/connectme.astro:4sk99r">
              <div class="w-12 h-12 bg-[#F54a00]/10 rounded-xl flex items-center justify-center shrink-0" data-ps="src/pages/fi/connectme.astro:4sk99q">
                <svg class="w-6 h-6 text-[#F54a00]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-3m-1 4l-3 3m0 0l-3-3m3 3V4" /></svg>
              </div>
              <div data-ps="src/pages/fi/connectme.astro:4sk99p">
                <h3 class="text-xl font-bold text-white mb-2" data-ps="src/pages/fi/connectme.astro:vju381">Automaattinen Varmuuskopiointi</h3>
                <p class="text-white/60" data-ps="src/pages/fi/connectme.astro:3oqj81">Pidämme tietosi turvassa. Jos laitteesi rikkoutuu, saamme tietosi palautettua nopeasti.</p>
              </div>
            </div>
          </div>
        </div>
        
        <div class="relative" data-ps="src/pages/fi/connectme.astro:4sk99o">
          <div class="absolute inset-0 bg-gradient-to-tr from-[#F54a00]/20 to-transparent rounded-3xl blur-3xl" data-ps="src/pages/fi/connectme.astro:4sk99n"></div>
          <div class="relative bg-white/5 border border-white/10 p-12 rounded-3xl backdrop-blur-sm" data-ps="src/pages/fi/connectme.astro:4sk99m">
            <h3 class="text-2xl font-bold text-white mb-6" data-ps="src/pages/fi/connectme.astro:vju380">Henkilökohtaista Palvelua</h3>
            <p class="text-white/70 mb-8 italic" data-ps="src/pages/fi/connectme.astro:3oqj80">
              "Yhdessä selviämme kaikista IT-maailman tarjoamista haasteista."
            </p>
            <p class="text-white/60 mb-8" data-ps="src/pages/fi/connectme.astro:3oqj7z">
              Meillä Archipelago Technicsillä asioit aina ihmisen kanssa. Huolehdimme jokaisesta asiakkaastamme henkilökohtaisesti ja vältyt keskusteluilta robottien kanssa.
            </p>
            <a href="https://connectme.fi" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-[#F54a00] font-bold hover:gap-3 transition-all" data-ps="src/pages/fi/connectme.astro:3f7dh1">
              Lue lisää ConnectMe.fi sivustolta
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-24 bg-white" data-ps="src/pages/fi/connectme.astro:dht8lj">
    <div class="max-w-4xl mx-auto px-6 text-center" data-ps="src/pages/fi/connectme.astro:4sk99l">
      <h2 class="text-4xl font-black text-zinc-900 mb-6" data-ps="src/pages/fi/connectme.astro:gvf60e">Valmis turvaamaan laitteesi?</h2>
      <p class="text-xl text-zinc-600 mb-10" data-ps="src/pages/fi/connectme.astro:3oqj7y">
        ConnectMe on helpoin tapa varmistaa, että tietokoneesi on aina turvassa, päivitetty ja toimintavalmis.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center" data-ps="src/pages/fi/connectme.astro:4sk99k">
        <a href="https://connectme.fi/hinnasto" target="_blank" class="px-8 py-4 bg-[#F54a00] text-zinc-950 rounded-xl font-bold text-lg hover:bg-[#D43F00] transition-colors" data-ps="src/pages/fi/connectme.astro:3f7dh2">
          Katso Hinnasto
        </a>
        <a href="/fi/varaus" class="px-8 py-4 bg-zinc-900 text-white rounded-xl font-bold text-lg hover:bg-zinc-800 transition-colors" data-ps="src/pages/fi/connectme.astro:3f7dh3">
          Varaa Konsultaatio
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
