---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHeader from '@/components/PageHeader.astro';

const title = "IT-infrastruktuuripalvelut ja Verkkoratkaisut | Archipelago Technics";
const description = "IT-infrastruktuurin suunnittelu ja toteutus. Rakennamme luotettavat verkot ja palvelinympäristöt yrityksellesi.";
---

<BaseLayout title={title} description={description} lang="fi">
  <PageHeader title={title} description={description} />
  <div class="max-w-3xl mx-auto px-6 py-20 reveal" data-ps="src/pages/fi/it-infra.astro:eky41v">
    <div class="prose prose-invert prose-lg max-w-none prose-headings:font-black prose-headings:tracking-tight prose-p:text-gray-300 prose-p:leading-relaxed" data-ps="src/pages/fi/it-infra.astro:eky41t">
      <h2 data-ps="src/pages/fi/it-infra.astro:h2-1" class="text-3xl md:text-4xl mb-8">Henkilökohtaista ja tarpeen mukaan räätälöityä palvelua</h2>
      <p data-ps="src/pages/fi/it-infra.astro:p-1">Kaipaako IT-infrastruktuurinne päivitystä tai oletteko vasta aloittamassa IT-infran luontia? Me Archipelago Technicsillä uskomme siihen että jokainen asiakas ja yksilö ovat erilaisia. Panostamme henkilökohtaiseen ja asiakkaan tarpeen mukaan räätälöityyn palveluun. Tämä pätee myös IT-infroihin!</p>
      
      <p data-ps="src/pages/fi/it-infra.astro:p-2">IT-infrastruktuurit suunnittelemme räätälöidysti asiakkaiden toiveiden mukaan, on sitten kyseessä isompi tai pienempi kokonaisuus. Meillä on kokemusta alalta jo yli vuosikymmenen ajalta!</p>

      <div class="my-12 p-8 bg-zinc-900/50 rounded-2xl border border-white/5" data-ps="src/pages/fi/it-infra.astro:features-box">
        <h3 data-ps="src/pages/fi/it-infra.astro:h3-1" class="mt-0 text-white">Mitä tarjoamme:</h3>
        <ul data-ps="src/pages/fi/it-infra.astro:ul-1" class="grid gap-4 list-none pl-0">
          <li data-ps="src/pages/fi/it-infra.astro:li-1" class="flex items-start gap-3">
            <span class="text-blue-500 mt-1" data-ps="src/pages/fi/it-infra.astro:sd9eu9">●</span>
            <span data-ps="src/pages/fi/it-infra.astro:sd9eua"><strong>Verkkosuunnittelu:</strong> Rakennamme luotettavat ja nopeat lähiverkot (LAN) ja langattomat verkot (WLAN).</span>
          </li>
          <li data-ps="src/pages/fi/it-infra.astro:li-2" class="flex items-start gap-3">
            <span class="text-blue-500 mt-1" data-ps="src/pages/fi/it-infra.astro:sd9eub">●</span>
            <span data-ps="src/pages/fi/it-infra.astro:sd9euc"><strong>Palvelinhallinta:</strong> Palvelinten asennus, ylläpito ja optimointi.</span>
          </li>
          <li data-ps="src/pages/fi/it-infra.astro:li-3" class="flex items-start gap-3">
            <span class="text-blue-500 mt-1" data-ps="src/pages/fi/it-infra.astro:sd9eud">●</span>
            <span data-ps="src/pages/fi/it-infra.astro:sd9eue"><strong>Tiedon varmistus:</strong> Varmistamme, että yrityksesi tärkeät tiedot ovat aina tallessa ja palautettavissa.</span>
          </li>
          <li data-ps="src/pages/fi/it-infra.astro:li-4" class="flex items-start gap-3">
            <span class="text-blue-500 mt-1" data-ps="src/pages/fi/it-infra.astro:sd9euf">●</span>
            <span data-ps="src/pages/fi/it-infra.astro:sd9eug"><strong>Tietoturva:</strong> Integroitu tietoturva osaksi koko infrastruktuuria.</span>
          </li>
        </ul>
      </div>

      <p data-ps="src/pages/fi/it-infra.astro:p-3">Meidän tehtävämme on ottaa huomioon tekniset vaatimukset, budjetti ja liiketoiminnan tavoitteet, jotta voimme rakentaa sinulle optimaalisen infrastruktuurin. Oikein suunniteltu IT-infrastruktuuri on avain yrityksesi menestykseen.</p>

      <div class="bg-gradient-to-br from-blue-600 to-blue-800 rounded-2xl p-8 md:p-12 mt-16 text-center text-white not-prose" data-ps="src/pages/fi/it-infra.astro:cta">
        <h3 class="text-3xl font-black mb-4" data-ps="src/pages/fi/it-infra.astro:cta-h3">Kiinnostuitko?</h3>
        <p class="text-blue-100 text-lg mb-8 max-w-xl mx-auto" data-ps="src/pages/fi/it-infra.astro:cta-p">Soita meille heti nro +358 40 582 9704 tai jätä yhteydenottopyyntö, niin otamme pian yhteyttä.</p>
        <a href="/fi/yhteystiedot" class="inline-block bg-white text-blue-600 hover:bg-blue-50 font-black py-4 px-10 rounded-xl transition-all hover:scale-105 active:scale-95 shadow-xl" data-ps="src/pages/fi/it-infra.astro:cta-a">Ota yhteyttä</a>
      </div>
    </div>
  </div>
</BaseLayout>
