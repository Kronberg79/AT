---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHeader from '@/components/PageHeader.astro';

const title = "Ulkoistettu IT-päällikkö ja Tietohallinto | Archipelago Technics";
const description = "Strategista IT-johtajuutta ja teknistä hallintaa yrityksesi kasvun tueksi. Ulkoistettu tietohallintojohtaja (CIO) pk-yrityksille.";
---

<BaseLayout title={title} description={description} lang="fi">
  <PageHeader title={title} description={description} />
  
  <div class="max-w-7xl mx-auto px-6 py-12" data-ps="src/pages/fi/it-paallikko.astro:qs8a4p">
    <div class="grid md:grid-cols-2 gap-12 items-center mb-24" data-ps="src/pages/fi/it-paallikko.astro:qs8a4o">
      <div class="prose prose-invert prose-lg" data-ps="src/pages/fi/it-paallikko.astro:qs8a4n">
        <p class="lead" data-ps="src/pages/fi/it-paallikko.astro:z4nk5m">Yhdistämme liiketoiminnan tavoitteet ja teknisen toteutuksen.</p>
        <p data-ps="src/pages/fi/it-paallikko.astro:z4nk5l">Monet pienet ja keskisuuret yritykset saavuttavat pisteen, jossa perus-IT-tuki ei enää riitä, mutta kokopäiväinen tietohallintojohtaja (CIO) on liian kallis investointi. Ulkoistettu IT-päällikkö -palvelumme tarjoaa kokenutta osaamista osa-aikaisesti tai projektikohtaisesti.</p>
        <p data-ps="src/pages/fi/it-paallikko.astro:njlj59">Emme vain huolla tietokoneita; varmistamme, että teknologia-investointinne tukevat todella yrityksenne kasvua, hallitsemme laitetoimittajia ja suunnittelemme tulevaisuutta.</p>
      </div>
      <div data-ps="src/pages/fi/it-paallikko.astro:qs8a4m">
        <img 
            crossorigin="anonymous"
            src="https://images.unsplash.com/photo-1659353219596-80cd21857b52?auto=format&w=800&q=80" 
            srcset="https://images.unsplash.com/photo-1659353219596-80cd21857b52?auto=format&w=400&q=80 400w, https://images.unsplash.com/photo-1659353219596-80cd21857b52?auto=format&w=800&q=80 800w"
            class="rounded-xl shadow-2xl w-full" 
            alt="IT-hallinnan strategia" data-ps="src/pages/fi/it-paallikko.astro:edmt76" />
      </div>
    </div>

    <div class="grid md:grid-cols-3 gap-8 mb-24" data-ps="src/pages/fi/it-paallikko.astro:qs8a4t">
      <div class="bg-neutral-900/50 p-8 rounded-2xl border border-white/10" data-ps="src/pages/fi/it-paallikko.astro:qs8a4s">
        <h3 class="text-xl font-bold mb-4 text-primary-400" data-ps="src/pages/fi/it-paallikko.astro:720e52">Strateginen suunnittelu</h3>
        <p class="text-neutral-400" data-ps="src/pages/fi/it-paallikko.astro:njlj58">Vuosittainen IT-budjetointi, teknologian tiekartat ja IT-infrastruktuurin sovittaminen yhteen liiketoiminnan tavoitteiden kanssa.</p>
      </div>
      <div class="bg-neutral-900/50 p-8 rounded-2xl border border-white/10" data-ps="src/pages/fi/it-paallikko.astro:qs8a4r">
        <h3 class="text-xl font-bold mb-4 text-primary-400" data-ps="src/pages/fi/it-paallikko.astro:720e51">Toimittajahallinta</h3>
        <p class="text-neutral-400" data-ps="src/pages/fi/it-paallikko.astro:njlj57">Toimimme teknisenä edustajananasi ja hallitsemme suhteita sekä sopimuksia ohjelmisto-, internet- ja laitetoimittajien kanssa.</p>
      </div>
      <div class="bg-neutral-900/50 p-8 rounded-2xl border border-white/10" data-ps="src/pages/fi/it-paallikko.astro:qs8a4q">
        <h3 class="text-xl font-bold mb-4 text-primary-400" data-ps="src/pages/fi/it-paallikko.astro:720e50">Projektinhallinta</h3>
        <p class="text-neutral-400" data-ps="src/pages/fi/it-paallikko.astro:njlj56">Asiantunteva hallinta suurissa teknisissä muutoksissa, migraatioissa ja käyttöönotoissa varmistaen, että ne pysyvät aikataulussa ja budjetissa.</p>
      </div>
    </div>

    <div class="prose prose-invert max-w-none bg-neutral-900/30 p-12 rounded-3xl border border-white/5" data-ps="src/pages/fi/it-paallikko.astro:qs8a4p">
      <h2 class="text-center mb-12" data-ps="src/pages/fi/it-paallikko.astro:pg7pp6">Miten luomme arvoa</h2>
      <div class="grid md:grid-cols-2 gap-12" data-ps="src/pages/fi/it-paallikko.astro:qs8a4o">
        <div data-ps="src/pages/fi/it-paallikko.astro:qs8a4n">
          <h3 data-ps="src/pages/fi/it-paallikko.astro:720e4z">Linjaukset ja vaatimustenmukaisuus</h3>
          <p data-ps="src/pages/fi/it-paallikko.astro:njlj4k">Sisäisten IT-käytäntöjen kehittäminen (tietoturva, etätyö) ja varmistaminen, että järjestelmät täyttävät toimialakohtaiset vaatimukset.</p>
          
          <h3 data-ps="src/pages/fi/it-paallikko.astro:720e4y">Toipumissuunnittelu</h3>
          <p data-ps="src/pages/fi/it-paallikko.astro:njlj4j">Siirtyminen pelkistä varmuuskopioista kattavaan liiketoiminnan jatkuvuussuunnitteluun. Varmistamme, että työt voivat jatkua myös häiriötilanteissa.</p>
        </div>
        <div data-ps="src/pages/fi/it-paallikko.astro:qs8a4m">
          <h3 data-ps="src/pages/fi/it-paallikko.astro:720e4x">Digitaalinen transformaatio</h3>
          <p data-ps="src/pages/fi/it-paallikko.astro:njlj4i">Tunnistamme manuaaliset prosessit, jotka voidaan automatisoida tai parantaa nykyaikaisilla pilviratkaisuilla ja tekoälyn hyödyntämisellä.</p>
          
          <h3 data-ps="src/pages/fi/it-paallikko.astro:oz62k9">Resurssien optimointi</h3>
          <p data-ps="src/pages/fi/it-paallikko.astro:njlj4h">Ohjelmistotilausten ja laitteiston käytön auditointi turhien kulujen karsimiseksi ja budjetin kohdentamiseksi tärkeimmille alueille.</p>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>