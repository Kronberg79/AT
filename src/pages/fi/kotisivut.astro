---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHeader from '@/components/PageHeader.astro';

const title = "Kotisivut yrityksille Turku ja Parainen | Hakukoneoptimointi";
const description = "Hanki laadukkaat ja edulliset kotisivut yrityksille Turun ja Paraisten alueella. Tarjoamme ammattimaista Google-optimointia ja modernit verkkoratkaisut.";
---

<BaseLayout title={title} description={description} lang="fi">
  <PageHeader title="Kotisivut & Google Optimointi" description="Ammattimaiset ja edulliset kotisivut yrityksille Turun ja Paraisten alueella. Toteutamme modernit verkkopalvelut, jotka löytyvät Googlen hakutuloksista." />
  
  <div class="max-w-5xl mx-auto px-6 py-16" data-ps="src/pages/fi/kotisivut.astro:6ucpu9">
    <div class="prose prose-lg max-w-none" data-ps="src/pages/fi/kotisivut.astro:6ucpub">
      <div class="grid md:grid-cols-2 gap-12 items-center mb-16" data-ps="src/pages/fi/kotisivut.astro:intro-grid">
        <div data-ps="src/pages/fi/kotisivut.astro:intro-text">
          <h2 class="text-3xl font-black text-black mb-6 mt-0" data-ps="src/pages/fi/kotisivut.astro:h2-1">Nykyaikaiset kotisivut yrityksille Turussa ja Paraisilla</h2>
          <p class="text-zinc-700 leading-relaxed" data-ps="src/pages/fi/kotisivut.astro:p-1">
            Etsitkö yrityksellesi edullisia mutta laadukkaita kotisivuja Turun tai Paraisten alueelta? Meiltä saat täysin räätälöidyt verkkopalvelut sekä modernit ratkaisut. 
            Keskitymme erityisesti nopeuteen, käytettävyyteen ja tehokkaaseen <strong>Google-optimointiin</strong>, jotta sivustosi ei vain näytä hyvältä, vaan myös tuottaa tulosta.
          </p>
          <p class="text-zinc-700" data-ps="src/pages/fi/kotisivut.astro:p-intro-2">
            Tarjoamme markkinoiden kenties <strong>halvimmat kotisivut</strong> laadusta tinkimättä, hyödyntämällä uusimpia teknologioita ja automatisoituja työnkulkuja.
          </p>
        </div>
        <div class="relative rounded-2xl overflow-hidden shadow-xl border border-zinc-200 aspect-video md:aspect-square" data-ps="src/pages/fi/kotisivut.astro:intro-image-container">
          <img 
            crossorigin="anonymous"
            src="https://images.unsplash.com/photo-1460925895917-afdab827c52f?auto=format&w=1200&q=80"
            srcset="https://images.unsplash.com/photo-1460925895917-afdab827c52f?auto=format&w=320&q=80 320w, https://images.unsplash.com/photo-1460925895917-afdab827c52f?auto=format&w=480&q=80 480w, https://images.unsplash.com/photo-1460925895917-afdab827c52f?auto=format&w=640&q=80 640w, https://images.unsplash.com/photo-1460925895917-afdab827c52f?auto=format&w=768&q=80 768w, https://images.unsplash.com/photo-1460925895917-afdab827c52f?auto=format&w=1024&q=80 1024w"
            sizes="(max-width: 768px) 100vw, 50vw"
            alt="Kotisivut ja Google-optimointi Turku" 
            class="absolute inset-0 w-full h-full object-cover"
            loading="lazy" data-ps="src/pages/fi/kotisivut.astro:3gn17m" />
        </div>
      </div>

      <div class="my-20 bg-black rounded-3xl overflow-hidden border border-zinc-900 shadow-2xl" data-ps="src/pages/fi/kotisivut.astro:pagesmith-promo">
        <div class="grid md:grid-cols-2 items-stretch" data-ps="src/pages/fi/kotisivut.astro:promo-grid">
          <div class="p-8 md:p-14 flex flex-col justify-center" data-ps="src/pages/fi/kotisivut.astro:6ucpua">
            <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-orange-600/10 text-orange-600 text-sm font-bold mb-6 border border-orange-600/20 w-fit" data-ps="src/pages/fi/kotisivut.astro:badge">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/></svg>
              Moderni Websites Finland -teknologia
            </div>
            <h3 class="text-3xl md:text-4xl font-black text-white mt-0 mb-6 leading-tight" data-ps="src/pages/fi/kotisivut.astro:96zy1i">Ammattimaiset kotisivut nopeasti</h3>
            <p class="text-zinc-300 text-lg mb-8" data-ps="src/pages/fi/kotisivut.astro:n66jsh">Hyödynnämme uusinta teknologiaa, jonka avulla syntyvät näyttävät ja suorituskykyiset kotisivut yrityksille Turun ja Paraisten alueella. Tämä on täydellinen valinta, kun etsit <strong>edullisia kotisivuja</strong> laadusta tinkimättä.</p>
            <ul class="space-y-4 mb-0 list-none p-0">
              <li class="flex items-start gap-3 text-white" data-ps="src/pages/fi/kotisivut.astro:gbvx76">
                <div class="mt-1 flex-shrink-0 w-6 h-6 rounded-full bg-orange-700 flex items-center justify-center text-white font-black text-sm" data-ps="src/pages/fi/kotisivut.astro:ydww4">✓</div>
                <div data-ps="src/pages/fi/kotisivut.astro:ydww3"><strong class="text-white block">Erittäin nopea julkaisu</strong> Valmiit sivut jopa muutamassa päivässä.</div>
              </li>
              <li class="flex items-start gap-3 text-white" data-ps="src/pages/fi/kotisivut.astro:gbvx77">
                <div class="mt-1 flex-shrink-0 w-6 h-6 rounded-full bg-orange-700 flex items-center justify-center text-white font-black text-sm" data-ps="src/pages/fi/kotisivut.astro:ydww2">✓</div>
                <div data-ps="src/pages/fi/kotisivut.astro:ydwvg"><strong class="text-white block">Moderni & Responsiivinen</strong> Sivut toimivat täydellisesti kaikilla laitteilla.</div>
              </li>
              <li class="flex items-start gap-3 text-white" data-ps="src/pages/fi/kotisivut.astro:gbvx78">
                <div class="mt-1 flex-shrink-0 w-6 h-6 rounded-full bg-orange-700 flex items-center justify-center text-white font-black text-sm" data-ps="src/pages/fi/kotisivut.astro:ydwvf">✓</div>
                <div data-ps="src/pages/fi/kotisivut.astro:ydwve"><strong class="text-white block">Valmis Google-optimointi</strong> Hakukonenäkyvyys on rakennettu suoraan sivustoon.</div>
              </li>
            </ul>
          </div>
          <div class="min-h-[400px] relative bg-zinc-900" data-ps="src/pages/fi/kotisivut.astro:6ucpuc">
            <img 
              crossorigin="anonymous"
              src="https://images.unsplash.com/photo-1498050108023-c5249f4df085?auto=format&w=1200&q=80"
              srcset="https://images.unsplash.com/photo-1498050108023-c5249f4df085?auto=format&w=800&q=80 800w, https://images.unsplash.com/photo-1498050108023-c5249f4df085?auto=format&w=1200&q=80 1200w"
              sizes="(max-width: 768px) 100vw, 50vw"
              alt="Koodaus ja verkkopalvelut" 
              class="absolute inset-0 w-full h-full object-cover opacity-80"
              loading="lazy" data-ps="src/pages/fi/kotisivut.astro:3gn17l" />
          </div>
        </div>
      </div>

      <div class="text-center mb-12" data-ps="src/pages/fi/kotisivut.astro:services-intro">
        <h2 class="text-3xl font-black text-black mb-4" data-ps="src/pages/fi/kotisivut.astro:96zy1j">Palvelut eri tarpeisiin</h2>
        <p class="text-zinc-600 max-w-2xl mx-auto" data-ps="src/pages/fi/kotisivut.astro:services-p">Tarjoamme joustavat ratkaisut niin pienille kuin suurillekin yrityksille Turussa ja Paraisilla.</p>
      </div>

      <div class="grid md:grid-cols-2 gap-6 mb-20" data-ps="src/pages/fi/kotisivut.astro:grid">
        <div class="bg-white p-8 rounded-2xl border border-zinc-200 hover:border-orange-500 transition-all group shadow-sm" data-ps="src/pages/fi/kotisivut.astro:card-1">
          <div class="w-12 h-12 bg-orange-600/10 rounded-xl flex items-center justify-center text-orange-700 mb-6 group-hover:scale-110 transition-transform" data-ps="src/pages/fi/kotisivut.astro:icon-1">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/></svg>
          </div>
          <h3 class="text-xl font-black text-black mt-0 mb-3" data-ps="src/pages/fi/kotisivut.astro:h3-1">Edulliset Kotisivut</h3>
          <p class="text-zinc-600 text-base leading-relaxed mb-0" data-ps="src/pages/fi/kotisivut.astro:p-2">Nopeat yhden sivun kokonaisuudet, jotka toimivat yrityksesi tehokkaana käyntikorttina verkossa. Ideaalinen pienyrityksille, jotka etsivät halvimmat kotisivut -ratkaisua.</p>
        </div>
        <div class="bg-white p-8 rounded-2xl border border-zinc-200 hover:border-orange-500 transition-all group shadow-sm" data-ps="src/pages/fi/kotisivut.astro:card-2">
          <div class="w-12 h-12 bg-orange-600/10 rounded-xl flex items-center justify-center text-orange-700 mb-6 group-hover:scale-110 transition-transform" data-ps="src/pages/fi/kotisivut.astro:icon-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="7" height="7" x="3" y="3" rx="1"/><rect width="7" height="7" x="14" y="3" rx="1"/><rect width="7" height="7" x="14" y="14" rx="1"/><rect width="7" height="7" x="3" y="14" rx="1"/></svg>
          </div>
          <h3 class="text-xl font-black text-black mt-0 mb-3" data-ps="src/pages/fi/kotisivut.astro:h3-2">Laajat Verkkopalvelut</h3>
          <p class="text-zinc-600 text-base leading-relaxed mb-0" data-ps="src/pages/fi/kotisivut.astro:p-3">Monipuoliset sivustot, joissa on useita alasivuja, blogi tai asiantuntija-artikkeleita. Täydellinen kasvaville yrityksille, jotka tarvitsevat jatkuvaa Google-optimointia.</p>
        </div>
        <div class="bg-white p-8 rounded-2xl border border-zinc-200 hover:border-orange-500 transition-all group shadow-sm" data-ps="src/pages/fi/kotisivut.astro:card-3">
          <div class="w-12 h-12 bg-orange-600/10 rounded-xl flex items-center justify-center text-orange-700 mb-6 group-hover:scale-110 transition-transform" data-ps="src/pages/fi/kotisivut.astro:icon-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="8" cy="21" r="1"/><circle cx="19" cy="21" r="1"/><path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12"/></svg>
          </div>
          <h3 class="text-xl font-black text-black mt-0 mb-3" data-ps="src/pages/fi/kotisivut.astro:h3-3">Verkkokaupat</h3>
          <p class="text-zinc-600 text-base leading-relaxed mb-0" data-ps="src/pages/fi/kotisivut.astro:p-4">Täydelliset myyntialustat tuotteiden ja palveluiden suoraan verkkomyyntiin. Käytämme luotettavia alustoja kuten WooCommerce, jotta myynti on sujuvaa.</p>
        </div>
        <div class="bg-white p-8 rounded-2xl border border-zinc-200 hover:border-orange-500 transition-all group shadow-sm" data-ps="src/pages/fi/kotisivut.astro:card-4">
          <div class="w-12 h-12 bg-orange-600/10 rounded-xl flex items-center justify-center text-orange-700 mb-6 group-hover:scale-110 transition-transform" data-ps="src/pages/fi/kotisivut.astro:icon-4">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
          </div>
          <h3 class="text-xl font-black text-black mt-0 mb-3" data-ps="src/pages/fi/kotisivut.astro:h3-4">Erikoisratkaisut</h3>
          <p class="text-zinc-600 text-base leading-relaxed mb-0" data-ps="src/pages/fi/kotisivut.astro:p-5">Vaativammat järjestelmät ja räätälöidyt sovellukset (PHP, Python, JS). Websites Finland -osaamisemme takaa parhaan suorituskyvyn haastaviinkin tarpeisiin.</p>
        </div>
      </div>

      <div class="grid md:grid-cols-2 gap-12 mb-20 items-center" data-ps="src/pages/fi/kotisivut.astro:seo-section">
        <div class="order-2 md:order-1" data-ps="src/pages/fi/kotisivut.astro:seo-text">
          <h3 class="text-2xl font-black text-black mb-6" data-ps="src/pages/fi/kotisivut.astro:h3-5">Kokonaisvaltainen Google Optimointi</h3>
          <p class="text-zinc-700 mb-6" data-ps="src/pages/fi/kotisivut.astro:p-6">Huolehdimme puolestasi kaikista kriittisistä osa-alueista, jotta kotisivusi näkyvät Googlessa ja muut hakukoneet löytävät ne helposti:</p>
          <ul class="space-y-3 list-none p-0" data-ps="src/pages/fi/kotisivut.astro:ul-1">
            <li class="flex items-center gap-3 text-zinc-700 font-medium" data-ps="src/pages/fi/kotisivut.astro:li-1"><span class="w-2 h-2 rounded-full bg-orange-700" data-ps="src/pages/fi/kotisivut.astro:g70i4t"></span> Verkkotunnukset ja niiden hallinta</li>
            <li class="flex items-center gap-3 text-zinc-700 font-medium" data-ps="src/pages/fi/kotisivut.astro:li-2"><span class="w-2 h-2 rounded-full bg-orange-700" data-ps="src/pages/fi/kotisivut.astro:g70i4u"></span> Luotettava ja nopea webhotelli</li>
            <li class="flex items-center gap-3 text-zinc-700 font-medium" data-ps="src/pages/fi/kotisivut.astro:li-3"><span class="w-2 h-2 rounded-full bg-orange-700" data-ps="src/pages/fi/kotisivut.astro:g70i4v"></span> Google Analytics & Search Console</li>
            <li class="flex items-center gap-3 text-zinc-700 font-medium" data-ps="src/pages/fi/kotisivut.astro:li-4"><span class="w-2 h-2 rounded-full bg-orange-700" data-ps="src/pages/fi/kotisivut.astro:g70i4w"></span> Sisällöntuotanto ja SEO-analyysit</li>
          </ul>
        </div>
        <div class="order-1 md:order-2 bg-gradient-to-br from-blue-600/20 to-zinc-900 p-8 rounded-3xl border border-zinc-800" data-ps="src/pages/fi/kotisivut.astro:seo-visual">
          <div class="space-y-4" data-ps="src/pages/fi/kotisivut.astro:ydwvd">
            <div class="h-8 bg-zinc-800/50 rounded-lg w-full flex items-center px-4 gap-2" data-ps="src/pages/fi/kotisivut.astro:ydwvc">
              <div class="w-2 h-2 rounded-full bg-red-400" data-ps="src/pages/fi/kotisivut.astro:ydwvb"></div>
              <div class="w-2 h-2 rounded-full bg-yellow-400" data-ps="src/pages/fi/kotisivut.astro:ydwva"></div>
              <div class="w-2 h-2 rounded-full bg-green-400" data-ps="src/pages/fi/kotisivut.astro:ydwv9"></div>
              <div class="h-2 bg-zinc-700 rounded w-24 ml-2" data-ps="src/pages/fi/kotisivut.astro:ydwv8"></div>
            </div>
            <div class="p-4 bg-zinc-800/30 rounded-lg border border-zinc-700/50" data-ps="src/pages/fi/kotisivut.astro:ydwv7">
              <div class="h-3 bg-blue-400/30 rounded w-3/4 mb-3" data-ps="src/pages/fi/kotisivut.astro:6ucpu3"></div>
              <div class="h-2 bg-zinc-600/30 rounded w-full mb-2" data-ps="src/pages/fi/kotisivut.astro:6ucpu4"></div>
              <div class="h-2 bg-zinc-600/30 rounded w-5/6" data-ps="src/pages/fi/kotisivut.astro:6ucpu5"></div>
            </div>
            <div class="p-4 bg-zinc-800/30 rounded-lg border border-zinc-700/50" data-ps="src/pages/fi/kotisivut.astro:6ucpu6">
              <div class="h-3 bg-blue-400/30 rounded w-2/3 mb-3" data-ps="src/pages/fi/kotisivut.astro:6ucpu7"></div>
              <div class="h-2 bg-zinc-600/30 rounded w-full mb-2" data-ps="src/pages/fi/kotisivut.astro:6ucpu8"></div>
              <div class="h-2 bg-zinc-600/30 rounded w-4/5" data-ps="src/pages/fi/kotisivut.astro:6ucpu9"></div>
            </div>
          </div>
          <p class="text-center text-xs text-zinc-500 mt-6 uppercase tracking-widest" data-ps="src/pages/fi/kotisivut.astro:80ihop">Search Engine Optimization</p>
        </div>
      </div>

      <div class="bg-black border border-zinc-900 rounded-3xl p-10 md:p-14 text-center relative overflow-hidden shadow-2xl" data-ps="src/pages/fi/kotisivut.astro:cta">
        <div class="relative z-10" data-ps="src/pages/fi/kotisivut.astro:6ucpua">
          <h2 class="text-3xl md:text-4xl font-black text-white mt-0 mb-6" data-ps="src/pages/fi/kotisivut.astro:cta-h3">Pyydä tarjous jo tänään</h2>
          <p class="text-zinc-300 text-lg mb-10 max-w-2xl mx-auto" data-ps="src/pages/fi/kotisivut.astro:cta-p">Autamme sinua valitsemaan juuri oikeanlaisen ratkaisun yrityksesi liiketoiminnan tueksi Turun ja Paraisten alueella. Laadukkaat kotisivut ja ammattimainen lopputulos.</p>
          <a href="/fi/yhteystiedot" class="inline-flex items-center gap-2 bg-orange-700 hover:bg-orange-800 text-white font-black py-4 px-10 rounded-full transition-all hover:scale-105 no-underline shadow-xl" data-ps="src/pages/fi/kotisivut.astro:cta-a">
            Ota yhteyttä
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>
        <div class="absolute top-0 right-0 -mr-20 -mt-20 w-64 h-64 bg-blue-500/10 rounded-full blur-3xl" data-ps="src/pages/fi/kotisivut.astro:6ucpub"></div>
        <div class="absolute bottom-0 left-0 -ml-20 -mb-20 w-64 h-64 bg-indigo-500/10 rounded-full blur-3xl" data-ps="src/pages/fi/kotisivut.astro:6ucpuc"></div>
      </div>
    </div>
  </div>
</BaseLayout>
