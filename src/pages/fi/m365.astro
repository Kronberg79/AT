---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHeader from '@/components/PageHeader.astro';

const lang = 'fi';
---

<BaseLayout
  title="Microsoft 365 Yrityksille | Archipelago Technics"
  description="Olemme virallinen Microsoft-kumppani. Tarjoamme kaikki Microsoft 365 -ratkaisut, asennukset ja tuen yrityksellesi."
>
  <PageHeader
    title="Microsoft 365"
    subtitle="Tehokkuutta, turvallisuutta ja yhteistyötä yrityksellesi"
  />

  <section class="py-24 bg-white" data-ps="src/pages/fi/m365.astro:6lkn72">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8" data-ps="src/pages/fi/m365.astro:d3uvcp">
      <div class="grid lg:grid-cols-2 gap-16 items-center mb-24" data-ps="src/pages/fi/m365.astro:d3uvco">
        <div data-ps="src/pages/fi/m365.astro:ggmtc0">
          <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-blue-50 text-blue-700 text-sm font-bold mb-6" data-ps="src/pages/fi/m365.astro:ggmtbz">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M11.4 24H0V12.6h11.4V24zM24 24H12.6V12.6H24V24zM11.4 11.4H0V0h11.4v11.4zM24 11.4H12.6V0H24v11.4z"/></svg>
            Microsoft Partner
          </div>
          <h2 class="text-4xl font-black text-zinc-900 mb-6 leading-tight" data-ps="src/pages/fi/m365.astro:qex6w5">Olemme valtuutettu Microsoft-kumppanisi</h2>
          <p class="text-lg text-zinc-600 mb-8 leading-relaxed" data-ps="src/pages/fi/m365.astro:9tuiv1">
            Archipelago Technics on virallinen Microsoft-kumppani. Autamme yritystänne valitsemaan oikeat lisenssit, suorittamaan siirtymän pilveen ja varmistamaan, että tietoturva on huippuluokkaa. Tarjoamme kaikki mahdolliset ratkaisut, joita tarvitset liiketoimintasi pyörittämiseen.
          </p>
          <ul class="space-y-4 mb-10">
            {[
              'Asiantunteva lisenssien hallinta',
              'Sähköpostien ja tiedostojen siirto',
              'Advanced Threat Protection (ATP)',
              'Jatkuva tuki ja ylläpito'
            ].map(item => (
              <li class="flex items-center gap-3 text-zinc-800 font-bold" data-ps="src/pages/fi/m365.astro:pnyaec">
                <svg class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
                </svg>
                {item}
              </li>
            ))}
          </ul>
          <a href="/fi/yhteystiedot" class="inline-flex items-center justify-center px-8 py-4 text-lg font-bold text-white bg-blue-600 hover:bg-blue-700 rounded-xl transition-all shadow-lg shadow-blue-200" data-ps="src/pages/fi/m365.astro:gxsfk6">
            Ota yhteyttä asiantuntijaan
          </a>
        </div>
        <div class="relative" data-ps="src/pages/fi/m365.astro:ggmtby">
          <img crossorigin="anonymous" src="https://images.unsplash.com/photo-1758876021739-d7c60b8742a5?auto=format&w=800&q=80" 
            alt="Microsoft 365 Business" 
            class="rounded-3xl shadow-2xl relative z-10" data-ps="src/pages/fi/m365.astro:fm3zo7" />
          <div class="absolute -bottom-6 -right-6 w-64 h-64 bg-blue-600/10 rounded-full blur-3xl -z-10" data-ps="src/pages/fi/m365.astro:ggmtbx"></div>
        </div>
      </div>

      <div class="grid md:grid-cols-3 gap-8 mb-24" data-ps="src/pages/fi/m365.astro:ggmtbw">
        {[
          {
            title: 'Microsoft 365 Business Basic',
            desc: 'Parhaat palvelut yrityksille, jotka tarvitsevat helppoja etäratkaisuja, pilvitallennustilaa ja pilvipalveluita.',
            features: ['Teams, Exchange, OneDrive', 'Web- ja mobiiliversiot Office-sovelluksista', '1 Tt pilvitallennustilaa']
          },
          {
            title: 'Microsoft 365 Business Standard',
            desc: 'Täydellinen ratkaisu yrityksille, jotka tarvitsevat täydet Office-sovellukset kaikkiin laitteisiin.',
            features: ['Kaikki Basic-ominaisuudet', 'Työpöytäversiot Outlookista, Wordista, Excelistä jne.', 'Isännöi webinaareja helposti']
          },
          {
            title: 'Microsoft 365 Business Premium',
            desc: 'Kattavin ratkaisu, joka sisältää kehittyneen tietoturvan ja laitehallinnan.',
            features: ['Kaikki Standard-ominaisuudet', 'Kehittynyt kyberturvallisuus', 'Laitehallinta (Intune)']
          }
        ].map(plan => (
          <div class="p-10 rounded-3xl border border-zinc-100 bg-zinc-50 hover:bg-white hover:shadow-xl transition-all group" data-ps="src/pages/fi/m365.astro:ggmtbv">
            <h3 class="text-2xl font-black text-zinc-900 mb-4" data-ps="src/pages/fi/m365.astro:txrxve">{plan.title}</h3>
            <p class="text-zinc-600 mb-8 leading-relaxed" data-ps="src/pages/fi/m365.astro:9tuiv2">{plan.desc}</p>
            <ul class="space-y-3">
              {plan.features.map(f => (
                <li class="flex gap-2 text-sm text-zinc-700 font-medium" data-ps="src/pages/fi/m365.astro:pnyaeb">
                  <span class="text-blue-600" data-ps="src/pages/fi/m365.astro:cs72bj">•</span> {f}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>

      <div class="bg-zinc-900 rounded-[3rem] p-12 md:p-20 text-center overflow-hidden relative" data-ps="src/pages/fi/m365.astro:ggmtbu">
        <div class="absolute inset-0 bg-gradient-to-br from-blue-600/20 to-transparent opacity-50" data-ps="src/pages/fi/m365.astro:ggmtbt"></div>
        <div class="relative z-10 max-w-3xl mx-auto" data-ps="src/pages/fi/m365.astro:ggmtbs">
          <h2 class="text-3xl md:text-5xl font-black text-white mb-8" data-ps="src/pages/fi/m365.astro:qex6w4">Tarvitsetko apua valinnassa?</h2>
          <p class="text-xl text-zinc-400 mb-12" data-ps="src/pages/fi/m365.astro:9tuiv3">
            Autamme sinua valitsemaan juuri oikean Microsoft 365 -paketin yrityksesi tarpeisiin. Hoidamme kaiken puolestasi avaimet käteen -periaatteella.
          </p>
          <div class="flex flex-wrap justify-center gap-6" data-ps="src/pages/fi/m365.astro:ggmtbr">
            <a href="tel:+358405829704" class="px-8 py-4 bg-white text-zinc-900 font-bold rounded-xl hover:scale-105 transition-transform" data-ps="src/pages/fi/m365.astro:gxsfk7">
              Soita: 040 582 9704
            </a>
            <a href="/fi/yhteystiedot" class="px-8 py-4 bg-transparent border-2 border-white/20 text-white font-bold rounded-xl hover:bg-white/10 transition-colors" data-ps="src/pages/fi/m365.astro:gxsfk8">
              Lähetä viesti
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
