---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHeader from '@/components/PageHeader.astro';

const title = "Palvelinhuolto ja Pilviratkaisut | Archipelago Technics";
const description = "Asiantuntevat palvelinhuollot, päivitykset ja migraatiot. Varmistamme palvelimiesi tietoturvan ja toimintavarmuuden.";
---

<BaseLayout title={title} description={description} lang="fi">
  <PageHeader title={title} description={description} />
  
  <div class="max-w-7xl mx-auto px-6 py-16" data-ps="src/pages/fi/serverihuolto.astro:7wpnyy">
    <div class="grid lg:grid-cols-2 gap-12 mb-16" data-ps="src/pages/fi/serverihuolto.astro:7wpnyx">
      <div class="prose prose-lg prose-invert" data-ps="src/pages/fi/serverihuolto.astro:7wpnyw">
        <h2 class="text-3xl font-bold text-white mb-6" data-ps="src/pages/fi/serverihuolto.astro:v575bt">Hyvää asiantuntijapalvelua vuosien kokemuksella</h2>
        <p data-ps="src/pages/fi/serverihuolto.astro:7x9pky">
          Etsitkö luotettavaa kumppania palvelimiesi huoltoon, päivityksiin tai migraatioihin? 
          Me olemme erikoistuneet servereiden ylläpitoon ja vikatilanteiden ratkaisuun – nopeasti, 
          turvallisesti ja asiantuntevasti. Palvelemme teitä vielä saman päivän aikana!
        </p>
        <p data-ps="src/pages/fi/serverihuolto.astro:7x9pkx">
          Valitse meidät, kun haluat varmistaa palvelinympäristösi jatkuvan toimivuuden ja turvallisuuden.
        </p>
        <div class="mt-8" data-ps="src/pages/fi/serverihuolto.astro:7wpnyv">
          <a href="/fi/yhteystiedot" class="bg-orange-600 hover:bg-orange-700 text-white font-bold py-3 px-6 rounded-lg transition" data-ps="src/pages/fi/serverihuolto.astro:tbsv5">
            Ota yhteyttä
          </a>
        </div>
      </div>
      <div data-ps="src/pages/fi/serverihuolto.astro:7wpnyu">
        <img crossorigin="anonymous" src="https://images.unsplash.com/photo-1680992046617-e2e35451bcdb?auto=format&w=800&q=80" 
          class="rounded-xl shadow-2xl w-full h-full object-cover" 
          alt="Serverihuolto" data-ps="src/pages/fi/serverihuolto.astro:yl0lbu" />
      </div>
    </div>

    <div class="grid md:grid-cols-2 gap-8" data-ps="src/pages/fi/serverihuolto.astro:7wpnyt">
      <div class="bg-zinc-900 p-8 rounded-xl border border-zinc-800" data-ps="src/pages/fi/serverihuolto.astro:7wpnys">
        <h3 class="text-2xl font-bold text-orange-500 mb-4" data-ps="src/pages/fi/serverihuolto.astro:ggs845">Serverihuolto ja ylläpito</h3>
        <p class="text-zinc-300 mb-4" data-ps="src/pages/fi/serverihuolto.astro:7x9pkw">
          Palvelimien säännöllinen huolto on kriittinen osa yrityksesi IT-infrastruktuurin toimintavarmuutta. 
          Tarjoamme kattavat serverihuoltopalvelut, joihin sisältyvät mm.:
        </p>
        <ul class="list-disc list-inside text-zinc-300 space-y-2">
          <li data-ps="src/pages/fi/serverihuolto.astro:vw61sq">Laitteiston ja ohjelmistojen tarkastukset</li>
          <li data-ps="src/pages/fi/serverihuolto.astro:vw61sr">Suorituskyvyn optimointi</li>
          <li data-ps="src/pages/fi/serverihuolto.astro:vw61ss">Tietoturvapäivitykset ja varmuuskopiointiratkaisut</li>
          <li data-ps="src/pages/fi/serverihuolto.astro:vw61te">Ennakoiva huolto ja vikojen ehkäisy</li>
        </ul>
      </div>

      <div class="bg-zinc-900 p-8 rounded-xl border border-zinc-800" data-ps="src/pages/fi/serverihuolto.astro:7wpnyr">
        <h3 class="text-2xl font-bold text-orange-500 mb-4" data-ps="src/pages/fi/serverihuolto.astro:ggs846">Serveripäivitykset ja modernisointi</h3>
        <p class="text-zinc-300 mb-4" data-ps="src/pages/fi/serverihuolto.astro:7x9pkv">
          Teknologia kehittyy nopeasti – me varmistamme, että palvelimesi pysyvät ajan tasalla. 
          Olemme erikoistuneet vanhojen järjestelmien (kuten Windows Server 2008) päivittämiseen 
          nykyaikaisiin ja tuettuihin versioihin.
        </p>
        <p class="text-zinc-300" data-ps="src/pages/fi/serverihuolto.astro:7x9pk9">
          Päivitys tuo mukanaan paremman suorituskyvyn, tietoturvan ja yhteensopivuuden uusien sovellusten kanssa.
        </p>
      </div>

      <div class="bg-zinc-900 p-8 rounded-xl border border-zinc-800" data-ps="src/pages/fi/serverihuolto.astro:7wpnyq">
        <h3 class="text-2xl font-bold text-orange-500 mb-4" data-ps="src/pages/fi/serverihuolto.astro:ggs847">Serverimigraatiot</h3>
        <p class="text-zinc-300 mb-4" data-ps="src/pages/fi/serverihuolto.astro:7x9pk8">
          Suunnitteletko siirtymistä uuteen palvelinympäristöön tai pilvipalveluihin? 
          Toteutamme serverimigraatiot hallitusti ja ilman katkoksia liiketoiminnallesi.
        </p>
        <ul class="list-disc list-inside text-zinc-300 space-y-2">
          <li data-ps="src/pages/fi/serverihuolto.astro:vw61tf">Nykytilan kartoitus ja suunnittelu</li>
          <li data-ps="src/pages/fi/serverihuolto.astro:vw61tg">Datan ja palveluiden siirto</li>
          <li data-ps="src/pages/fi/serverihuolto.astro:vw61th">Testaus ja käyttöönotto</li>
          <li data-ps="src/pages/fi/serverihuolto.astro:vw61ti">Käyttäjien opastus ja tuki</li>
        </ul>
      </div>

      <div class="bg-zinc-900 p-8 rounded-xl border border-zinc-800" data-ps="src/pages/fi/serverihuolto.astro:7wpnyp">
        <h3 class="text-2xl font-bold text-orange-500 mb-4" data-ps="src/pages/fi/serverihuolto.astro:ggs848">Vikatilanteet ja hätäpalvelu</h3>
        <p class="text-zinc-300 mb-4" data-ps="src/pages/fi/serverihuolto.astro:7x9pk7">
          Palvelinongelmat voivat aiheuttaa merkittäviä häiriöitä. Asiantuntijamme ovat valmiina auttamaan 
          kaikissa vikatilanteissa – olipa kyseessä laitteistovika, ohjelmiston kaatuminen tai tietoturvaongelma.
        </p>
        <p class="text-zinc-300" data-ps="src/pages/fi/serverihuolto.astro:7x9pk6">
          Reagoimme nopeasti ja palautamme järjestelmäsi toimintakuntoon.
        </p>
      </div>
    </div>
  </div>
</BaseLayout>
