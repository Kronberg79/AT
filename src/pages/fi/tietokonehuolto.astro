---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHeader from '@/components/PageHeader.astro';

const title = "Tietokonehuolto ja Tietojen Palautus Turku | Archipelago Technics";
const description = "Nopea ja luotettava tietokonehuolto ja tietojen palautus Turussa. Korjaamme laitteistoviat ja ohjelmisto-ongelmat.";
---

<BaseLayout title={title} description={description} lang="fi">
  <PageHeader title={title} description={description} />
  
  <div class="max-w-7xl mx-auto px-6 py-16" data-ps="src/pages/fi/tietokonehuolto.astro:dltu4g">
    <div class="grid lg:grid-cols-2 gap-12 items-center mb-16" data-ps="src/pages/fi/tietokonehuolto.astro:dltu4h">
      <div class="prose prose-lg prose-invert" data-ps="src/pages/fi/tietokonehuolto.astro:dltu4i">
        <h2 class="text-3xl font-bold text-white mb-6" data-ps="src/pages/fi/tietokonehuolto.astro:3h2s0m">Tietokonehuolto & IT-tuki</h2>
        <p class="lead text-xl text-orange-500 font-semibold" data-ps="src/pages/fi/tietokonehuolto.astro:hx05i4">
          Älä anna teknologian haitata yrityksesi kasvua!
        </p>
        <p data-ps="src/pages/fi/tietokonehuolto.astro:hx05i5">
          Tarjoamme kattavat tietokonehuollot ja IT-ratkaisut sekä yrityksille että kuluttajille.
          Hoidamme laitteistoviat, ohjelmisto-ongelmat ja tietojen palautukset ammattitaidolla.
        </p>
        <p data-ps="src/pages/fi/tietokonehuolto.astro:hx05i6">
          Palvelemme myymälässä sekä teemme yritys- ja kotikäyntejä tarpeen mukaan.
        </p>
        
        <div class="mt-8 not-prose" data-ps="src/pages/fi/tietokonehuolto.astro:db4gu2">
          <h3 class="text-xl font-bold text-white mb-4" data-ps="src/pages/fi/tietokonehuolto.astro:b7c572">Hinnasto ja palvelut</h3>
          <p class="text-zinc-400 mb-6" data-ps="src/pages/fi/tietokonehuolto.astro:hx05i7">Katso tarkemmat hinnat tai pyydä tarjous huollosta.</p>
          <div class="flex gap-4" data-ps="src/pages/fi/tietokonehuolto.astro:db4gu1">
            <a href="/fi/yhteystiedot" class="bg-orange-600 hover:bg-orange-700 text-white font-bold py-3 px-6 rounded-lg transition" data-ps="src/pages/fi/tietokonehuolto.astro:p0y27x">
              Ota yhteyttä
            </a>
          </div>
        </div>
      </div>
      <div data-ps="src/pages/fi/tietokonehuolto.astro:db4gu0">
        <img crossorigin="anonymous" src="https://images.unsplash.com/photo-1758686254545-2e8a33d39adb?auto=format&w=800&q=80" 
          class="rounded-xl shadow-2xl w-full h-full object-cover" 
          alt="Tietokonehuolto" data-ps="src/pages/fi/tietokonehuolto.astro:b3kpsz" />
      </div>
    </div>

    <div class="grid md:grid-cols-3 gap-8" data-ps="src/pages/fi/tietokonehuolto.astro:db4gtz">
      <div class="bg-zinc-900 p-6 rounded-xl border border-zinc-800 text-center" data-ps="src/pages/fi/tietokonehuolto.astro:db4gty">
        <div class="text-orange-500 text-4xl mb-4" data-ps="src/pages/fi/tietokonehuolto.astro:db4gtx">💻</div>
        <h3 class="text-xl font-bold text-white mb-2" data-ps="src/pages/fi/tietokonehuolto.astro:b7c571">Huollot</h3>
        <p class="text-zinc-400" data-ps="src/pages/fi/tietokonehuolto.astro:hx05i8">Nopeat ja luotettavat huollot kaikille merkeille.</p>
      </div>
      <div class="bg-zinc-900 p-6 rounded-xl border border-zinc-800 text-center" data-ps="src/pages/fi/tietokonehuolto.astro:db4gtw">
        <div class="text-orange-500 text-4xl mb-4" data-ps="src/pages/fi/tietokonehuolto.astro:db4gtv">💾</div>
        <h3 class="text-xl font-bold text-white mb-2" data-ps="src/pages/fi/tietokonehuolto.astro:b7c570">Tietojen pelastus</h3>
        <p class="text-zinc-400" data-ps="src/pages/fi/tietokonehuolto.astro:hx05i9">Pelastamme tärkeät tiedostosi rikkoutuneilta laitteilta.</p>
      </div>
      <div class="bg-zinc-900 p-6 rounded-xl border border-zinc-800 text-center" data-ps="src/pages/fi/tietokonehuolto.astro:db4gtu">
        <div class="text-orange-500 text-4xl mb-4" data-ps="src/pages/fi/tietokonehuolto.astro:db4gtt">🏠</div>
        <h3 class="text-xl font-bold text-white mb-2" data-ps="src/pages/fi/tietokonehuolto.astro:b7c56z">Kotikäynnit</h3>
        <p class="text-zinc-400" data-ps="src/pages/fi/tietokonehuolto.astro:hx05iv">Tulemme paikan päälle ratkaisemaan ongelmasi.</p>
      </div>
    </div>
  </div>
</BaseLayout>
