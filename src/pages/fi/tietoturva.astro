---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHeader from '@/components/PageHeader.astro';

const title = "Tietoturvapalvelut ja Kyberturvallisuus | Archipelago Technics";
const description = "Kattavat tietoturvaratkaisut yrityksesi suojaamiseksi. Päätelaitteiden suojaus, palomuurit ja henkilöstön tietoturvakoulutus.";
---

<BaseLayout title={title} description={description} lang="fi">
  <PageHeader title={title} description={description} />
  
  <div class="max-w-7xl mx-auto px-6 py-12" data-ps="src/pages/fi/tietoturva.astro:s5s8iu">
    <div class="grid md:grid-cols-2 gap-12 items-center mb-24" data-ps="src/pages/fi/tietoturva.astro:s5s8it">
      <div class="prose prose-invert prose-lg" data-ps="src/pages/fi/tietoturva.astro:s5s8is">
        <p class="lead" data-ps="src/pages/fi/tietoturva.astro:cn5oh3">Tietoturva ei ole vain tekninen kysymys; se on liiketoiminnan perusedellytys.</p>
        <p data-ps="src/pages/fi/tietoturva.astro:cn5oh2">Lisääntyvien kiristysohjelma- ja tietojenkalasteluhyökkäysten aikakaudella pelkkä virustorjunta ei enää riitä. Tarjoamme monikerroksisen puolustusstrategian, joka suojaa identiteettisi, tietosi ja infrastruktuurisi.</p>
        <p data-ps="src/pages/fi/tietoturva.astro:y8s970">Ennakoivasta valvonnasta henkilöstön koulutukseen – varmistamme, että organisaatiosi pysyy vastustuskykyisenä kehittyviä digitaalisia uhkia vastaan.</p>
      </div>
      <div data-ps="src/pages/fi/tietoturva.astro:s5s8ir">
        <img 
            crossorigin="anonymous"
            src="https://images.unsplash.com/photo-1768839721176-2fa91fdce725?auto=format&w=800&q=80" 
            srcset="https://images.unsplash.com/photo-1768839721176-2fa91fdce725?auto=format&w=400&q=80 400w, https://images.unsplash.com/photo-1768839721176-2fa91fdce725?auto=format&w=800&q=80 800w"
            class="rounded-xl shadow-2xl w-full" 
            alt="Tietoturvasuoja" data-ps="src/pages/fi/tietoturva.astro:d02ut1" />
      </div>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6 mb-24" data-ps="src/pages/fi/tietoturva.astro:klyoi4">
      <div class="bg-neutral-900 border border-white/10 p-6 rounded-xl" data-ps="src/pages/fi/tietoturva.astro:s5s8j0">
        <h3 class="font-bold text-lg mb-2" data-ps="src/pages/fi/tietoturva.astro:ik1oux">Päätelaitteiden suojaus</h3>
        <p class="text-sm text-neutral-400" data-ps="src/pages/fi/tietoturva.astro:y8s971">Kehittynyt suojaus kannettaville, pöytäkoneille ja mobiililaitteille reaaliaikaisella uhkien tunnistuksella.</p>
      </div>
      <div class="bg-neutral-900 border border-white/10 p-6 rounded-xl" data-ps="src/pages/fi/tietoturva.astro:s5s8iz">
        <h3 class="font-bold text-lg mb-2" data-ps="src/pages/fi/tietoturva.astro:ik1ouw">Sähköpostin suojaus</h3>
        <p class="text-sm text-neutral-400" data-ps="src/pages/fi/tietoturva.astro:y8s972">Suodatusjärjestelmät, jotka estävät kalasteluviestit, haittaohjelmat ja roskapostin ennen kuin ne saavuttavat postilaatikkosi.</p>
      </div>
      <div class="bg-neutral-900 border border-white/10 p-6 rounded-xl" data-ps="src/pages/fi/tietoturva.astro:s5s8iy">
        <h3 class="font-bold text-lg mb-2" data-ps="src/pages/fi/tietoturva.astro:ik1ouv">Identiteetinhallinta</h3>
        <p class="text-sm text-neutral-400" data-ps="src/pages/fi/tietoturva.astro:y8s973">MFA:n (monivaiheinen tunnistautuminen) ja Zero Trust -pääsynhallinnan toteutus.</p>
      </div>
      <div class="bg-neutral-900 border border-white/10 p-6 rounded-xl" data-ps="src/pages/fi/tietoturva.astro:s5s8ix">
        <h3 class="font-bold text-lg mb-2" data-ps="src/pages/fi/tietoturva.astro:ik1ouu">Tietoturva-auditoinnit</h3>
        <p class="text-sm text-neutral-400" data-ps="src/pages/fi/tietoturva.astro:y8s974">Säännölliset haavoittuvuusskannaukset ja tietoturvatason arvioinnit heikkojen kohtien löytämiseksi.</p>
      </div>
    </div>

    <div class="bg-primary-950/20 border border-primary-900/50 p-12 rounded-3xl" data-ps="src/pages/fi/tietoturva.astro:s5s8iw">
      <div class="max-w-3xl mx-auto text-center mb-12" data-ps="src/pages/fi/tietoturva.astro:s5s8iv">
        <h2 class="text-3xl font-bold mb-4" data-ps="src/pages/fi/tietoturva.astro:3vmrn9">Inhimillinen tekijä</h2>
        <p class="text-neutral-400" data-ps="src/pages/fi/tietoturva.astro:y8s975">Teknologia on vain puoli voittoa. Tarjoamme tietoturvakoulutusta, joka tekee työntekijöistäsi vahvimman puolustuslinjasi.</p>
      </div>
      <div class="grid md:grid-cols-3 gap-8" data-ps="src/pages/fi/tietoturva.astro:s5s8iu">
        <div data-ps="src/pages/fi/tietoturva.astro:s5s8it">
          <h4 class="font-bold mb-2" data-ps="src/pages/fi/tietoturva.astro:x8gm2k">Kalastelusimulaatiot</h4>
          <p class="text-sm text-neutral-400" data-ps="src/pages/fi/tietoturva.astro:y8s976">Realistiset testitestit, joilla opetetaan henkilöstöä tunnistamaan ja raportoimaan epäilyttävät viestit.</p>
        </div>
        <div data-ps="src/pages/fi/tietoturva.astro:s5s8is">
          <h4 class="font-bold mb-2" data-ps="src/pages/fi/tietoturva.astro:x8gm2j">Tietoturvatyöpajat</h4>
          <p class="text-sm text-neutral-400" data-ps="src/pages/fi/tietoturva.astro:y8s977">Käytännön harjoitukset salasanojen hallinnasta ja turvallisista selaustavoista.</p>
        </div>
        <div data-ps="src/pages/fi/tietoturva.astro:s5s8ir">
          <h4 class="font-bold mb-2" data-ps="src/pages/fi/tietoturva.astro:x8gm2i">Säädöstenmukaisuus</h4>
          <p class="text-sm text-neutral-400" data-ps="src/pages/fi/tietoturva.astro:y8s97t">Varmistamme, että henkilöstö ymmärtää GDPR:n ja muiden säädösten vaatimukset tietojen käsittelyssä.</p>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>