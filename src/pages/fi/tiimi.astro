---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHeader from '@/components/PageHeader.astro';

const title = "Tutustu IT-asiantuntijoihimme | Archipelago Technics";
const description = "Tutustu Archipelago Technicsin kokeneeseen tiimiin. Paikalliset IT-ammattilaiset palveluksessasi Turun saaristossa.";
---

<BaseLayout title={title} description={description} lang="fi">
  <PageHeader title={title} description={description} />
  <div class="max-w-7xl mx-auto px-6 py-12 space-y-24" data-ps="src/pages/fi/tiimi.astro:fbor2x">
    <div class="grid md:grid-cols-2 gap-12 items-center" data-ps="src/pages/fi/tiimi.astro:fbor2w">
      <div class="prose prose-invert prose-lg" data-ps="src/pages/fi/tiimi.astro:fbor2v">
        <p class="lead" data-ps="src/pages/fi/tiimi.astro:vsfckm">Kokenut. Omistautunut. Paikallinen.</p>
        <p data-ps="src/pages/fi/tiimi.astro:vsfckn">Olemme joukko IT-ammattilaisia, joilla on intohimo teknologiaan ja asiakaspalveluun. Saaristossa toimivana ymmärrämme paikallisen yhteisömme ainutlaatuiset tarpeet.</p>
      </div>
      <div data-ps="src/pages/fi/tiimi.astro:fbor2u" class="flex flex-col gap-4">
        <img 
          src="https://cdn.pagesmith.app/eb31781e/images/ATcrew-1024-1024-1024.webp" 
          alt="Archipelago Technics Tiimi" 
          class="rounded-xl shadow-lg w-full aspect-[4/3] object-cover" data-ps="src/pages/fi/tiimi.astro:pu6c92" />
      </div>
    </div>

    <section class="space-y-12" data-ps="src/pages/fi/tiimi.astro:75hpky">
      <h2 class="text-3xl md:text-4xl font-bold text-center" data-ps="src/pages/fi/tiimi.astro:jh6bxw">Henkilöstö</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8" data-ps="src/pages/fi/tiimi.astro:fbor2x">
        <div class="bg-gray-800/50 p-8 rounded-2xl border border-gray-700/50 hover:border-blue-500/50 transition-colors" data-ps="src/pages/fi/tiimi.astro:fbor2w">
          <img 
            src="https://cdn.pagesmith.app/eb31781e/images/IMG_4582-256-256.webp" 
            alt="Kasper Kronberg" 
            class="w-32 h-32 rounded-full mx-auto mb-6 object-cover border-2 border-blue-500" data-ps="src/pages/fi/tiimi.astro:pu6c8x" />
          <div class="text-center" data-ps="src/pages/fi/tiimi.astro:fbor2v">
            <h3 class="text-xl font-bold mb-1" data-ps="src/pages/fi/tiimi.astro:jy7z2t">Kasper Kronberg</h3>
            <p class="text-blue-400 font-medium mb-4" data-ps="src/pages/fi/tiimi.astro:8ycxtn">CEO and Founder</p>
            <div class="space-y-1 text-gray-300" data-ps="src/pages/fi/tiimi.astro:fbor2u">
              <p data-ps="src/pages/fi/tiimi.astro:vsfckj"><a href="tel:+358451108777" class="hover:text-blue-400 transition-colors" data-ps="src/pages/fi/tiimi.astro:1uf13v">+358 45 110 8777</a></p>
              <p data-ps="src/pages/fi/tiimi.astro:vsfckk"><a href="mailto:kasper.kronberg@a-t.fi" class="hover:text-blue-400 transition-colors" data-ps="src/pages/fi/tiimi.astro:1uf13u">kasper.kronberg@a-t.fi</a></p>
            </div>
          </div>
        </div>

        <div class="bg-gray-800/50 p-8 rounded-2xl border border-gray-700/50 hover:border-blue-500/50 transition-colors" data-ps="src/pages/fi/tiimi.astro:kalle-card">
          <img 
            src="https://cdn.pagesmith.app/eb31781e/images/IMG_4580-200-200.webp" 
            alt="Kalle Jonsson" 
            class="w-32 h-32 rounded-full mx-auto mb-6 object-cover border-2 border-blue-500" data-ps="src/pages/fi/tiimi.astro:kalle-img" />
          <div class="text-center" data-ps="src/pages/fi/tiimi.astro:kalle-info">
            <h3 class="text-xl font-bold mb-1" data-ps="src/pages/fi/tiimi.astro:kalle-name">Kalle Jonsson</h3>
            <p class="text-blue-400 font-medium mb-4" data-ps="src/pages/fi/tiimi.astro:kalle-role">Myyntipäällikkö</p>
            <div class="space-y-1 text-gray-300" data-ps="src/pages/fi/tiimi.astro:kalle-contact">
              <p data-ps="src/pages/fi/tiimi.astro:kalle-phone"><a href="tel:+358405829767" class="hover:text-blue-400 transition-colors" data-ps="src/pages/fi/tiimi.astro:kalle-tel">+358 40 582 9767</a></p>
              <p data-ps="src/pages/fi/tiimi.astro:kalle-email-p"><a href="mailto:kalle.jonsson@a-t.fi" class="hover:text-blue-400 transition-colors" data-ps="src/pages/fi/tiimi.astro:kalle-mail">kalle.jonsson@a-t.fi</a></p>
            </div>
          </div>
        </div>

        <div class="bg-gray-800/50 p-8 rounded-2xl border border-gray-700/50 hover:border-blue-500/50 transition-colors" data-ps="src/pages/fi/tiimi.astro:edwin-card">
          <img 
            src="https://cdn.pagesmith.app/eb31781e/images/IMG_4581-256-256.webp" 
            alt="Edwin Mickelsson" 
            class="w-32 h-32 rounded-full mx-auto mb-6 object-cover border-2 border-blue-500" data-ps="src/pages/fi/tiimi.astro:edwin-img" />
          <div class="text-center" data-ps="src/pages/fi/tiimi.astro:edwin-info">
            <h3 class="text-xl font-bold mb-1" data-ps="src/pages/fi/tiimi.astro:edwin-name">Edwin Mickelsson</h3>
            <p class="text-blue-400 font-medium mb-4" data-ps="src/pages/fi/tiimi.astro:edwin-role">Huoltopäällikkö</p>
            <div class="space-y-1 text-gray-300" data-ps="src/pages/fi/tiimi.astro:edwin-contact">
              <p data-ps="src/pages/fi/tiimi.astro:edwin-phone"><a href="tel:+358405829667" class="hover:text-blue-400 transition-colors" data-ps="src/pages/fi/tiimi.astro:edwin-tel">+358 40 582 9667</a></p>
              <p data-ps="src/pages/fi/tiimi.astro:edwin-email-p"><a href="mailto:edwin.mickelsson@a-t.fi" class="hover:text-blue-400 transition-colors" data-ps="src/pages/fi/tiimi.astro:edwin-mail">edwin.mickelsson@a-t.fi</a></p>
            </div>
          </div>
        </div>

        <div class="bg-gray-800/50 p-8 rounded-2xl border border-gray-700/50 hover:border-blue-500/50 transition-colors" data-ps="src/pages/fi/tiimi.astro:agneta-card">
          <img 
            src="https://cdn.pagesmith.app/eb31781e/images/IMG_5561-1024-1024.webp" 
            alt="Agneta Färm" 
            class="w-32 h-32 rounded-full mx-auto mb-6 object-cover border-2 border-blue-500" data-ps="src/pages/fi/tiimi.astro:agneta-img" />
          <div class="text-center" data-ps="src/pages/fi/tiimi.astro:agneta-info">
            <h3 class="text-xl font-bold mb-1" data-ps="src/pages/fi/tiimi.astro:agneta-name">Agneta Färm</h3>
            <p class="text-blue-400 font-medium mb-4" data-ps="src/pages/fi/tiimi.astro:agneta-role">Taloushallinto</p>
            <div class="space-y-1 text-gray-300" data-ps="src/pages/fi/tiimi.astro:agneta-contact">
              <p data-ps="src/pages/fi/tiimi.astro:agneta-email-p"><a href="mailto:agneta.farm@a-t.fi" class="hover:text-blue-400 transition-colors" data-ps="src/pages/fi/tiimi.astro:agneta-mail">agneta.farm@a-t.fi</a></p>
            </div>
          </div>
        </div>

        <div class="bg-gray-800/50 p-8 rounded-2xl border border-gray-700/50 hover:border-blue-500/50 transition-colors" data-ps="src/pages/fi/tiimi.astro:oliver-card">
          <img 
            src="https://cdn.pagesmith.app/eb31781e/images/IMG_3910-1536-1536.webp" 
            alt="Oliver Salviander" 
            class="w-32 h-32 rounded-full mx-auto mb-6 object-cover border-2 border-blue-500" data-ps="src/pages/fi/tiimi.astro:oliver-img" />
          <div class="text-center" data-ps="src/pages/fi/tiimi.astro:oliver-info">
            <h3 class="text-xl font-bold mb-1" data-ps="src/pages/fi/tiimi.astro:oliver-name">Oliver Salviander</h3>
            <p class="text-blue-400 font-medium mb-4" data-ps="src/pages/fi/tiimi.astro:oliver-role">Huolto</p>
            <div class="space-y-1 text-gray-300" data-ps="src/pages/fi/tiimi.astro:oliver-contact">
              <p data-ps="src/pages/fi/tiimi.astro:oliver-email-p"><a href="mailto:oliver.salviander@a-t.fi" class="hover:text-blue-400 transition-colors" data-ps="src/pages/fi/tiimi.astro:oliver-mail">oliver.salviander@a-t.fi</a></p>
            </div>
          </div>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>
