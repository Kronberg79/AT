---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHeader from '@/components/PageHeader.astro';

const title = "Ota Yhteyttä IT-tukeen | Archipelago Technics";
const description = "Ota yhteyttä Archipelago Technicsiin. IT-tuki, tietokonehuolto ja yrityspalvelut Turussa ja Paraisilla.";
---

<BaseLayout title={title} description={description} lang="fi">
  <PageHeader title={title} description={description} />
  <div class="max-w-7xl mx-auto px-6 py-12" data-ps="src/pages/fi/yhteystiedot.astro:8reizb">
    <div class="grid md:grid-cols-2 gap-12 items-center" data-ps="src/pages/fi/yhteystiedot.astro:8reizc">
      <div class="prose prose-invert prose-lg" data-ps="src/pages/fi/yhteystiedot.astro:8reizd">
        <p class="lead" data-ps="src/pages/fi/yhteystiedot.astro:vk3d0z">Olemme täällä auttamassa.</p>
        <p data-ps="src/pages/fi/yhteystiedot.astro:vk3d10">Ota yhteyttä kaikissa IT-asioissa, tukipyynnöissä tai yhteistyömahdollisuuksissa.</p>
        <div class="not-prose mt-8 p-6 bg-zinc-900 rounded-xl border border-white/10" data-ps="src/pages/fi/yhteystiedot.astro:8reize">
            <h3 class="text-xl font-bold text-white mb-4" data-ps="src/pages/fi/yhteystiedot.astro:sewfq5">Yhteystiedot</h3>
            <p class="text-gray-400 mb-2" data-ps="src/pages/fi/yhteystiedot.astro:85av70">Puhelin: <a href="tel:+358405829704" class="text-white hover:text-[#F54a00]" data-ps="src/pages/fi/yhteystiedot.astro:wd2s8d">+358 40 582 9704</a></p>
            <p class="text-gray-400 mb-2" data-ps="src/pages/fi/yhteystiedot.astro:85av6z">Sähköposti: <a href="mailto:info@a-t.fi" class="text-white hover:text-[#F54a00]" data-ps="src/pages/fi/yhteystiedot.astro:wd2s8c">info@a-t.fi</a></p>
            <p class="text-gray-400 mb-2" data-ps="src/pages/fi/yhteystiedot.astro:85av6y">Osoite: Teollisuuskatu 22, 21600 Parainen</p>
            <p class="text-gray-400" data-ps="src/pages/fi/yhteystiedot.astro:vat-fi">Y-tunnus: 2034944-5</p>
        </div>
      </div>
      <div data-ps="src/pages/fi/yhteystiedot.astro:8reizf">
        <img 
            crossorigin="anonymous"
            src="https://images.unsplash.com/photo-1553775282-20af80779df7?auto=format&w=800&q=80" 
            srcset="https://images.unsplash.com/photo-1553775282-20af80779df7?auto=format&w=400&q=80 400w, https://images.unsplash.com/photo-1553775282-20af80779df7?auto=format&w=800&q=80 800w"
            class="rounded-xl shadow-2xl w-full" 
            alt="Asiakaspalvelu" data-ps="src/pages/fi/yhteystiedot.astro:l3ufny" />
      </div>
    </div>
  </div>
</BaseLayout>
