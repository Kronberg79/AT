---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHeader from '@/components/PageHeader.astro';

const title = "Outsourced IT Manager & CIO Services | Archipelago Technics";
const description = "Strategic IT leadership and technical management for your growing business. Outsourced CIO services for SMEs in the Turku area.";
---

<BaseLayout
  title={title}
  description={description}
  lang="en"
>
  <PageHeader title={title} description={description} />
  
  <div class="max-w-7xl mx-auto px-6 py-12" data-ps="src/pages/it-manager.astro:j53j9c">
    <div class="grid md:grid-cols-2 gap-12 items-center mb-24" data-ps="src/pages/it-manager.astro:j53j9d">
      <div class="prose prose-invert prose-lg" data-ps="src/pages/it-manager.astro:j53j9e">
        <p class="lead" data-ps="src/pages/it-manager.astro:q54fnj">Bridging the gap between business goals and technical execution.</p>
        <p data-ps="src/pages/it-manager.astro:q54fnk">Most small and medium-sized businesses reach a point where basic support isn't enough, but a full-time IT Director (CIO) is too expensive. Our Outsourced IT Manager service provides that senior-level expertise on a part-time or project basis.</p>
        <p data-ps="src/pages/it-manager.astro:t2kvl6">We don't just fix computers; we ensure your technology investments actually serve your business growth, manage your vendors, and plan for the future.</p>
      </div>
      <div data-ps="src/pages/it-manager.astro:j53j9f">
        <img 
            crossorigin="anonymous"
            src="https://images.unsplash.com/photo-1758691736975-9f7f643d178e?auto=format&w=800&q=80" 
            srcset="https://images.unsplash.com/photo-1758691736975-9f7f643d178e?auto=format&w=400&q=80 400w, https://images.unsplash.com/photo-1758691736975-9f7f643d178e?auto=format&w=800&q=80 800w"
            class="rounded-xl shadow-2xl w-full" 
            alt="IT Management Strategy" data-ps="src/pages/it-manager.astro:aq5fdx" />
      </div>
    </div>

    <div class="grid md:grid-cols-3 gap-8 mb-24" data-ps="src/pages/it-manager.astro:j53j98">
      <div class="bg-neutral-900/50 p-8 rounded-2xl border border-white/10" data-ps="src/pages/it-manager.astro:j53j99">
        <h3 class="text-xl font-bold mb-4 text-primary-400" data-ps="src/pages/it-manager.astro:h145dr">Strategic Planning</h3>
        <p class="text-neutral-400" data-ps="src/pages/it-manager.astro:t2kvl7">Annual IT budgeting, 3-year technology roadmaps, and alignment of IT infrastructure with your business objectives.</p>
      </div>
      <div class="bg-neutral-900/50 p-8 rounded-2xl border border-white/10" data-ps="src/pages/it-manager.astro:j53j9a">
        <h3 class="text-xl font-bold mb-4 text-primary-400" data-ps="src/pages/it-manager.astro:h145dq">Vendor Management</h3>
        <p class="text-neutral-400" data-ps="src/pages/it-manager.astro:t2kvl8">We act as your technical representative, managing relationships and contracts with software providers, ISPs, and hardware vendors.</p>
      </div>
      <div class="bg-neutral-900/50 p-8 rounded-2xl border border-white/10" data-ps="src/pages/it-manager.astro:j53j9b">
        <h3 class="text-xl font-bold mb-4 text-primary-400" data-ps="src/pages/it-manager.astro:h145dp">Project Oversight</h3>
        <p class="text-neutral-400" data-ps="src/pages/it-manager.astro:t2kvl9">Expert management of major technical transitions, migrations, and implementations to ensure they finish on time and within budget.</p>
      </div>
    </div>

    <div class="prose prose-invert max-w-none bg-neutral-900/30 p-12 rounded-3xl border border-white/5" data-ps="src/pages/it-manager.astro:j53j9c">
      <h2 class="text-center mb-12" data-ps="src/pages/it-manager.astro:mu550j">How We Add Value</h2>
      <div class="grid md:grid-cols-2 gap-12" data-ps="src/pages/it-manager.astro:j53j9d">
        <div data-ps="src/pages/it-manager.astro:j53j9e">
          <h3 data-ps="src/pages/it-manager.astro:h145do">Policy & Compliance</h3>
          <p data-ps="src/pages/it-manager.astro:t2kvlv">Developing internal IT policies (AUP, Remote Work, Security) and ensuring your systems meet industry-specific compliance requirements.</p>
          
          <h3 data-ps="src/pages/it-manager.astro:h145dn">Disaster Recovery</h3>
          <p data-ps="src/pages/it-manager.astro:t2kvlw">Moving beyond simple backups to comprehensive business continuity planning. We ensure you can actually keep working if disaster strikes.</p>
        </div>
        <div data-ps="src/pages/it-manager.astro:j53j9f">
          <h3 data-ps="src/pages/it-manager.astro:h145dm">Digital Transformation</h3>
          <p data-ps="src/pages/it-manager.astro:t2kvlx">Identifying manual processes that can be automated or improved through modern cloud-native solutions and AI integration.</p>
          
          <h3 data-ps="src/pages/it-manager.astro:md3hvm">Resource Optimization</h3>
          <p data-ps="src/pages/it-manager.astro:t2kvly">Auditing current software subscriptions and hardware usage to eliminate waste and reallocate budget to high-impact areas.</p>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>