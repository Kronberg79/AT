---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHeader from '@/components/PageHeader.astro';

const pulsewayImage = "https://images.unsplash.com/photo-1673526759317-be71a1243e3d?auto=format&w=1200&q=80";
const monitoringImage = "https://images.unsplash.com/photo-1746893737268-81fe686e6a51?auto=format&w=1200&q=80";
---

<BaseLayout 
  title="Pulseway RMM Solutions | Archipelago Technics"
  description="As Pulseway Partners in Finland, we provide complete RMM solutions for companies and service providers. Monitor, manage, and automate your IT infrastructure."
>
  <!-- Pulseway Themed Header & Logo Ticker -->
  <div class="bg-[#002B49] pt-24 pb-12 overflow-hidden" data-ps="src/pages/pulseway.astro:5h2xg">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center mb-16" data-ps="src/pages/pulseway.astro:5h2xh">
      <h1 class="text-4xl md:text-6xl font-black text-white mb-6 tracking-tight" data-ps="src/pages/pulseway.astro:vtln5k">Pulseway RMM</h1>
      <p class="text-xl md:text-2xl text-blue-100 max-w-3xl mx-auto font-medium" data-ps="src/pages/pulseway.astro:lphxrs">Your IT Infrastructure, Managed Anywhere. Proud Pulseway Partners from Finland.</p>
    </div>

    <!-- Trusted By Ticker -->
    <div class="relative flex overflow-x-hidden border-y border-white/10 bg-white/5 py-8 group" data-ps="src/pages/pulseway.astro:5h2xi">
      <div class="animate-marquee whitespace-nowrap flex items-center gap-12 px-6" data-ps="src/pages/pulseway.astro:5h2xj">
        <img alt="Pulseway customer logo" loading="lazy" width="160" height="40" class="h-10 w-auto opacity-70 hover:opacity-100 transition-opacity invert brightness-0" src="https://pulseway.s3.us-east-1.amazonaws.com/website/images/home-page/capterra-logo.png" data-ps="src/pages/pulseway.astro:27geid" />
        <img alt="Pulseway customer logo" loading="lazy" width="160" height="40" class="h-10 w-auto opacity-70 hover:opacity-100 transition-opacity invert brightness-0" src="https://pulseway.s3.us-east-1.amazonaws.com/website/images/home-page/dell-logo.png" data-ps="src/pages/pulseway.astro:27geie" />
        <img alt="Pulseway customer logo" loading="lazy" width="160" height="40" class="h-10 w-auto opacity-70 hover:opacity-100 transition-opacity invert brightness-0" src="https://pulseway.s3.us-east-1.amazonaws.com/website/images/home-page/harvard-logo.png" data-ps="src/pages/pulseway.astro:27geif" />
        <img alt="Pulseway customer logo" loading="lazy" width="160" height="40" class="h-10 w-auto opacity-70 hover:opacity-100 transition-opacity invert brightness-0" src="https://pulseway.s3.us-east-1.amazonaws.com/website/images/home-page/raspberry-logo.png" data-ps="src/pages/pulseway.astro:27geig" />
        <img alt="Pulseway customer logo" loading="lazy" width="160" height="40" class="h-10 w-auto opacity-70 hover:opacity-100 transition-opacity invert brightness-0" src="https://pulseway.s3.us-east-1.amazonaws.com/website/images/home-page/siemens-logo.png" data-ps="src/pages/pulseway.astro:27geih" />
        <img alt="Pulseway customer logo" loading="lazy" width="160" height="40" class="h-10 w-auto opacity-70 hover:opacity-100 transition-opacity invert brightness-0" src="https://pulseway.s3.us-east-1.amazonaws.com/website/images/home-page/canon-logo.png" data-ps="src/pages/pulseway.astro:27geii" />
        <img alt="Pulseway customer logo" loading="lazy" width="160" height="40" class="h-10 w-auto opacity-70 hover:opacity-100 transition-opacity invert brightness-0" src="https://pulseway.s3.us-east-1.amazonaws.com/website/images/home-page/archipelagotech-logo.png" data-ps="src/pages/pulseway.astro:27geij" />
      </div>
      <div class="absolute top-0 animate-marquee2 whitespace-nowrap flex items-center gap-12 px-6" aria-hidden="true" data-ps="src/pages/pulseway.astro:5h2xk">
        <img alt="Pulseway customer logo" loading="lazy" width="160" height="40" class="h-10 w-auto opacity-70 hover:opacity-100 transition-opacity invert brightness-0" src="https://pulseway.s3.us-east-1.amazonaws.com/website/images/home-page/capterra-logo.png" data-ps="src/pages/pulseway.astro:27geik" />
        <img alt="Pulseway customer logo" loading="lazy" width="160" height="40" class="h-10 w-auto opacity-70 hover:opacity-100 transition-opacity invert brightness-0" src="https://pulseway.s3.us-east-1.amazonaws.com/website/images/home-page/dell-logo.png" data-ps="src/pages/pulseway.astro:27geil" />
        <img alt="Pulseway customer logo" loading="lazy" width="160" height="40" class="h-10 w-auto opacity-70 hover:opacity-100 transition-opacity invert brightness-0" src="https://pulseway.s3.us-east-1.amazonaws.com/website/images/home-page/harvard-logo.png" data-ps="src/pages/pulseway.astro:tprvpx" />
        <img alt="Pulseway customer logo" loading="lazy" width="160" height="40" class="h-10 w-auto opacity-70 hover:opacity-100 transition-opacity invert brightness-0" src="https://pulseway.s3.us-east-1.amazonaws.com/website/images/home-page/raspberry-logo.png" data-ps="src/pages/pulseway.astro:tprvpw" />
        <img alt="Pulseway customer logo" loading="lazy" width="160" height="40" class="h-10 w-auto opacity-70 hover:opacity-100 transition-opacity invert brightness-0" src="https://pulseway.s3.us-east-1.amazonaws.com/website/images/home-page/siemens-logo.png" data-ps="src/pages/pulseway.astro:tprvpv" />
        <img alt="Pulseway customer logo" loading="lazy" width="160" height="40" class="h-10 w-auto opacity-70 hover:opacity-100 transition-opacity invert brightness-0" src="https://pulseway.s3.us-east-1.amazonaws.com/website/images/home-page/canon-logo.png" data-ps="src/pages/pulseway.astro:tprvpu" />
        <img alt="Pulseway customer logo" loading="lazy" width="160" height="40" class="h-10 w-auto opacity-70 hover:opacity-100 transition-opacity invert brightness-0" src="https://pulseway.s3.us-east-1.amazonaws.com/website/images/home-page/archipelagotech-logo.png" data-ps="src/pages/pulseway.astro:tprvpt" />
      </div>
    </div>
  </div>

  <style>
    .animate-marquee {
      animation: marquee 30s linear infinite;
    }
    .animate-marquee2 {
      animation: marquee2 30s linear infinite;
    }
    @keyframes marquee {
      0% { transform: translateX(0%); }
      100% { transform: translateX(-100%); }
    }
    @keyframes marquee2 {
      0% { transform: translateX(100%); }
      100% { transform: translateX(0%); }
    }
  </style>

  <section class="py-24 bg-white" data-ps="src/pages/pulseway.astro:s9z2x1">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8" data-ps="src/pages/pulseway.astro:s9z2x2">
      <div class="grid lg:grid-cols-2 gap-16 items-center" data-ps="src/pages/pulseway.astro:s9z2x3">
        <div data-ps="src/pages/pulseway.astro:s9z2x4">
          <h2 class="text-3xl md:text-4xl font-black text-zinc-950 mb-6" data-ps="src/pages/pulseway.astro:s9z2x5">What is Pulseway?</h2>
          <p class="text-lg text-zinc-600 mb-6" data-ps="src/pages/pulseway.astro:s9z2x6">
            Pulseway is a mobile-first Remote Monitoring and Management (RMM) platform that gives IT professionals complete control over their entire IT environment from anywhere, at any time.
          </p>
          <div class="space-y-4" data-ps="src/pages/pulseway.astro:s9z2x7">
            <div class="flex items-start gap-4" data-ps="src/pages/pulseway.astro:s9z2x8">
              <div class="w-10 h-10 bg-[#F54a00]/10 rounded-lg flex items-center justify-center shrink-0" data-ps="src/pages/pulseway.astro:s9z2x9">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-[#F54a00]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z" />
                </svg>
              </div>
              <div data-ps="src/pages/pulseway.astro:s9z2y1">
                <h3 class="font-bold text-zinc-950" data-ps="src/pages/pulseway.astro:s9z2y2">Mobile-First Control</h3>
                <p class="text-zinc-600" data-ps="src/pages/pulseway.astro:s9z2y3">Receive instant alerts and fix issues directly from your smartphone or tablet.</p>
              </div>
            </div>
            <div class="flex items-start gap-4" data-ps="src/pages/pulseway.astro:s9z2y4">
              <div class="w-10 h-10 bg-[#F54a00]/10 rounded-lg flex items-center justify-center shrink-0" data-ps="src/pages/pulseway.astro:s9z2y5">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-[#F54a00]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                </svg>
              </div>
              <div data-ps="src/pages/pulseway.astro:s9z2y6">
                <h3 class="font-bold text-zinc-950" data-ps="src/pages/pulseway.astro:s9z2y7">Powerful Automation</h3>
                <p class="text-zinc-600" data-ps="src/pages/pulseway.astro:s9z2y8">Automate routine maintenance tasks, patch management, and security updates with ease.</p>
              </div>
            </div>
            <div class="flex items-start gap-4" data-ps="src/pages/pulseway.astro:s9z2y9">
              <div class="w-10 h-10 bg-[#F54a00]/10 rounded-lg flex items-center justify-center shrink-0" data-ps="src/pages/pulseway.astro:s9z2z1">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-[#F54a00]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04 inter-2 2 0 00-1.79 1.994 11.95 11.95 0 005.458 9.235 11.952 11.952 0 005.459 9.235 2 2 0 001.79-1.994 11.955 11.955 0 015.458-9.235 11.95 11.95 0 005.458-9.235 2 2 0 00-1.79-1.994z" />
                </svg>
              </div>
              <div data-ps="src/pages/pulseway.astro:s9z2z2">
                <h3 class="font-bold text-zinc-950" data-ps="src/pages/pulseway.astro:s9z2z3">Endpoint Security</h3>
                <p class="text-zinc-600" data-ps="src/pages/pulseway.astro:s9z2z4">Integrated antivirus and ransomware protection ensures your clients' or company's data stays safe.</p>
              </div>
            </div>
          </div>
        </div>
        <div class="relative" data-ps="src/pages/pulseway.astro:s9z2z5">
          <img crossorigin="anonymous" src={monitoringImage} 
            alt="Pulseway Monitoring Dashboard" 
            class="rounded-2xl shadow-2xl w-full" data-ps="src/pages/pulseway.astro:s9z2z6" />
          <div class="absolute -bottom-6 -left-6 bg-orange-700 p-8 rounded-2xl text-zinc-50 shadow-xl max-w-xs" data-ps="src/pages/pulseway.astro:s9z2z7">
            <p class="text-2xl font-black mb-2" data-ps="src/pages/pulseway.astro:s9z2z8">100%</p>
            <p class="text-sm font-bold text-zinc-100" data-ps="src/pages/pulseway.astro:s9z2z9">Visibility over your IT infrastructure from your mobile phone.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-24 bg-zinc-50" data-ps="src/pages/pulseway.astro:s9z3a1">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center" data-ps="src/pages/pulseway.astro:s9z3a2">
      <h2 class="text-3xl md:text-4xl font-black text-zinc-950 mb-8" data-ps="src/pages/pulseway.astro:s9z3a3">Your Pulseway Partners in Finland</h2>
      <p class="text-xl text-zinc-600 mb-10" data-ps="src/pages/pulseway.astro:s9z3a4">
        Archipelago Technics is a certified Pulseway Partner. We bring this world-class IT management solution to companies and IT service providers across Finland.
      </p>
      <div class="bg-white p-12 rounded-3xl shadow-sm border border-zinc-200" data-ps="src/pages/pulseway.astro:s9z3a5">
        <h3 class="text-2xl font-black text-zinc-950 mb-6" data-ps="src/pages/pulseway.astro:s9z3a6">Get Your Solution via Us</h3>
        <p class="text-zinc-600 mb-8" data-ps="src/pages/pulseway.astro:s9z3a7">
          Whether you are looking to manage your own internal company IT or you are an MSP providing services to your own customers, we provide the license, setup support, and local expertise you need to succeed with Pulseway.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center" data-ps="src/pages/pulseway.astro:s9z3a8">
          <a href="/contact" class="px-10 py-5 bg-[#F54a00] text-zinc-950 rounded-full font-black text-lg hover:brightness-110 transition-all shadow-xl" data-ps="src/pages/pulseway.astro:s9z3a9">
            Request a Demo
          </a>
          <a href="tel:+358405829704" class="px-10 py-5 border-2 border-zinc-200 text-zinc-900 rounded-full font-black text-lg hover:bg-zinc-50 transition-all" data-ps="src/pages/pulseway.astro:s9z3b1">
            Call our Experts
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="py-24 bg-white" data-ps="src/pages/pulseway.astro:s9z3b2">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8" data-ps="src/pages/pulseway.astro:s9z3b3">
      <div class="grid md:grid-cols-3 gap-8" data-ps="src/pages/pulseway.astro:s9z3b4">
        <div class="p-8 bg-zinc-50 rounded-2xl border border-zinc-100" data-ps="src/pages/pulseway.astro:s9z3b5">
          <h4 class="text-xl font-black text-zinc-950 mb-4" data-ps="src/pages/pulseway.astro:s9z3b6">For Internal IT</h4>
          <p class="text-zinc-600" data-ps="src/pages/pulseway.astro:s9z3b7">Simplify your daily workload and monitor servers, workstations, and network devices from one unified dashboard.</p>
        </div>
        <div class="p-8 bg-zinc-50 rounded-2xl border border-zinc-100" data-ps="src/pages/pulseway.astro:s9z3b8">
          <h4 class="text-xl font-black text-zinc-950 mb-4" data-ps="src/pages/pulseway.astro:s9z3b9">For MSPs</h4>
          <p class="text-zinc-600" data-ps="src/pages/pulseway.astro:s9z3c1">Scale your business by managing multiple client environments efficiently and providing proactive support that keeps customers happy.</p>
        </div>
        <div class="p-8 bg-zinc-50 rounded-2xl border border-zinc-100" data-ps="src/pages/pulseway.astro:s9z3c2">
          <h4 class="text-xl font-black text-zinc-950 mb-4" data-ps="src/pages/pulseway.astro:s9z3c3">Local Support</h4>
          <p class="text-zinc-600" data-ps="src/pages/pulseway.astro:s9z3c4">Get help when you need it from our Finnish-based team. We understand the local market and technical requirements.</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
