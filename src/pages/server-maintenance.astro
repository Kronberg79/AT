---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHeader from '@/components/PageHeader.astro';

const title = "Server Maintenance & Cloud Management | Archipelago Technics";
const description = "Expert server maintenance, updates, and migrations. We ensure your servers are secure, up-to-date, and running efficiently.";
---

<BaseLayout
  title={title}
  description={description}
  lang="en"
>
  <PageHeader title={title} description={description} />
  
  <div class="max-w-7xl mx-auto px-6 py-16" data-ps="src/pages/server-maintenance.astro:1wwu64">
    <div class="grid lg:grid-cols-2 gap-12 mb-16" data-ps="src/pages/server-maintenance.astro:1wwu65">
      <div class="prose prose-lg prose-invert" data-ps="src/pages/server-maintenance.astro:1wwu66">
        <h2 class="text-3xl font-bold text-white mb-6" data-ps="src/pages/server-maintenance.astro:d4peoz">Expert Service with Years of Experience</h2>
        <p data-ps="src/pages/server-maintenance.astro:pdwwgo">
          Looking for a reliable partner for server maintenance, updates, or migrations? 
          We specialize in server upkeep and troubleshooting – fast, secure, and expert service. 
          We serve you within the same day!
        </p>
        <p data-ps="src/pages/server-maintenance.astro:pdwwgn">
          Choose us when you want to ensure the continuous operation and security of your server environment.
        </p>
        <div class="mt-8" data-ps="src/pages/server-maintenance.astro:1wwu67">
          <a href="/contact" class="bg-orange-600 hover:bg-orange-700 text-white font-bold py-3 px-6 rounded-lg transition" data-ps="src/pages/server-maintenance.astro:i9yzqv">
            Contact Us
          </a>
        </div>
      </div>
      <div data-ps="src/pages/server-maintenance.astro:1wwu68">
        <img crossorigin="anonymous" src="https://images.unsplash.com/photo-1680992046617-e2e35451bcdb?auto=format&w=800&q=80" 
          class="rounded-xl shadow-2xl w-full h-full object-cover" 
          alt="Server Maintenance" data-ps="src/pages/server-maintenance.astro:e736vk" />
      </div>
    </div>

    <div class="grid md:grid-cols-2 gap-8" data-ps="src/pages/server-maintenance.astro:1wwu69">
      <div class="bg-zinc-900 p-8 rounded-xl border border-zinc-800" data-ps="src/pages/server-maintenance.astro:1wwu6a">
        <h3 class="text-2xl font-bold text-orange-500 mb-4" data-ps="src/pages/server-maintenance.astro:1jpiip">Maintenance & Upkeep</h3>
        <p class="text-zinc-300 mb-4" data-ps="src/pages/server-maintenance.astro:pdwwgm">
          Regular maintenance is critical for your IT infrastructure's reliability. 
          We offer comprehensive server maintenance services, including:
        </p>
        <ul class="list-disc list-inside text-zinc-300 space-y-2">
          <li data-ps="src/pages/server-maintenance.astro:dvob5w">Hardware and software checks</li>
          <li data-ps="src/pages/server-maintenance.astro:dvob5x">Performance optimization</li>
          <li data-ps="src/pages/server-maintenance.astro:dvob5y">Security updates and backup solutions</li>
          <li data-ps="src/pages/server-maintenance.astro:dvob6k">Proactive maintenance and fault prevention</li>
        </ul>
      </div>

      <div class="bg-zinc-900 p-8 rounded-xl border border-zinc-800" data-ps="src/pages/server-maintenance.astro:1wwu6b">
        <h3 class="text-2xl font-bold text-orange-500 mb-4" data-ps="src/pages/server-maintenance.astro:1jpiio">Updates & Modernization</h3>
        <p class="text-zinc-300 mb-4" data-ps="src/pages/server-maintenance.astro:pdwwgl">
          Technology evolves fast – we ensure your servers stay up to date. 
          We specialize in updating legacy systems (like Windows Server 2008) to modern, supported versions.
        </p>
        <p class="text-zinc-300" data-ps="src/pages/server-maintenance.astro:pdwwfz">
          Updates bring better performance, security, and compatibility with new applications.
        </p>
      </div>

      <div class="bg-zinc-900 p-8 rounded-xl border border-zinc-800" data-ps="src/pages/server-maintenance.astro:1wwu6c">
        <h3 class="text-2xl font-bold text-orange-500 mb-4" data-ps="src/pages/server-maintenance.astro:1jpiin">Server Migrations</h3>
        <p class="text-zinc-300 mb-4" data-ps="src/pages/server-maintenance.astro:pdwwfy">
          Planning a move to a new server environment or the cloud? 
          We execute server migrations efficiently and without business interruptions.
        </p>
        <ul class="list-disc list-inside text-zinc-300 space-y-2">
          <li data-ps="src/pages/server-maintenance.astro:dvob6l">Current state mapping and planning</li>
          <li data-ps="src/pages/server-maintenance.astro:dvob6m">Data and service transfer</li>
          <li data-ps="src/pages/server-maintenance.astro:dvob6n">Testing and deployment</li>
          <li data-ps="src/pages/server-maintenance.astro:dvob6o">User guidance and support</li>
        </ul>
      </div>

      <div class="bg-zinc-900 p-8 rounded-xl border border-zinc-800" data-ps="src/pages/server-maintenance.astro:1wwu6d">
        <h3 class="text-2xl font-bold text-orange-500 mb-4" data-ps="src/pages/server-maintenance.astro:1jpiim">Emergency Services</h3>
        <p class="text-zinc-300 mb-4" data-ps="src/pages/server-maintenance.astro:pdwwfx">
          Server issues can cause significant disruptions. Our experts are ready to help in all failure situations 
          – whether it's hardware failure, software crashes, or security issues.
        </p>
        <p class="text-zinc-300" data-ps="src/pages/server-maintenance.astro:pdwwfw">
          We react quickly to restore your systems to working order.
        </p>
      </div>
    </div>
  </div>
</BaseLayout>
