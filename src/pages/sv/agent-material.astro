                  </div>
                  <div class="flex items-center justify-between pt-4 border-t border-blue-500/20" data-ps="src/pages/sv/agent-material.astro:1t9vkx">
                    <span class="text-sm font-semibold text-blue-300" data-ps="src/pages/sv/agent-material.astro:m56yaj">Potentiell provision</span>
                    <span class="text-xl font-bold text-white" data-webpage-commission data-ps="src/pages/sv/agent-material.astro:m56yai">0.00 €</span>
