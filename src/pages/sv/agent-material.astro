          <script is:inline>
            function updateGrandTotal() {
              let total = 0;
              let hasAgreed = false;

              // Support
              const supportDisp = document.querySelector('[data-commission-display]');
              if (supportDisp) total += parseFloat(supportDisp.textContent.replace('€', '')) || 0;

              // Webpage
              const webDisp = document.querySelector('[data-webpage-commission]');
              if (webDisp) total += parseFloat(webDisp.textContent.replace('€', '')) || 0;

              // ConnectMe
              const cmDisp = document.querySelector('[data-cm-commission]');
              if (cmDisp) total += parseFloat(cmDisp.textContent.replace('€', '')) || 0;

              // Rewards
              const rewDisp = document.querySelector('[data-rewards-commission]');
              if (rewDisp) {
                const text = rewDisp.textContent;
                total += parseFloat(text.replace('€', '').split('+')[0]) || 0;
                if (text.includes('överens')) hasAgreed = true;
              }

              const display = document.getElementById('grand-commission-display');
              if (display) {
                display.textContent = hasAgreed ? `€${total.toFixed(2)} + överens` : `€${total.toFixed(2)}`;
              }
            }

            // Global observer
            const observer = new MutationObserver(() => {
              updateGrandTotal();
            });

            document.querySelectorAll('[data-commission-display], [data-webpage-commission], [data-cm-commission], [data-rewards-commission]').forEach(el => {
              observer.observe(el, { characterData: true, childList: true, subtree: true });
            });

            // Send Order Logic
            document.getElementById('send-order-btn').addEventListener('click', async (e) => {
              const btn = e.currentTarget;
              const customerName = document.getElementById('order-customer-name').value;
              const contactName = document.getElementById('order-customer-contact-name').value;
              const address = document.getElementById('order-customer-address').value;
              const phone = document.getElementById('order-customer-phone').value;
              const email = document.getElementById('order-customer-email').value;
              const confirmed = document.getElementById('order-confirm-rules').checked;

              if (!customerName || !contactName || !address || !phone || !email) {
                alert('Vänligen fyll i alla kunduppgifter.');
                return;
              }

              if (!confirmed) {
                alert('Vänligen bekräfta att du har läst reglerna.');
                return;
              }

              const ogText = btn.textContent;
              btn.textContent = 'Skickar...';
              btn.disabled = true;

              // Gather selection details
              let details = "--- ORDERRESUMÉ ---\n\n";
              
              // Group 1: Support
              const emp = document.querySelector('[data-support-input="employees"]')?.value || 0;
              const dev = document.querySelector('[data-support-input="devices"]')?.value || 0;
              const mail = document.querySelector('[data-support-input="mailboxes"]')?.value || 0;
              if(emp > 0 || dev > 0 || mail > 0) {
                details += `GRUPP 1: IT-SUPPORT\n- Anställda: ${emp}\n- Enheter: ${dev}\n- Mejlkorgar: ${mail}\n\n`;
              }

              // Group 2: Webpage
              const pages = document.querySelector('[data-webpage-input]')?.value || 0;
              if(pages > 0) {
                const isMulti = document.querySelector('[data-webpage-multilingual-yes]')?.checked ? "Ja" : "Nej";
                const numLang = document.querySelector('[data-webpage-languages]')?.value || 1;
                const isSeo = document.querySelector('[data-webpage-seo-yes]')?.checked ? "Ja" : "Nej";
                const isEmail = document.querySelector('[data-webpage-email-yes]')?.checked ? "Ja" : "Nej";
                const mailboxes = document.querySelector('[data-webpage-mailboxes]')?.value || 0;
                
                details += `GRUPP 2: WEBBPLATS\n- Sidor: ${pages}\n- Flerspråkig: ${isMulti}`;
                if (isMulti === "Ja") details += ` (${numLang} extra språk)`;
                details += `\n- SEO: ${isSeo}\n- E-post: ${isEmail}`;
                if (isEmail === "Ja") details += ` (${mailboxes} mejlkorgar)`;
                details += `\n\n`;
              }

              // Group 3: ConnectMe
              const p1 = document.querySelector('[data-cm-pkg1-amount]')?.value || 0;
              const p2 = document.querySelector('[data-cm-pkg2-amount]')?.value || 0;
              const p3 = document.querySelector('[data-cm-pkg3-amount]')?.value || 0;
              if(p1 > 0 || p2 > 0 || p3 > 0) {
                details += `GRUPP 3: CONNECTME\n- Basic: ${p1}\n- Standard: ${p2}\n- Advanced: ${p3}\n\n`;
              }

              // Group 4: Rewards
              const r1 = document.querySelector('.group/rewards [data-cm-pkg1-amount]')?.value || 0;
              const r2 = document.querySelector('.group/rewards [data-cm-pkg2-amount]')?.value || 0;
              const r3 = document.querySelector('.group/rewards [data-cm-pkg3-amount]')?.value || 0;
              const r4 = document.querySelector('.group/rewards [data-cm-pkg4-check]')?.checked ? "Ja" : "Nej";
              if(r1 > 0 || r2 > 0 || r3 > 0 || r4 === "Ja") {
                details += `GRUPP 4: BELÖNINGAR\n- Hembesök: ${r1}\n- PC-service: ${r2}\n- Licenser: ${r3}\n- Större projekt: ${r4}\n\n`;
              }

              const total = document.getElementById('grand-commission-display').textContent;
              details += `TOTAL PROVISION: ${total}\n\n`;
              
              const payload = {
                name: contactName,
                email: email,
                subject: "Incoming order from an Agent",
                CustomerName: customerName,
                ContactPerson: contactName,
                Address: address,
                Phone: phone,
                OrderDetails: details
              };

              try {
                const response = await fetch('/psapi-internal-v1/forms/submit', {
                  method: 'POST',
                  headers: { 'Content-Type': 'application/json' },
                  body: JSON.stringify(payload),
                });
                
                const result = await response.json();
                
                if(result.success) {
                  document.getElementById('order-success-msg').classList.remove('hidden');
                } else {
                  alert("Misslyckades att skicka: " + (result.error || 'Okänt fel'));
                }
              } catch(err) {
                alert("Misslyckades att skicka. Vänligen försök igen.");
              } finally {
                btn.textContent = ogText;
                btn.disabled = false;
              }
            });

            // Toggle logic
            document.querySelectorAll('.configurator-toggle').forEach(button => {
              button.addEventListener('click', () => {
                const targetId = button.getAttribute('data-target');
                const target = document.getElementById(targetId);
                const svg = button.querySelector('svg');
                
                if (target.classList.contains('hidden')) {
                  target.classList.remove('hidden');
                  svg.classList.add('rotate-180');
                } else {
                  target.classList.add('hidden');
                  svg.classList.remove('rotate-180');
                }
              });
            });
          </script>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
