---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHeader from '@/components/PageHeader.astro';
import ConnectMeConfigurator from '@/components/agent/ConnectMeConfigurator.astro';

const title = "Agentmaterial | Sälj tjänster för Archipelago Technics";
const description = "Läs mer om de tjänster du kan sälja som A-T Agent och hur mycket provision du kan tjäna. Konfiguratorn kommer snart!";
---

<BaseLayout title={title} description={description}>
  <PageHeader
    title="Agentens material och provisioner"
    subtitle="Allt du behöver veta om de tjänster du kan sälja och den belöning du kommer att tjäna."
  />

  <section class="py-20 bg-white" data-ps="src/pages/sv/agent-material.astro:or9kk6">
    <div class="container mx-auto px-4 max-w-4xl" data-ps="src/pages/sv/agent-material.astro:etluwf">
      <div class="text-center mb-16" data-ps="src/pages/sv/agent-material.astro:etluwg">
        <h2 class="text-3xl font-bold text-slate-900 mb-6" data-ps="src/pages/sv/agent-material.astro:ogtbus">Tjänstekatalog och provisionsstruktur</h2>
        <p class="text-lg text-slate-600" data-ps="src/pages/sv/agent-material.astro:crj0zz">
          Som A-T Agent har du ett brett utbud av tjänster att erbjuda ditt nätverk. Nedan finns en översikt över våra viktigaste tjänster och intjäningspotentialen för varje framgångsrik rekommendation.
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-8 mb-20" data-ps="src/pages/sv/agent-material.astro:etluwh">
        <div class="bg-slate-50 p-8 rounded-2xl border border-slate-200" data-ps="src/pages/sv/agent-material.astro:etluwi">
          <div class="bg-blue-100 w-12 h-12 rounded-xl flex items-center justify-center mb-6" data-ps="src/pages/sv/agent-material.astro:1t9vl6">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-blue-700"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect><line x1="8" y1="21" x2="16" y2="21"></line><line x1="12" y1="17" x2="12" y2="21"></line></svg>
          </div>
          <h3 class="text-xl font-bold text-slate-900 mb-3" data-ps="src/pages/sv/agent-material.astro:9seen6">Webbutveckling</h3>
          <p class="text-slate-600 mb-4" data-ps="src/pages/sv/agent-material.astro:crj100">Sälj moderna, snabba och SEO-optimerade hemsidor byggda på Astro och Tailwind CSS. Perfekt för små och medelstora företag.</p>
          <ul class="space-y-2 mb-4 text-sm text-slate-700 font-medium">
            <li class="flex items-center gap-2" data-ps="src/pages/sv/agent-material.astro:p7s8cj"><svg class="w-4 h-4 text-green-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> Grundpaket</li>
            <li class="flex items-center gap-2" data-ps="src/pages/sv/agent-material.astro:p7s8ck"><svg class="w-4 h-4 text-green-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> E-handelsintegration</li>
            <li class="flex items-center gap-2" data-ps="src/pages/sv/agent-material.astro:p7s8cl"><svg class="w-4 h-4 text-green-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> Anpassade webbapplikationer</li>
          </ul>
        </div>

        <div class="bg-slate-50 p-8 rounded-2xl border border-slate-200" data-ps="src/pages/sv/agent-material.astro:1t9vl5">
          <div class="bg-blue-100 w-12 h-12 rounded-xl flex items-center justify-center mb-6" data-ps="src/pages/sv/agent-material.astro:1t9vl4">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-blue-700"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect><line x1="8" y1="21" x2="16" y2="21"></line><line x1="12" y1="17" x2="12" y2="21"></line></svg>
          </div>
          <h3 class="text-xl font-bold text-slate-900 mb-3" data-ps="src/pages/sv/agent-material.astro:9seen7">IT-support och underhåll</h3>
          <p class="text-slate-600 mb-4" data-ps="src/pages/sv/agent-material.astro:crj101">Hänvisa företag för kontinuerlig IT-support, Microsoft 365-licenser och enhetshantering genom ConnectMe eller Pulseway.</p>
          <ul class="space-y-2 mb-4 text-sm text-slate-700 font-medium">
            <li class="flex items-center gap-2" data-ps="src/pages/sv/agent-material.astro:p7s8cm"><svg class="w-4 h-4 text-green-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> Månatliga underhållsavtal</li>
            <li class="flex items-center gap-2" data-ps="src/pages/sv/agent-material.astro:p7s8cn"><svg class="w-4 h-4 text-green-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> M365 Uppsättning & Migrering</li>
            <li class="flex items-center gap-2" data-ps="src/pages/sv/agent-material.astro:p7s8co"><svg class="w-4 h-4 text-green-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> Säkerhetsrevisioner</li>
          </ul>
        </div>
      </div>

      <div class="bg-slate-900 rounded-3xl p-10 text-center text-white relative overflow-hidden" data-ps="src/pages/sv/agent-material.astro:1t9vl3">
        <div class="absolute top-0 right-0 w-64 h-64 bg-blue-500 rounded-full mix-blend-multiply filter blur-3xl opacity-20 transform translate-x-1/2 -translate-y-1/2" data-ps="src/pages/sv/agent-material.astro:1t9vl2"></div>
        <div class="absolute bottom-0 left-0 w-64 h-64 bg-orange-500 rounded-full mix-blend-multiply filter blur-3xl opacity-20 transform -translate-x-1/2 translate-y-1/2" data-ps="src/pages/sv/agent-material.astro:1t9vl1"></div>
        
        <div class="relative z-10" data-ps="src/pages/sv/agent-material.astro:1t9vl0">
          <h2 class="text-3xl font-bold mb-4" data-ps="src/pages/sv/agent-material.astro:ogtbut">Provisionskonfigurator</h2>
          <div class="inline-block bg-blue-600 text-white text-sm font-bold px-4 py-1 rounded-full mb-6" data-ps="src/pages/sv/agent-material.astro:1t9vkz">Kommer snart</div>
          <p class="text-lg text-slate-300 max-w-2xl mx-auto mb-8" data-ps="src/pages/sv/agent-material.astro:crj10n">
            Vi bygger ett interaktivt konfiguratorverktyg precis här. Snart kommer du att kunna välja specifika tjänster, anpassa paket och omedelbart se exakt den provision du kommer att tjäna för varje försäljning.
          </p>
          <div class="w-full max-w-2xl mx-auto space-y-4 text-left" data-ps="src/pages/sv/agent-material.astro:dmbs82">
          <!-- Group 1 -->
          <div class="bg-slate-800 rounded-2xl border border-slate-700 overflow-hidden transition-all duration-300 ring-2 ring-blue-500/50 shadow-lg shadow-blue-500/10" data-ps="src/pages/sv/agent-material.astro:3yj0ul">
          <button class="w-full p-6 flex items-center justify-between text-left group configurator-toggle" data-target="group-1" data-ps="src/pages/sv/agent-material.astro:gexvwq">
          <div class="flex items-center gap-4" data-ps="src/pages/sv/agent-material.astro:3yj0um">
          <div class="w-10 h-10 rounded-lg bg-blue-600/20 flex items-center justify-center text-blue-400 group-hover:bg-blue-600 group-hover:text-white transition-colors" data-ps="src/pages/sv/agent-material.astro:3yj0un">
          <span class="font-bold" data-ps="src/pages/sv/agent-material.astro:k8adpu">1</span>
          </div>
          <div data-ps="src/pages/sv/agent-material.astro:3yj0uo">
          <h3 class="font-bold text-white" data-ps="src/pages/sv/agent-material.astro:4c8i6s">IT-stöd för ett företag</h3>
          <p class="text-xs text-slate-400 uppercase tracking-wider font-semibold" data-ps="src/pages/sv/agent-material.astro:zx1ym">Grupp 1</p>
          </div>
          </div>
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-slate-500 group-hover:text-white transition-transform duration-300"><path d="m6 9 6 6 6-6"></path></svg>
          </button>
              
          <div id="group-1" class="hidden p-8 border-t border-slate-700 bg-slate-800/50 group/support" data-ps="src/pages/sv/agent-material.astro:3yj0up">
                <div class="grid gap-6" data-ps="src/pages/sv/agent-material.astro:etluvm">
                  <div data-ps="src/pages/sv/agent-material.astro:etluvn">
                    <div class="flex justify-between items-center mb-3" data-ps="src/pages/sv/agent-material.astro:1t9vkz">
                      <label class="text-sm font-medium text-slate-300">Antal anställda (0-100)</label>
                      <input type="number" min="0" max="100" value="0" class="w-16 bg-slate-900 border border-slate-700 rounded px-2 py-1 text-xs text-white focus:outline-none focus:ring-1 focus:ring-blue-500" data-support-input="employees" />
                    </div>
                    <input type="range" min="0" max="100" value="0" class="w-full h-2 bg-slate-700 rounded-lg appearance-none cursor-pointer accent-blue-500" data-support-slider="employees" />
                    <div class="flex justify-between text-xs text-slate-500 mt-2" data-ps="src/pages/sv/agent-material.astro:etluw9"><span data-ps="src/pages/sv/agent-material.astro:m56ycc">0</span><span data-ps="src/pages/sv/agent-material.astro:m56ycb">50</span><span data-ps="src/pages/sv/agent-material.astro:m56yca">100</span></div>
                  </div>
                  
                  <div data-ps="src/pages/sv/agent-material.astro:etluwa">
                    <div class="flex justify-between items-center mb-3" data-ps="src/pages/sv/agent-material.astro:1t9vky">
                      <label class="text-sm font-medium text-slate-300">Enheter att hantera (0-100)</label>
                      <input type="number" min="0" max="100" value="0" class="w-16 bg-slate-900 border border-slate-700 rounded px-2 py-1 text-xs text-white focus:outline-none focus:ring-1 focus:ring-blue-500" data-support-input="devices" />
                    </div>
                    <input type="range" min="0" max="100" value="0" class="w-full h-2 bg-slate-700 rounded-lg appearance-none cursor-pointer accent-blue-500" data-support-slider="devices" />
                    <div class="flex justify-between text-xs text-slate-500 mt-2" data-ps="src/pages/sv/agent-material.astro:etluwb"><span data-ps="src/pages/sv/agent-material.astro:m56yc9">0</span><span data-ps="src/pages/sv/agent-material.astro:m56yc8">50</span><span data-ps="src/pages/sv/agent-material.astro:m56yc7">100</span></div>
                  </div>

                  <div data-ps="src/pages/sv/agent-material.astro:etluwc">
                    <div class="flex justify-between items-center mb-3" data-ps="src/pages/sv/agent-material.astro:1t9vkx">
                      <label class="text-sm font-medium text-slate-300">E-postlådor (0-100)</label>
                      <input type="number" min="0" max="100" value="0" class="w-16 bg-slate-900 border border-slate-700 rounded px-2 py-1 text-xs text-white focus:outline-none focus:ring-1 focus:ring-blue-500" data-support-input="mailboxes" />
                    </div>
                    <input type="range" min="0" max="100" value="0" class="w-full h-2 bg-slate-700 rounded-lg appearance-none cursor-pointer accent-blue-500" data-support-slider="mailboxes" />
                    <div class="flex justify-between text-xs text-slate-500 mt-2" data-ps="src/pages/sv/agent-material.astro:etluwd"><span data-ps="src/pages/sv/agent-material.astro:m56yc6">0</span><span data-ps="src/pages/sv/agent-material.astro:m56yc5">50</span><span data-ps="src/pages/sv/agent-material.astro:m56yc4">100</span></div>
                  </div>

                  <div class="pt-4 border-t border-slate-700" data-ps="src/pages/sv/agent-material.astro:etluwe">
                    <label class="flex items-start gap-3 cursor-pointer group">
                      <div class="relative flex items-center justify-center mt-1" data-ps="src/pages/sv/agent-material.astro:etluwf">
                        <input type="checkbox" class="peer h-5 w-5 appearance-none rounded border border-slate-600 bg-slate-700 checked:bg-blue-600 checked:border-blue-600 transition-all cursor-pointer" />
                        <svg class="absolute w-3.5 h-3.5 text-white opacity-0 peer-checked:opacity-100 transition-opacity pointer-events-none" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
                      </div>
                      <span class="text-sm text-slate-300 group-hover:text-white transition-colors" data-ps="src/pages/sv/agent-material.astro:m56yc3">Jag vet inte, de vill att ni kontaktar dem så snart som möjligt</span>
                    </label>
                  </div>
                </div>

                <div class="mt-8 p-4 bg-blue-600/10 rounded-xl border border-blue-500/20 flex items-center justify-between" data-ps="src/pages/sv/agent-material.astro:etluwg">
                  <span class="text-sm font-semibold text-blue-300" data-ps="src/pages/sv/agent-material.astro:m56ybh">Potentiell provision</span>
                  <span class="text-xl font-bold text-white" data-commission-display data-ps="src/pages/sv/agent-material.astro:aqpz7o">0.00 €</span>
                </div>
              </div>
            </div>

            <script is:inline>
              function setupITSupportConfigurator() {
                const group = document.querySelector('.group\\/support');
                if (!group) return;

                const inputs = {
                  employees: {
                    slider: group.querySelector('[data-support-slider="employees"]'),
                    input: group.querySelector('[data-support-input="employees"]')
                  },
                  devices: {
                    slider: group.querySelector('[data-support-slider="devices"]'),
                    input: group.querySelector('[data-support-input="devices"]')
                  },
                  mailboxes: {
                    slider: group.querySelector('[data-support-slider="mailboxes"]'),
                    input: group.querySelector('[data-support-input="mailboxes"]')
                  }
                };

                const display = group.querySelector('[data-commission-display]');

                function update() {
                  const emp = parseInt(inputs.employees.input.value) || 0;
                  const dev = parseInt(inputs.devices.input.value) || 0;
                  const mail = parseInt(inputs.mailboxes.input.value) || 0;

                  const total = (emp * 8) + (dev * 8) + (mail * 2);
                  display.textContent = `${total.toFixed(2)} €`;
                }

                Object.keys(inputs).forEach(key => {
                  const { slider, input } = inputs[key];
                  
                  slider.addEventListener('input', (e) => {
                    input.value = e.target.value;
                    update();
                  });

                  input.addEventListener('input', (e) => {
                    let val = parseInt(e.target.value);
                    if (isNaN(val)) val = 0;
                    if (val > 100) val = 100;
                    if (val < 0) val = 0;
                    slider.value = val;
                    update();
                  });
                });

                update();
              }

              // Run setup
              setupITSupportConfigurator();
            </script>

            <!-- Group 2 -->
            <div class="bg-slate-800 rounded-2xl border border-slate-700 overflow-hidden transition-all duration-300 ring-2 ring-blue-500/50 shadow-lg shadow-blue-500/10" data-ps="src/pages/sv/agent-material.astro:3yj0vl">
            <button class="w-full p-6 flex items-center justify-between text-left group configurator-toggle" data-target="group-2" data-ps="src/pages/sv/agent-material.astro:gexvwr">
            <div class="flex items-center gap-4" data-ps="src/pages/sv/agent-material.astro:3yj0vm">
            <div class="w-10 h-10 rounded-lg bg-blue-600/20 flex items-center justify-center text-blue-400 group-hover:bg-blue-600 group-hover:text-white transition-colors" data-ps="src/pages/sv/agent-material.astro:dmbs8a">
            <span class="font-bold" data-ps="src/pages/sv/agent-material.astro:k8adob">2</span>
            </div>
            <div data-ps="src/pages/sv/agent-material.astro:dmbs89">
            <h3 class="font-bold text-white" data-ps="src/pages/sv/agent-material.astro:4c8i66">Webbsida</h3>
            <p class="text-xs text-slate-400 uppercase tracking-wider font-semibold" data-ps="src/pages/sv/agent-material.astro:zx1yn">Grupp 2</p>
            </div>
            </div>
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-slate-500 group-hover:text-white transition-transform duration-300"><path d="m6 9 6 6 6-6"></path></svg>
            </button>

            <div id="group-2" class="hidden p-8 border-t border-slate-700 bg-slate-800/50 group/webpage" data-ps="src/pages/sv/agent-material.astro:3yj0un">
                <div class="grid gap-6" data-ps="src/pages/sv/agent-material.astro:etluvk">
                  <!-- Hur många sidor -->
                  <div data-ps="src/pages/sv/agent-material.astro:etluvl">
                    <div class="flex justify-between items-center mb-3" data-ps="src/pages/sv/agent-material.astro:1t9vkz">
                      <label class="text-sm font-medium text-slate-300">Antal sidor (0-100)</label>
                      <input type="number" min="0" max="100" value="0" class="w-16 bg-slate-900 border border-slate-700 rounded px-2 py-1 text-xs text-white focus:outline-none focus:ring-1 focus:ring-blue-500" data-webpage-input />
                    </div>
                    <input type="range" min="0" max="100" value="0" class="w-full h-2 bg-slate-700 rounded-lg appearance-none cursor-pointer accent-blue-500" data-webpage-slider />
                    <div class="flex justify-between text-xs text-slate-500 mt-2" data-ps="src/pages/sv/agent-material.astro:etluvm"><span data-ps="src/pages/sv/agent-material.astro:m56ybf">0</span><span data-ps="src/pages/sv/agent-material.astro:m56ybe">50</span><span data-ps="src/pages/sv/agent-material.astro:m56ybd">100</span></div>
                  </div>

                  <!-- Flerspråkig -->
                  <div class="space-y-4" data-ps="src/pages/sv/agent-material.astro:etluvn">
                    <label class="block text-sm font-medium text-slate-300">Flerspråkig?</label>
                    <div class="flex gap-4" data-ps="src/pages/sv/agent-material.astro:etluw9">
                      <label class="flex items-center gap-2 cursor-pointer group">
                        <input type="radio" name="multilingual_sv" value="no" class="peer hidden" checked data-webpage-multilingual-no />
                        <div class="w-4 h-4 rounded-full border border-slate-600 peer-checked:border-blue-500 peer-checked:bg-blue-500 transition-all" data-ps="src/pages/sv/agent-material.astro:etluwa"></div>
                        <span class="text-sm text-slate-400 peer-checked:text-white" data-ps="src/pages/sv/agent-material.astro:m56ybc">Nej</span>
                      </label>
                      <label class="flex items-center gap-2 cursor-pointer group">
                        <input type="radio" name="multilingual_sv" value="yes" class="peer hidden" data-webpage-multilingual-yes />
                        <div class="w-4 h-4 rounded-full border border-slate-600 peer-checked:border-blue-500 peer-checked:bg-blue-500 transition-all" data-ps="src/pages/sv/agent-material.astro:etluwb"></div>
                        <span class="text-sm text-slate-400 peer-checked:text-white" data-ps="src/pages/sv/agent-material.astro:m56ybb">Ja</span>
                      </label>
                    </div>
                    <div class="hidden [.group:has(input[value='yes']:checked)_~_&]:block space-y-3 pt-2" data-ps="src/pages/sv/agent-material.astro:etluwc">
                      <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider">Antal extraspråk</label>
                      <input type="number" min="1" value="1" class="w-20 bg-slate-900 border border-slate-700 rounded px-2 py-1 text-xs text-white focus:outline-none focus:ring-1 focus:ring-blue-500" data-webpage-languages />
                      <p class="text-[10px] text-slate-500" data-ps="src/pages/sv/agent-material.astro:hx2r6q">+10% pris & +3% provision per extraspråk</p>
                    </div>
                  </div>

                  <!-- SEO -->
                  <div class="space-y-4" data-ps="src/pages/sv/agent-material.astro:etluwd">
                    <label class="block text-sm font-medium text-slate-300">SEO-optimerad för något specifikt?</label>
                    <div class="flex gap-4" data-ps="src/pages/sv/agent-material.astro:etluwe">
                      <label class="flex items-center gap-2 cursor-pointer group">
                        <input type="radio" name="seo_sv" value="no" class="peer hidden" checked data-webpage-seo-no />
                        <div class="w-4 h-4 rounded-full border border-slate-600 peer-checked:border-blue-500 peer-checked:bg-blue-500 transition-all" data-ps="src/pages/sv/agent-material.astro:etluwf"></div>
                        <span class="text-sm text-slate-400 peer-checked:text-white" data-ps="src/pages/sv/agent-material.astro:m56yba">Nej</span>
                      </label>
                      <label class="flex items-center gap-2 cursor-pointer group">
                        <input type="radio" name="seo_sv" value="yes" class="peer hidden" data-webpage-seo-yes />
                        <div class="w-4 h-4 rounded-full border border-slate-600 peer-checked:border-blue-500 peer-checked:bg-blue-500 transition-all" data-ps="src/pages/sv/agent-material.astro:etluwg"></div>
                        <span class="text-sm text-slate-400 peer-checked:text-white" data-ps="src/pages/sv/agent-material.astro:m56yb9">Ja</span>
                      </label>
                    </div>
                    <div class="hidden [.group:has(input[value='yes']:checked)_~_&]:block pt-2 space-y-3" data-ps="src/pages/sv/agent-material.astro:etluwh">
                      <textarea placeholder="Beskriv SEO-målen..." class="w-full bg-slate-900 border border-slate-700 rounded-lg px-4 py-2 text-sm text-white h-20 focus:outline-none focus:ring-2 focus:ring-blue-500/50 transition-all resize-none"></textarea>
                      <p class="text-[10px] text-slate-500" data-ps="src/pages/sv/agent-material.astro:hx2r6p">+100€ pris & +10€ provision</p>
                    </div>
                  </div>

                  <!-- Övriga önskemål -->
                  <div class="space-y-4" data-ps="src/pages/sv/agent-material.astro:etluwi">
                    <label class="block text-sm font-medium text-slate-300">Andra önskemål för sidan?</label>
                    <div class="flex gap-4" data-ps="src/pages/sv/agent-material.astro:1t9vl6">
                      <label class="flex items-center gap-2 cursor-pointer group">
                        <input type="radio" name="other_sv" value="no" class="peer hidden" checked />
                        <div class="w-4 h-4 rounded-full border border-slate-600 peer-checked:border-blue-500 peer-checked:bg-blue-500 transition-all" data-ps="src/pages/sv/agent-material.astro:1t9vl5"></div>
