---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHeader from '@/components/PageHeader.astro';

const title = "Tjäna pengar online: Enkla pengar som A-T Agent";
const description = "Vill du tjäna pengar online snabbt och enkelt? Bli en A-T Agent. Tjäna pengar var du än är genom att tipsa om IT-tjänster. Ingen risk, hög ersättning.";
---

<BaseLayout title={title} description={description}>
  <PageHeader
    title="Tjäna pengar online som A-T Agent"
    subtitle="Tjäna enkla pengar var du än är genom att koppla ihop oss med nya kunder. Inga förpliktelser."
  />

  <section class="py-20 bg-white" data-ps="src/pages/sv/agent.astro:sq0sis">
    <div class="container mx-auto px-4" data-ps="src/pages/sv/agent.astro:i1gyxf">
      <div class="grid md:grid-cols-2 gap-12 items-center max-w-6xl mx-auto" data-ps="src/pages/sv/agent.astro:i1gyxg">
        <div data-ps="src/pages/sv/agent.astro:i1gyxh">
          <h2 class="text-3xl font-bold text-slate-900 mb-6" data-ps="src/pages/sv/agent.astro:gui0xb">Tjäna mycket pengar snabbt – var du än är</h2>
          <div class="space-y-4 mb-6" data-ps="src/pages/sv/agent.astro:bbf9iq">
            <p class="text-lg text-slate-600" data-ps="src/pages/sv/agent.astro:ip1jee">
              Har du ett stort nätverk eller känner du företag som söker pålitliga IT-tjänster? Gå med i vårt agentprogram och lär dig hur du kan <strong>tjäna pengar online</strong> genom att förvandla dina kontakter till extra inkomst.
            </p>
            <p class="text-lg text-slate-600" data-ps="src/pages/sv/agent.astro:ip1jef">
              Oavsett om du är en teknikentusiast som vill <strong>tjäna enkla pengar</strong> eller en småföretagare som behöver en pålitlig partner, har vi den perfekta möjligheten för dig. Du kan <strong>tjäna pengar var du än är</strong> — hemifrån, kontoret eller på resande fot — helt enkelt genom att tipsa om våra IT-tjänster.
            </p>
            <p class="text-lg text-slate-600" data-ps="src/pages/sv/agent.astro:ip1jef">
              Med årtionden av erfarenhet sköter vi det tekniska arbetet medan du fokuserar på att tjäna provision. Det är det enklaste sättet att <strong>tjäna mycket pengar snabbt</strong> utan ansvar för projektledning.
            </p>
          </div>
          <ul class="space-y-4 mb-8">
            <li class="flex items-start gap-3" data-ps="src/pages/sv/agent.astro:g3j4fm">
              <div class="mt-1 bg-blue-100 p-1 rounded-full" data-ps="src/pages/sv/agent.astro:i1gyxi">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="text-blue-700"><polyline points="20 6 9 17 4 12"></polyline></svg>
              </div>
              <div data-ps="src/pages/sv/agent.astro:i1gyxj">
                <span class="font-bold text-slate-900" data-ps="src/pages/sv/agent.astro:gghbw3">Hemsideskontrakt:</span> Hjälp företag att få en modern, snabb hemsida och tjäna provision.
              </div>
            </li>
            <li class="flex items-start gap-3" data-ps="src/pages/sv/agent.astro:g3j4fl">
              <div class="mt-1 bg-blue-100 p-1 rounded-full" data-ps="src/pages/sv/agent.astro:i1gyxk">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="text-blue-700"><polyline points="20 6 9 17 4 12"></polyline></svg>
              </div>
              <div data-ps="src/pages/sv/agent.astro:i1gyxl">
                <span class="font-bold text-slate-900" data-ps="src/pages/sv/agent.astro:gghbw4">PC-reparationer & Service:</span> Hänvisa konsumenter eller företag som behöver teknisk support.
              </div>
            </li>
            <li class="flex items-start gap-3" data-ps="src/pages/sv/agent.astro:g3j4fk">
              <div class="mt-1 bg-blue-100 p-1 rounded-full" data-ps="src/pages/sv/agent.astro:i1gyxm">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="text-blue-700"><polyline points="20 6 9 17 4 12"></polyline></svg>
              </div>
              <div data-ps="src/pages/sv/agent.astro:i1gyxn">
                <span class="font-bold text-slate-900" data-ps="src/pages/sv/agent.astro:gghbw5">ConnectMe Kunder:</span> Marknadsför våra smarta uppkopplingslösningar för företag.
              </div>
            </li>
            <li class="flex items-start gap-3" data-ps="src/pages/sv/agent.astro:g3j4fj">
              <div class="mt-1 bg-blue-100 p-1 rounded-full" data-ps="src/pages/sv/agent.astro:i1gyxo">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="text-blue-700"><polyline points="20 6 9 17 4 12"></polyline></svg>
              </div>
              <div data-ps="src/pages/sv/agent.astro:400vis">
                <span class="font-bold text-slate-900" data-ps="src/pages/sv/agent.astro:gghbw6">Företagskunder:</span> Säkra nya förvaltningsavtal för långsiktiga belöningar.
              </div>
            </li>
          </ul>
          <p class="text-slate-600 font-medium italic" data-ps="src/pages/sv/agent.astro:bbf9ir">
            "Det är enkelt: du gör introduktionen, vi gör jobbet, du får betalt."
          </p>
        </div>
        <div class="relative" data-ps="src/pages/sv/agent.astro:400vir">
          <img 
            src="https://images.unsplash.com/photo-1758599543157-bc1a94fec33c?auto=format&w=800&q=80" 
            srcset="https://images.unsplash.com/photo-1758599543157-bc1a94fec33c?auto=format&w=320&q=80 320w, https://images.unsplash.com/photo-1758599543157-bc1a94fec33c?auto=format&w=480&q=80 480w, https://images.unsplash.com/photo-1758599543157-bc1a94fec33c?auto=format&w=640&q=80 640w, https://images.unsplash.com/photo-1758599543157-bc1a94fec33c?auto=format&w=800&q=80 800w"
            sizes="(max-width: 768px) 100vw, 50vw"
            alt="Business handshake and partnership" 
            class="rounded-2xl shadow-2xl w-full object-cover aspect-[4/3]"
            crossorigin="anonymous" data-ps="src/pages/sv/agent.astro:fj7ulb" />
          <div class="absolute -bottom-6 -right-6 bg-blue-600 text-white p-8 rounded-2xl shadow-xl hidden md:block" data-ps="src/pages/sv/agent.astro:400viq">
            <p class="text-2xl font-bold" data-ps="src/pages/sv/agent.astro:bbf9is">Ingen Risk.</p>
            <p class="text-lg opacity-90" data-ps="src/pages/sv/agent.astro:bbf9it">Bara Möjlighet.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 bg-slate-50" data-ps="src/pages/sv/agent.astro:sq0sit">
    <div class="container mx-auto px-4 max-w-4xl text-center" data-ps="src/pages/sv/agent.astro:400vip">
      <h2 class="text-3xl font-bold text-slate-900 mb-8" data-ps="src/pages/sv/agent.astro:gui0xa">Registrera dig som Agent</h2>
      <div class="bg-white p-8 md:p-12 rounded-3xl shadow-sm border border-slate-200" data-ps="src/pages/sv/agent.astro:400vio">
        <form class="grid md:grid-cols-2 gap-6 text-left">
          <div class="space-y-2" data-ps="src/pages/sv/agent.astro:400vin">
            <label class="block text-sm font-semibold text-slate-700">Fullständigt Namn</label>
            <input type="text" placeholder="Ditt Namn" class="w-full px-4 py-3 rounded-xl border border-slate-300 focus:ring-2 focus:ring-blue-600 focus:border-transparent outline-none transition-all" />
          </div>
          <div class="space-y-2" data-ps="src/pages/sv/agent.astro:400vim">
            <label class="block text-sm font-semibold text-slate-700">E-postadress</label>
            <input type="email" placeholder="din@epost.se" class="w-full px-4 py-3 rounded-xl border border-slate-300 focus:ring-2 focus:ring-blue-600 focus:border-transparent outline-none transition-all" />
          </div>
          <div class="space-y-2 md:col-span-2" data-ps="src/pages/sv/agent.astro:400vil">
            <label class="block text-sm font-semibold text-slate-700">Telefonnummer</label>
            <input type="tel" placeholder="+358..." class="w-full px-4 py-3 rounded-xl border border-slate-300 focus:ring-2 focus:ring-blue-600 focus:border-transparent outline-none transition-all" />
          </div>
          <div class="space-y-2 md:col-span-2" data-ps="src/pages/sv/agent.astro:400vik">
            <label class="block text-sm font-semibold text-slate-700">Berätta lite om dig själv/ditt nätverk</label>
            <textarea rows="4" placeholder="Hur planerar du att hitta kunder?" class="w-full px-4 py-3 rounded-xl border border-slate-300 focus:ring-2 focus:ring-blue-600 focus:border-transparent outline-none transition-all resize-none"></textarea>
          </div>
          <div class="md:col-span-2 pt-4" data-ps="src/pages/sv/agent.astro:400vij">
            <button type="submit" class="w-full bg-blue-600 hover:bg-blue-700 text-white font-bold py-4 px-8 rounded-xl transition-all shadow-lg shadow-blue-200" data-ps="src/pages/sv/agent.astro:ui7k1e">
              Registrera dig Nu & Börja Tjäna
            </button>
            <p class="text-center text-sm text-slate-500 mt-4" data-ps="src/pages/sv/agent.astro:bbf9iu">
              Genom att registrera dig godkänner du att representera Archipelago Technics professionellt.
            </p>
          </div>
        </form>
      </div>
    </div>
  </section>
</BaseLayout>
