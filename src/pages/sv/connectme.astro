---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHeader from '@/components/PageHeader.astro';

const lang = 'sv';
---

<BaseLayout 
  title="ConnectMe | Proaktiv IT-säkerhet"
  description="ConnectMe är Archipelago Technics omfattande säkerhetspaket som inkluderar Bitdefender, Pulseway och automatisk säkerhetskopiering."
  lang={lang}
>
  <PageHeader 
    title="ConnectMe" 
    subtitle="Bättre att förebygga och förhindra än att ångra och reparera."
  />

  <section class="py-24 bg-zinc-950" data-ps="src/pages/sv/connectme.astro:6hfbc8">
    <div class="max-w-7xl mx-auto px-6" data-ps="src/pages/sv/connectme.astro:tqzqoe">
      <div class="grid lg:grid-cols-2 gap-16 items-center" data-ps="src/pages/sv/connectme.astro:tqzqod">
        <div data-ps="src/pages/sv/connectme.astro:tqzqoc">
          <h2 class="text-4xl font-black text-white mb-6 leading-tight" data-ps="src/pages/sv/connectme.astro:h6xn67">
            Varför välja <span class="text-[#F54a00]" data-ps="src/pages/sv/connectme.astro:oeusmo">ConnectMe?</span>
          </h2>
          <p class="text-xl text-white/70 mb-8 leading-relaxed" data-ps="src/pages/sv/connectme.astro:v4j1dj">
            När cyberattackerna ökar är det viktigare än någonsin att skydda dina system. Regelbundna uppdateringar och övervakning förbättrar prestandan och minskar sårbarheter.
          </p>
          
          <div class="space-y-6" data-ps="src/pages/sv/connectme.astro:tqzqob">
            <div class="flex gap-4" data-ps="src/pages/sv/connectme.astro:tqzqoa">
              <div class="w-12 h-12 bg-[#F54a00]/10 rounded-xl flex items-center justify-center shrink-0" data-ps="src/pages/sv/connectme.astro:tqzqo9">
                <svg class="w-6 h-6 text-[#F54a00]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
              </div>
              <div data-ps="src/pages/sv/connectme.astro:tqzqo8">
                <h3 class="text-xl font-bold text-white mb-2" data-ps="src/pages/sv/connectme.astro:vvckdv">Bitdefender Säkerhet</h3>
                <p class="text-white/60" data-ps="src/pages/sv/connectme.astro:v4j1dk">Globalt betrodd skydd mot virus och skadlig kod med maskininlärning.</p>
              </div>
            </div>
            
            <div class="flex gap-4" data-ps="src/pages/sv/connectme.astro:tqzqo7">
              <div class="w-12 h-12 bg-[#F54a00]/10 rounded-xl flex items-center justify-center shrink-0" data-ps="src/pages/sv/connectme.astro:eph18x">
                <svg class="w-6 h-6 text-[#F54a00]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" /></svg>
              </div>
              <div data-ps="src/pages/sv/connectme.astro:eph18w">
                <h3 class="text-xl font-bold text-white mb-2" data-ps="src/pages/sv/connectme.astro:vvckdu">Pulseway Övervakning</h3>
                <p class="text-white/60" data-ps="src/pages/sv/connectme.astro:v4j1dl">Proaktiva varningar, fjärrhjälp och automatisk mjukvaruhantering håller din dator uppdaterad.</p>
              </div>
            </div>

            <div class="flex gap-4" data-ps="src/pages/sv/connectme.astro:eph18v">
              <div class="w-12 h-12 bg-[#F54a00]/10 rounded-xl flex items-center justify-center shrink-0" data-ps="src/pages/sv/connectme.astro:eph18u">
                <svg class="w-6 h-6 text-[#F54a00]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-3m-1 4l-3 3m0 0l-3-3m3 3V4" /></svg>
              </div>
              <div data-ps="src/pages/sv/connectme.astro:eph18t">
                <h3 class="text-xl font-bold text-white mb-2" data-ps="src/pages/sv/connectme.astro:vvckdt">Automatisk Backup</h3>
                <p class="text-white/60" data-ps="src/pages/sv/connectme.astro:v4j1e7">Vi håller din data säker. Om din enhet går sönder återställer vi snabbt din information.</p>
              </div>
            </div>
          </div>
        </div>
        
        <div class="relative" data-ps="src/pages/sv/connectme.astro:eph18s">
          <div class="absolute inset-0 bg-gradient-to-tr from-[#F54a00]/20 to-transparent rounded-3xl blur-3xl" data-ps="src/pages/sv/connectme.astro:eph18r"></div>
          <div class="relative bg-white/5 border border-white/10 p-12 rounded-3xl backdrop-blur-sm" data-ps="src/pages/sv/connectme.astro:eph18q">
            <h3 class="text-2xl font-bold text-white mb-6" data-ps="src/pages/sv/connectme.astro:vvckds">Personlig Service</h3>
            <p class="text-white/70 mb-8 italic" data-ps="src/pages/sv/connectme.astro:v4j1e8">
              "Tillsammans klarar vi alla utmaningar som IT-världen erbjuder."
            </p>
            <p class="text-white/60 mb-8" data-ps="src/pages/sv/connectme.astro:v4j1e9">
              Hos oss på Archipelago Technics pratar du alltid med en människa. Vi tar hand om varje kund personligen och du slipper prata med robotar.
            </p>
            <a href="https://connectme.fi" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-[#F54a00] font-bold hover:gap-3 transition-all" data-ps="src/pages/sv/connectme.astro:wsn3vv">
              Läs mer på ConnectMe.fi
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-24 bg-white" data-ps="src/pages/sv/connectme.astro:6hfbc7">
    <div class="max-w-4xl mx-auto px-6 text-center" data-ps="src/pages/sv/connectme.astro:eph18p">
      <h2 class="text-4xl font-black text-zinc-900 mb-6" data-ps="src/pages/sv/connectme.astro:h6xn66">Redo att säkra din enhet?</h2>
      <p class="text-xl text-zinc-600 mb-10" data-ps="src/pages/sv/connectme.astro:v4j1ea">
        ConnectMe är det enklaste sättet att se till att din dator alltid är säker, uppdaterad och redo för användning.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center" data-ps="src/pages/sv/connectme.astro:eph18o">
        <a href="https://connectme.fi/sv/prislista" target="_blank" class="px-8 py-4 bg-[#F54a00] text-zinc-950 rounded-xl font-bold text-lg hover:bg-[#D43F00] transition-colors" data-ps="src/pages/sv/connectme.astro:wsn3vu">
          Se Prislista
        </a>
        <a href="/sv/bokning" class="px-8 py-4 bg-zinc-900 text-white rounded-xl font-bold text-lg hover:bg-zinc-800 transition-colors" data-ps="src/pages/sv/connectme.astro:wsn3vt">
          Boka Konsultation
        </a>
      </div>
    </div>
  </section>
</BaseLayout>