---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHeader from '@/components/PageHeader.astro';

const title = "Datorservice Åbo | Gratis hämtning och lämning";
const description = "Behöver du datorservice eller reparation i Åboregionen? Archipelago Technics erbjuder en smidig hämtservice: vi hämtar din enhet från ditt hem och lämnar tillbaka den reparerad.";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Datorservice och hämttjänst Åbo",
  "provider": {
    "@type": "LocalBusiness",
    "name": "Archipelago Technics",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Industrigatan 22",
      "addressLocality": "Pargas",
      "postalCode": "21600",
      "addressRegion": "Åboregionen",
      "addressCountry": "FI"
    },
    "telephone": "+358405829704"
  },
  "areaServed": "Åbo, Pargas, S:t Karins",
  "description": "Datorservice och reparation med gratis hämtning och lämning i Åboregionen.",
  "serviceType": "Datorservice Åbo"
};
---

<BaseLayout title={title} description={description} lang="sv" jsonLd={jsonLd}>
  <PageHeader 
    title="Datorservice och reparation Åbo" 
    description="Smidig hämtservice – vi hämtar din dator från ditt hem, servar den och lämnar tillbaka den." 
  />

  <section class="py-16 md:py-24" data-ps="src/pages/sv/datorservice-abo.astro:s3v1">
    <div class="max-w-7xl mx-auto px-6" data-ps="src/pages/sv/datorservice-abo.astro:d7qx1w">
      <div class="grid md:grid-cols-2 gap-12 items-center" data-ps="src/pages/sv/datorservice-abo.astro:d7qx1x">
        <div class="prose prose-invert prose-lg" data-ps="src/pages/sv/datorservice-abo.astro:d7qx2j">
          <h2 class="text-3xl font-bold mb-6" data-ps="src/pages/sv/datorservice-abo.astro:kmdzaf">Datorservice Åbo: Enkel och snabb hämtservice</h2>
          <p data-ps="src/pages/sv/datorservice-abo.astro:iixm1d">
            Är din dator långsam, startar den inte eller behöver den rengöras? Vi gör servicen så enkel som möjligt för dig. Du behöver inte släpa din maskin till en verkstad – <strong>vi hämtar den direkt från din dörr i Åboregionen.</strong>
          </p>
          <p data-ps="src/pages/sv/datorservice-abo.astro:iixm1e">
            När servicen är klar lämnar vi tillbaka enheten till ditt hem vid en överenskommen tidpunkt. Hämtning och lämning är helt gratis i Åboregionen när du beställer reparationsservice från oss.
          </p>
          <div class="mt-8 flex flex-col sm:flex-row gap-4" data-ps="src/pages/sv/datorservice-abo.astro:d7qx2k">
            <a href="/sv/bokning" class="inline-flex justify-center items-center px-6 py-3 border border-transparent text-base font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700 transition-colors shadow-lg shadow-blue-500/20" data-ps="src/pages/sv/datorservice-abo.astro:pmviqg">
              Boka hämtning online
            </a>
            <a href="tel:+358405829704" class="inline-flex justify-center items-center px-6 py-3 border border-gray-700 text-base font-medium rounded-md text-white bg-transparent hover:bg-gray-800 transition-colors" data-ps="src/pages/sv/datorservice-abo.astro:pmvir2">
              Ring och boka hämtning: 040 582 9704
            </a>
          </div>
        </div>
        <div class="relative" data-ps="src/pages/sv/datorservice-abo.astro:d7qx2l">
          <img 
            crossorigin="anonymous"
            src="https://images.unsplash.com/photo-1699905527162-8b932a8e9206?auto=format&w=1200&q=80" 
            srcset="https://images.unsplash.com/photo-1699905527162-8b932a8e9206?auto=format&w=320&q=80 320w, https://images.unsplash.com/photo-1699905527162-8b932a8e9206?auto=format&w=480&q=80 480w, https://images.unsplash.com/photo-1699905527162-8b932a8e9206?auto=format&w=800&q=80 800w, https://images.unsplash.com/photo-1699905527162-8b932a8e9206?auto=format&w=1200&q=80 1200w"
            sizes="(max-width: 768px) 100vw, 50vw"
            alt="Datorservice Åbo" 
            class="rounded-2xl shadow-2xl w-full object-cover aspect-4/3" 
            loading="eager" data-ps="src/pages/sv/datorservice-abo.astro:aphsqf" />
          <div class="absolute -bottom-6 -left-6 bg-blue-600 p-6 rounded-xl hidden lg:block shadow-xl" data-ps="src/pages/sv/datorservice-abo.astro:d7qx2m">
            <span class="text-white font-bold text-lg block" data-ps="src/pages/sv/datorservice-abo.astro:3zmpav">Hämtning & Lämning</span>
            <span class="text-blue-50" data-ps="src/pages/sv/datorservice-abo.astro:3zmpau">0 € i Åboregionen</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-gray-900/50" data-ps="src/pages/sv/datorservice-abo.astro:s3v2">
    <div class="max-w-7xl mx-auto px-6 text-center mb-16" data-ps="src/pages/sv/datorservice-abo.astro:d7qx2n">
      <h2 class="text-3xl font-bold mb-4" data-ps="src/pages/sv/datorservice-abo.astro:kmdzag">Hur fungerar det?</h2>
      <p class="text-gray-400 max-w-2xl mx-auto" data-ps="src/pages/sv/datorservice-abo.astro:iixm1f">Tre enkla steg för att få din dator i skick.</p>
    </div>
    
    <div class="max-w-7xl mx-auto px-6 grid md:grid-cols-3 gap-8" data-ps="src/pages/sv/datorservice-abo.astro:d7qx2o">
      <div class="p-8 bg-gray-950 rounded-2xl border border-gray-800 hover:border-blue-500 transition-colors text-center group" data-ps="src/pages/sv/datorservice-abo.astro:d7qx2p">
        <div class="w-16 h-16 bg-blue-600/10 rounded-full flex items-center justify-center mx-auto mb-6 group-hover:bg-blue-600/20 transition-colors" data-ps="src/pages/sv/datorservice-abo.astro:d7qx2q">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-blue-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2-2v12a2 2 0 002 2z" />
          </svg>
        </div>
        <h3 class="text-xl font-bold mb-4" data-ps="src/pages/sv/datorservice-abo.astro:5xz223">1. Boka tid</h3>
        <p class="text-gray-400" data-ps="src/pages/sv/datorservice-abo.astro:iixm1g">Boka en hämttid direkt från vår webbplats eller ring oss. Vi kommer överens om en lämplig tid för att hämta enheten från ditt hem.</p>
      </div>

      <div class="p-8 bg-gray-950 rounded-2xl border border-gray-800 hover:border-blue-500 transition-colors text-center group" data-ps="src/pages/sv/datorservice-abo.astro:d7qx2r">
        <div class="w-16 h-16 bg-blue-600/10 rounded-full flex items-center justify-center mx-auto mb-6 group-hover:bg-blue-600/20 transition-colors" data-ps="src/pages/sv/datorservice-abo.astro:d7qx2s">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-blue-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
          </svg>
        </div>
        <h3 class="text-xl font-bold mb-4" data-ps="src/pages/sv/datorservice-abo.astro:5xz224">2. Service</h3>
        <p class="text-gray-400" data-ps="src/pages/sv/datorservice-abo.astro:iixm1h">Vi hämtar maskinen och utför nödvändiga serviceåtgärder och reparationer professionellt vid vår servicepunkt i Pargas–Åbo området.</p>
      </div>

      <div class="p-8 bg-gray-950 rounded-2xl border border-gray-800 hover:border-blue-500 transition-colors text-center group" data-ps="src/pages/sv/datorservice-abo.astro:l1qfkk">
        <div class="w-16 h-16 bg-blue-600/10 rounded-full flex items-center justify-center mx-auto mb-6 group-hover:bg-blue-600/20 transition-colors" data-ps="src/pages/sv/datorservice-abo.astro:l1qfkl">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-blue-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
          </svg>
        </div>
        <h3 class="text-xl font-bold mb-4" data-ps="src/pages/sv/datorservice-abo.astro:5xz225">3. Hemleverans</h3>
        <p class="text-gray-400" data-ps="src/pages/sv/datorservice-abo.astro:iixm23">Vi hämtar den servade och fungerande datorn tillbaka till ditt hem. Du kan fortsätta arbeta utan onödig väntan eller resande.</p>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-24" data-ps="src/pages/sv/datorservice-abo.astro:s3v3">
    <div class="max-w-4xl mx-auto px-6" data-ps="src/pages/sv/datorservice-abo.astro:l1qfkm">
      <h2 class="text-3xl font-bold mb-12 text-center" data-ps="src/pages/sv/datorservice-abo.astro:kmdzah">Vanliga frågor – Datorservice Åbo</h2>
      
      <div class="space-y-8" data-ps="src/pages/sv/datorservice-abo.astro:l1qfkn">
        <div data-ps="src/pages/sv/datorservice-abo.astro:l1qfko">
          <h3 class="text-xl font-bold mb-3 text-blue-400" data-ps="src/pages/sv/datorservice-abo.astro:5xz226">Är hämttjänsten verkligen gratis?</h3>
          <p class="text-gray-400" data-ps="src/pages/sv/datorservice-abo.astro:iixm24">Ja, vi erbjuder gratis hämtning och lämning för alla som behöver datorservice eller reparation i Åbo, Pargas och S:t Karins.</p>
        </div>
        
        <div data-ps="src/pages/sv/datorservice-abo.astro:l1qfkp">
          <h3 class="text-xl font-bold mb-3 text-blue-400" data-ps="src/pages/sv/datorservice-abo.astro:5xz22s">Vad kostar datorreparation i Åbo?</h3>
          <p class="text-gray-400" data-ps="src/pages/sv/datorservice-abo.astro:iixm25">Priset på servicen beror på de åtgärder som krävs och eventuella reservdelar. Vi ger alltid en uppskattning av kostnaderna innan arbetet påbörjas, så att du vet exakt vad du betalar.</p>
        </div>
        
        <div data-ps="src/pages/sv/datorservice-abo.astro:l1qfkq">
          <h3 class="text-xl font-bold mb-3 text-blue-400" data-ps="src/pages/sv/datorservice-abo.astro:5xz22t">Hur länge tar en datorservice?</h3>
          <p class="text-gray-400" data-ps="src/pages/sv/datorservice-abo.astro:iixm26">Vanligtvis är reparationen klar inom 1–3 arbetsdagar från hämtningen, beroende på reparationens omfattning och tillgången på reservdelar.</p>
        </div>

        <div data-ps="src/pages/sv/datorservice-abo.astro:l1qfkr">
          <h3 class="text-xl font-bold mb-3 text-blue-400" data-ps="src/pages/sv/datorservice-abo.astro:5xz22u">Kan ni laga datorn på plats i mitt hem?</h3>
          <p class="text-gray-400" data-ps="src/pages/sv/datorservice-abo.astro:iixm27">Många mjukvaruproblem och nätverksinstallationer kan skötas direkt vid ett hembesök. Om felet kräver grundligare reparation eller byte av delar, använder vi vår hämtservice för att ta enheten till våra lokaler.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-blue-600" data-ps="src/pages/sv/datorservice-abo.astro:s3v4">
    <div class="max-w-4xl mx-auto px-6 text-center" data-ps="src/pages/sv/datorservice-abo.astro:l1qfks">
      <h2 class="text-3xl font-bold text-white mb-6" data-ps="src/pages/sv/datorservice-abo.astro:kmdzai">Behöver du datorservice i Åbo?</h2>
      <p class="text-xl text-blue-50 mb-8" data-ps="src/pages/sv/datorservice-abo.astro:iixm28">Kontakta oss och beställ din gratis hämtning redan idag!</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center" data-ps="src/pages/sv/datorservice-abo.astro:l1qfkt">
        <a href="/sv/bokning" class="px-8 py-4 bg-white text-blue-600 font-bold rounded-xl hover:bg-gray-100 transition-colors shadow-lg" data-ps="src/pages/sv/datorservice-abo.astro:pmvir3">
          Boka hämtning nu
        </a>
        <a href="tel:+358405829704" class="px-8 py-4 border-2 border-white text-white font-bold rounded-xl hover:bg-blue-700 transition-colors" data-ps="src/pages/sv/datorservice-abo.astro:pmvir4">
          Ring: 040 582 9704
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
