---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHeader from '@/components/PageHeader.astro';

const title = "IT-fjärrsupport för företag i hela Sverige och Finland | Archipelago Technics";
const description = "Snabb och professionell IT-fjärrsupport och IT-hjälp för företag i hela Sverige och Finland. Vi löser era datorproblem på distans snabbt och säkert.";
---

<BaseLayout 
  title={title} 
  description={description} 
  lang="sv"
  jsonLd={{
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "IT-fjärrsupport",
    "description": "Professionell IT-fjärrsupport för företag i hela Sverige och Finland.",
    "provider": {
      "@type": "LocalBusiness",
      "name": "Archipelago Technics",
      "url": "https://a-t.fi/sv/fjarrsupport"
    },
    "areaServed": [
      { "@type": "Country", "name": "Sweden" },
      { "@type": "Country", "name": "Finland" }
    ]
  }}
>
  <PageHeader title={title} description={description} />
  
  <div class="max-w-7xl mx-auto px-6 py-16" data-ps="src/pages/sv/fjarrsupport.astro:4rq32m">
    <div class="grid lg:grid-cols-2 gap-12 mb-16 items-center" data-ps="src/pages/sv/fjarrsupport.astro:4rq32l">
      <div class="prose prose-lg prose-invert" data-ps="src/pages/sv/fjarrsupport.astro:4rq32k">
        <h2 class="text-3xl font-bold text-white mb-6" data-ps="src/pages/sv/fjarrsupport.astro:abun9j">Datorproblem?</h2>
        <p class="lead text-xl text-orange-400 font-semibold" data-ps="src/pages/sv/fjarrsupport.astro:furipg">
          Få personlig IT-fjärrsupport av oss, utan långa väntetider!
        </p>
        <p data-ps="src/pages/sv/fjarrsupport.astro:furipf">
          Vi hjälper företag med alla IT-ärenden på distans i hela Sverige och Finland! Fjärr-IT-hjälp för företag effektiverar er affärsverksamhet 
          och förbättrar era anställdas produktivitet genom att erbjuda realtids och effektivt stöd för alla IT-problem, oavsett var ni befinner er.
        </p>
        <p data-ps="src/pages/sv/fjarrsupport.astro:furipe">
          Våra experter är redo att hjälpa dig med alla dina IT-utmaningar. Vi erbjuder säker, 
          pålitlig och snabb service som gör ditt företags IT-miljö smidig och sömlös.
        </p>
        <div class="mt-8 flex flex-col sm:flex-row gap-4" data-ps="src/pages/sv/fjarrsupport.astro:4rq32j">
          <a href="tel:+358405829704" class="bg-orange-700 hover:bg-orange-800 text-white font-bold py-3 px-6 rounded-lg transition text-center" data-ps="src/pages/sv/fjarrsupport.astro:8qtm09">
            Ring: 040 582 9704
          </a>
          <a href="/sv/kontakt" class="bg-zinc-800 hover:bg-zinc-700 text-white font-bold py-3 px-6 rounded-lg transition text-center border border-zinc-700" data-ps="src/pages/sv/fjarrsupport.astro:8qtlzn">
            Lämna kontaktbegäran
          </a>
        </div>
      </div>
      <div data-ps="src/pages/sv/fjarrsupport.astro:dwgq19">
        <img crossorigin="anonymous" src="https://images.unsplash.com/photo-1758577515339-93872db0d37e?auto=format&w=800&q=80" 
          class="rounded-xl shadow-2xl w-full h-full object-cover" 
          alt="Fjärrsupport" data-ps="src/pages/sv/fjarrsupport.astro:79z7e3" />
      </div>
    </div>

    <div class="grid md:grid-cols-3 gap-8 mb-16" data-ps="src/pages/sv/fjarrsupport.astro:dwgq18">
      <div class="bg-zinc-900 p-8 rounded-xl border border-zinc-800" data-ps="src/pages/sv/fjarrsupport.astro:dwgq17">
        <h3 class="text-xl font-bold text-white mb-4" data-ps="src/pages/sv/fjarrsupport.astro:4ck9y4">Dagligt stöd</h3>
        <p class="text-zinc-400" data-ps="src/pages/sv/fjarrsupport.astro:furipd">Dagligt stöd för anställda i alla datatekniska problem.</p>
      </div>
      <div class="bg-zinc-900 p-8 rounded-xl border border-zinc-800" data-ps="src/pages/sv/fjarrsupport.astro:dwgq16">
        <h3 class="text-xl font-bold text-white mb-4" data-ps="src/pages/sv/fjarrsupport.astro:4ck9y3">Mjukvarustöd</h3>
        <p class="text-zinc-400" data-ps="src/pages/sv/fjarrsupport.astro:furipc">Frågor relaterade till programvara, som t.ex. Microsoft Office 365.</p>
      </div>
      <div class="bg-zinc-900 p-8 rounded-xl border border-zinc-800" data-ps="src/pages/sv/fjarrsupport.astro:dwgq15">
        <h3 class="text-xl font-bold text-white mb-4" data-ps="src/pages/sv/fjarrsupport.astro:4ck9y2">Felsökning</h3>
        <p class="text-zinc-400" data-ps="src/pages/sv/fjarrsupport.astro:furipb">Systemuppdateringar, felsökning och service via fjärranslutning.</p>
      </div>
    </div>

    <div class="bg-zinc-900 p-10 rounded-2xl border border-zinc-800" data-ps="src/pages/sv/fjarrsupport.astro:dwgq14">
      <h2 class="text-3xl font-bold text-white mb-6" data-ps="src/pages/sv/fjarrsupport.astro:abun9k">Ulkoistad IT-support</h2>
      <div class="grid md:grid-cols-2 gap-8" data-ps="src/pages/sv/fjarrsupport.astro:dwgq13">
        <div data-ps="src/pages/sv/fjarrsupport.astro:dwgq12">
          <p class="text-zinc-300 mb-4" data-ps="src/pages/sv/fjarrsupport.astro:furipa">
            Vi erbjuder extra resurshjälp för nuvarande IT-avdelning vid brådska eller helhetsmässig outsourcing.
            Vi är lösningen när:
          </p>
          <ul class="list-disc list-inside text-zinc-300 space-y-2">
            <li data-ps="src/pages/sv/fjarrsupport.astro:b2tjqj">Ni behöver genast hjälp med IT-bekymmer</li>
            <li data-ps="src/pages/sv/fjarrsupport.astro:b2tjqk">Ni behöver ett nummer att ringa för omedelbar personlig hjälp utan kö</li>
            <li data-ps="src/pages/sv/fjarrsupport.astro:b2tjql">Ni inte vet vad ett IT-fel beror på eller inte kan fixa det</li>
            <li data-ps="src/pages/sv/fjarrsupport.astro:b2tjqm">Ni behöver hjälp med frågor kring uppdateringar</li>
          </ul>
        </div>
        <div class="flex items-center justify-center bg-zinc-950/50 rounded-xl p-8" data-ps="src/pages/sv/fjarrsupport.astro:dwgq11">
          <div class="text-center" data-ps="src/pages/sv/fjarrsupport.astro:dwgq10">
            <p class="text-2xl font-bold text-orange-400 mb-2" data-ps="src/pages/sv/fjarrsupport.astro:furip9">Personlig service</p>
            <p class="text-white" data-ps="src/pages/sv/fjarrsupport.astro:furip8">Alltid. Det är ett löfte!</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
