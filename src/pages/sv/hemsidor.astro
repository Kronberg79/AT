---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHeader from '@/components/PageHeader.astro';

const title = "Hemsidor för Företag i Åbo | Google Optimering & Websites Finland";
const description = "Letar du efter billiga hemsidor för företag i Åbo? Vi erbjuder professionell Google-optimering och moderna lösningar för hemsidor i hela Finland.";
---

<BaseLayout title={title} description={description} lang="sv">
  <PageHeader title="Hemsidor & Google Optimering" description="Professionella och prisvärda hemsidor för företag i Åboregionen. Vi skapar moderna webbtjänster som även hittas på Google." />
  
  <div class="max-w-5xl mx-auto px-6 py-16" data-ps="src/pages/sv/hemsidor.astro:6ucpu9">
    <div class="prose prose-invert prose-lg max-w-none" data-ps="src/pages/sv/hemsidor.astro:6ucpub">
      <div class="grid md:grid-cols-2 gap-12 items-center mb-16" data-ps="src/pages/sv/hemsidor.astro:intro-grid">
        <div data-ps="src/pages/sv/hemsidor.astro:intro-text">
          <h2 class="text-3xl font-bold text-white mb-6 mt-0" data-ps="src/pages/sv/hemsidor.astro:h2-1">Moderna hemsidor för företag i Åbo</h2>
          <p class="text-zinc-300 leading-relaxed" data-ps="src/pages/sv/hemsidor.astro:p-1">
            Letar du efter prisvärda men högkvalitativa hemsidor för ditt företag? Vi erbjuder helt skräddarsydda webbtjänster samt moderna <strong>Websites Finland</strong>-lösningar. 
            Vi fokuserar särskilt på snabbhet, användarvänlighet och effektiv <strong>Google-optimering</strong>, så att din webbplats inte bara ser bra ut, utan också ger resultat.
          </p>
          <p class="text-zinc-300" data-ps="src/pages/sv/hemsidor.astro:p-intro-2">
            Vi erbjuder marknadens kanske <strong>billigaste hemsidor</strong> utan att pruta på kvaliteten genom att använda den senaste tekniken och automatiserade arbetsflöden.
          </p>
        </div>
        <div class="relative rounded-2xl overflow-hidden shadow-2xl border border-zinc-700 aspect-video md:aspect-square" data-ps="src/pages/sv/hemsidor.astro:intro-image-container">
          <img 
            crossorigin="anonymous"
            src="https://images.unsplash.com/photo-1460925895917-afdab827c52f?auto=format&w=1200&q=80"
            srcset="https://images.unsplash.com/photo-1460925895917-afdab827c52f?auto=format&w=320&q=80 320w, https://images.unsplash.com/photo-1460925895917-afdab827c52f?auto=format&w=480&q=80 480w, https://images.unsplash.com/photo-1460925895917-afdab827c52f?auto=format&w=640&q=80 640w, https://images.unsplash.com/photo-1460925895917-afdab827c52f?auto=format&w=768&q=80 768w, https://images.unsplash.com/photo-1460925895917-afdab827c52f?auto=format&w=1024&q=80 1024w"
            sizes="(max-width: 768px) 100vw, 50vw"
            alt="Hemsidor och Google-optimering Åbo" 
            class="absolute inset-0 w-full h-full object-cover"
            loading="lazy" data-ps="src/pages/sv/hemsidor.astro:p1qk85" />
        </div>
      </div>

      <div class="my-20 bg-zinc-900/50 rounded-3xl overflow-hidden border border-zinc-800 shadow-xl" data-ps="src/pages/sv/hemsidor.astro:pagesmith-promo">
        <div class="grid md:grid-cols-2 items-stretch" data-ps="src/pages/sv/hemsidor.astro:promo-grid">
          <div class="p-8 md:p-14 flex flex-col justify-center" data-ps="src/pages/sv/hemsidor.astro:6ucpua">
            <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-blue-600/10 text-blue-400 text-sm font-semibold mb-6 border border-blue-600/20 w-fit" data-ps="src/pages/sv/hemsidor.astro:badge">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/></svg>
              Modern Websites Finland-teknik
            </div>
            <h3 class="text-3xl md:text-4xl font-bold text-white mt-0 mb-6 leading-tight" data-ps="src/pages/sv/hemsidor.astro:96zy1i">Professionella hemsidor snabbt</h3>
            <p class="text-zinc-300 text-lg mb-8" data-ps="src/pages/sv/hemsidor.astro:n66jsh">Vi använder den senaste tekniken för att skapa snygga och högpresterande hemsidor för företag i Åboregionen. Detta är det perfekta valet när du letar efter <strong>prisvärda hemsidor</strong> utan att pruta på kvaliteten.</p>
            <ul class="space-y-4 mb-0 list-none p-0">
              <li class="flex items-start gap-3 text-white" data-ps="src/pages/sv/hemsidor.astro:gbvx76">
                <div class="mt-1 flex-shrink-0 w-6 h-6 rounded-full bg-blue-600/20 flex items-center justify-center text-blue-400 font-bold text-sm" data-ps="src/pages/sv/hemsidor.astro:rjzojn">✓</div>
                <div data-ps="src/pages/sv/hemsidor.astro:rjzojo"><strong class="text-white block">Ultrasnabb publicering</strong> Färdiga sidor på bara några dagar.</div>
              </li>
              <li class="flex items-start gap-3 text-white" data-ps="src/pages/sv/hemsidor.astro:gbvx77">
                <div class="mt-1 flex-shrink-0 w-6 h-6 rounded-full bg-blue-600/20 flex items-center justify-center text-blue-400 font-bold text-sm" data-ps="src/pages/sv/hemsidor.astro:rjzojp">✓</div>
                <div data-ps="src/pages/sv/hemsidor.astro:rjzokb"><strong class="text-white block">Modern & Responsiiv</strong> Sidorna fungerar perfekt på alla enheter.</div>
              </li>
              <li class="flex items-start gap-3 text-white" data-ps="src/pages/sv/hemsidor.astro:gbvx78">
                <div class="mt-1 flex-shrink-0 w-6 h-6 rounded-full bg-blue-600/20 flex items-center justify-center text-blue-400 font-bold text-sm" data-ps="src/pages/sv/hemsidor.astro:rjzokc">✓</div>
                <div data-ps="src/pages/sv/hemsidor.astro:rjzokd"><strong class="text-white block">Inbyggd Google-optimering</strong> Sökmotorsynligheten är inbyggd direkt i webbplatsen.</div>
              </li>
            </ul>
          </div>
          <div class="min-h-[400px] relative bg-zinc-800" data-ps="src/pages/sv/hemsidor.astro:6ucpuc">
            <img 
              crossorigin="anonymous"
              src="https://images.unsplash.com/photo-1498050108023-c5249f4df085?auto=format&w=1200&q=80"
              srcset="https://images.unsplash.com/photo-1498050108023-c5249f4df085?auto=format&w=800&q=80 800w, https://images.unsplash.com/photo-1498050108023-c5249f4df085?auto=format&w=1200&q=80 1200w"
              sizes="(max-width: 768px) 100vw, 50vw"
              alt="Kodning och webbtjänster" 
              class="absolute inset-0 w-full h-full object-cover opacity-80"
              loading="lazy" data-ps="src/pages/sv/hemsidor.astro:p1qk86" />
          </div>
        </div>
      </div>

      <div class="text-center mb-12" data-ps="src/pages/sv/hemsidor.astro:services-intro">
        <h2 class="text-3xl font-bold text-white mb-4" data-ps="src/pages/sv/hemsidor.astro:96zy1j">Tjänster för olika behov</h2>
        <p class="text-zinc-400 max-w-2xl mx-auto" data-ps="src/pages/sv/hemsidor.astro:services-p">Vi erbjuder flexibla lösningar för både små och stora företag i Åbo.</p>
      </div>

      <div class="grid md:grid-cols-2 gap-6 mb-20" data-ps="src/pages/sv/hemsidor.astro:grid">
        <div class="bg-zinc-900/40 p-8 rounded-2xl border border-zinc-800 hover:border-zinc-700 transition-all group" data-ps="src/pages/sv/hemsidor.astro:card-1">
          <div class="w-12 h-12 bg-blue-600/10 rounded-xl flex items-center justify-center text-blue-400 mb-6 group-hover:scale-110 transition-transform" data-ps="src/pages/sv/hemsidor.astro:icon-1">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/></svg>
          </div>
          <h3 class="text-xl font-bold text-white mt-0 mb-3" data-ps="src/pages/sv/hemsidor.astro:h3-1">Prisvärda Hemsidor</h3>
          <p class="text-zinc-400 text-base leading-relaxed mb-0" data-ps="src/pages/sv/hemsidor.astro:p-2">Snabba ensidiga lösningar som fungerar som ditt företags effektiva visitkort online. Idealiskt för småföretag som letar efter de billigaste hemsidorna.</p>
        </div>
        <div class="bg-zinc-900/40 p-8 rounded-2xl border border-zinc-800 hover:border-zinc-700 transition-all group" data-ps="src/pages/sv/hemsidor.astro:card-2">
          <div class="w-12 h-12 bg-blue-600/10 rounded-xl flex items-center justify-center text-blue-400 mb-6 group-hover:scale-110 transition-transform" data-ps="src/pages/sv/hemsidor.astro:icon-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="7" height="7" x="3" y="3" rx="1"/><rect width="7" height="7" x="14" y="3" rx="1"/><rect width="7" height="7" x="14" y="14" rx="1"/><rect width="7" height="7" x="3" y="14" rx="1"/></svg>
          </div>
          <h3 class="text-xl font-bold text-white mt-0 mb-3" data-ps="src/pages/sv/hemsidor.astro:h3-2">Omfattande Webb-tjänster</h3>
          <p class="text-zinc-400 text-base leading-relaxed mb-0" data-ps="src/pages/sv/hemsidor.astro:p-3">Mångsidiga webbplatser med flera undersidor, blogg eller expertartiklar. Perfekt för växande företag som behöver kontinuerlig Google-optimering.</p>
        </div>
        <div class="bg-zinc-900/40 p-8 rounded-2xl border border-zinc-800 hover:border-zinc-700 transition-all group" data-ps="src/pages/sv/hemsidor.astro:card-3">
          <div class="w-12 h-12 bg-blue-600/10 rounded-xl flex items-center justify-center text-blue-400 mb-6 group-hover:scale-110 transition-transform" data-ps="src/pages/sv/hemsidor.astro:icon-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="8" cy="21" r="1"/><circle cx="19" cy="21" r="1"/><path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12"/></svg>
          </div>
          <h3 class="text-xl font-bold text-white mt-0 mb-3" data-ps="src/pages/sv/hemsidor.astro:h3-3">E-handel</h3>
          <p class="text-zinc-400 text-base leading-relaxed mb-0" data-ps="src/pages/sv/hemsidor.astro:p-4">Kompletta försäljningsplattformar för direkt onlineförsäljning. Vi använder pålitliga plattformar som WooCommerce för smidig försäljning.</p>
        </div>
        <div class="bg-zinc-900/40 p-8 rounded-2xl border border-zinc-800 hover:border-zinc-700 transition-all group" data-ps="src/pages/sv/hemsidor.astro:card-4">
          <div class="w-12 h-12 bg-blue-600/10 rounded-xl flex items-center justify-center text-blue-400 mb-6 group-hover:scale-110 transition-transform" data-ps="src/pages/sv/hemsidor.astro:icon-4">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
          </div>
          <h3 class="text-xl font-bold text-white mt-0 mb-3" data-ps="src/pages/sv/hemsidor.astro:h3-4">Speciallösningar</h3>
          <p class="text-zinc-400 text-base leading-relaxed mb-0" data-ps="src/pages/sv/hemsidor.astro:p-5">Mer krävande system och skräddarsydda applikationer (PHP, Python, JS). Vår Websites Finland-expertis garanterar bästa prestanda.</p>
        </div>
      </div>

      <div class="grid md:grid-cols-2 gap-12 mb-20 items-center" data-ps="src/pages/sv/hemsidor.astro:seo-section">
        <div class="order-2 md:order-1" data-ps="src/pages/sv/hemsidor.astro:seo-text">
          <h3 class="text-2xl font-bold text-white mb-6" data-ps="src/pages/sv/hemsidor.astro:h3-5">Helhetslösning & Google Optimering</h3>
          <p class="text-zinc-300 mb-6" data-ps="src/pages/sv/hemsidor.astro:p-6">Vi tar hand om alla kritiska områden så att dina hemsidor syns på Google och andra sökmotorer hittar dem enkelt:</p>
          <ul class="space-y-3 list-none p-0" data-ps="src/pages/sv/hemsidor.astro:ul-1">
            <li class="flex items-center gap-3 text-zinc-300" data-ps="src/pages/sv/hemsidor.astro:li-1"><span class="w-1.5 h-1.5 rounded-full bg-blue-500" data-ps="src/pages/sv/hemsidor.astro:35jewc"></span> Domännamn och hantering</li>
            <li class="flex items-center gap-3 text-zinc-300" data-ps="src/pages/sv/hemsidor.astro:li-2"><span class="w-1.5 h-1.5 rounded-full bg-blue-500" data-ps="src/pages/sv/hemsidor.astro:35jewb"></span> Pålitligt och snabbt webbhotell</li>
            <li class="flex items-center gap-3 text-zinc-300" data-ps="src/pages/sv/hemsidor.astro:li-3"><span class="w-1.5 h-1.5 rounded-full bg-blue-500" data-ps="src/pages/sv/hemsidor.astro:35jewa"></span> Google Analytics & Search Console</li>
            <li class="flex items-center gap-3 text-zinc-300" data-ps="src/pages/sv/hemsidor.astro:li-4"><span class="w-1.5 h-1.5 rounded-full bg-blue-500" data-ps="src/pages/sv/hemsidor.astro:35jew9"></span> Innehållsproduktion och SEO-analyser</li>
          </ul>
        </div>
        <div class="order-1 md:order-2 bg-gradient-to-br from-blue-600/20 to-zinc-900 p-8 rounded-3xl border border-zinc-800" data-ps="src/pages/sv/hemsidor.astro:seo-visual">
          <div class="space-y-4" data-ps="src/pages/sv/hemsidor.astro:rjzoke">
            <div class="h-8 bg-zinc-800/50 rounded-lg w-full flex items-center px-4 gap-2" data-ps="src/pages/sv/hemsidor.astro:rjzokf">
              <div class="w-2 h-2 rounded-full bg-red-400" data-ps="src/pages/sv/hemsidor.astro:rjzokg"></div>
              <div class="w-2 h-2 rounded-full bg-yellow-400" data-ps="src/pages/sv/hemsidor.astro:rjzokh"></div>
              <div class="w-2 h-2 rounded-full bg-green-400" data-ps="src/pages/sv/hemsidor.astro:rjzoki"></div>
              <div class="h-2 bg-zinc-700 rounded w-24 ml-2" data-ps="src/pages/sv/hemsidor.astro:rjzokj"></div>
            </div>
            <div class="p-4 bg-zinc-800/30 rounded-lg border border-zinc-700/50" data-ps="src/pages/sv/hemsidor.astro:rjzokk">
              <div class="h-3 bg-blue-400/30 rounded w-3/4 mb-3" data-ps="src/pages/sv/hemsidor.astro:5gz38k"></div>
              <div class="h-2 bg-zinc-600/30 rounded w-full mb-2" data-ps="src/pages/sv/hemsidor.astro:5gz38l"></div>
              <div class="h-2 bg-zinc-600/30 rounded w-5/6" data-ps="src/pages/sv/hemsidor.astro:5gz38m"></div>
            </div>
            <div class="p-4 bg-zinc-800/30 rounded-lg border border-zinc-700/50" data-ps="src/pages/sv/hemsidor.astro:5gz38n">
              <div class="h-3 bg-blue-400/30 rounded w-2/3 mb-3" data-ps="src/pages/sv/hemsidor.astro:5gz38o"></div>
              <div class="h-2 bg-zinc-600/30 rounded w-full mb-2" data-ps="src/pages/sv/hemsidor.astro:5gz38p"></div>
              <div class="h-2 bg-zinc-600/30 rounded w-4/5" data-ps="src/pages/sv/hemsidor.astro:5gz38q"></div>
            </div>
          </div>
          <p class="text-center text-xs text-zinc-500 mt-6 uppercase tracking-widest" data-ps="src/pages/sv/hemsidor.astro:hie9qa">Search Engine Optimization</p>
        </div>
      </div>

      <div class="bg-gradient-to-r from-blue-900/40 to-indigo-900/40 border border-blue-500/20 rounded-3xl p-10 md:p-14 text-center relative overflow-hidden" data-ps="src/pages/sv/hemsidor.astro:cta">
        <div class="relative z-10" data-ps="src/pages/sv/hemsidor.astro:5gz38r">
          <h2 class="text-3xl md:text-4xl font-bold text-white mt-0 mb-6" data-ps="src/pages/sv/hemsidor.astro:cta-h3">Begär offert redan idag</h2>
          <p class="text-zinc-200 text-lg mb-10 max-w-2xl mx-auto" data-ps="src/pages/sv/hemsidor.astro:cta-p">Vi hjälper dig att välja precis rätt lösning för ditt företags verksamhet i Åboregionen. Billiga hemsidor, men ett professionellt slutresultat.</p>
          <a href="/sv/kontakt" class="inline-flex items-center gap-2 bg-white hover:bg-zinc-100 text-blue-900 font-bold py-4 px-10 rounded-full transition-all hover:scale-105 no-underline shadow-xl" data-ps="src/pages/sv/hemsidor.astro:cta-a">
            Kontakta oss
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>
        <div class="absolute top-0 right-0 -mr-20 -mt-20 w-64 h-64 bg-blue-500/10 rounded-full blur-3xl" data-ps="src/pages/sv/hemsidor.astro:5gz38s"></div>
        <div class="absolute bottom-0 left-0 -ml-20 -mb-20 w-64 h-64 bg-indigo-500/10 rounded-full blur-3xl" data-ps="src/pages/sv/hemsidor.astro:5gz38t"></div>
      </div>
    </div>
  </div>
</BaseLayout>
