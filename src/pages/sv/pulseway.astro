---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHeader from '@/components/PageHeader.astro';

const pulsewayImage = "https://images.unsplash.com/photo-1673526759317-be71a1243e3d?auto=format&w=1200&q=80";
const monitoringImage = "https://images.unsplash.com/photo-1746893737268-81fe686e6a51?auto=format&w=1200&q=80";
---

<BaseLayout 
  lang="sv"
  title="Pulseway RMM-lösningar | Archipelago Technics"
  description="Som Pulseway-partner i Finland erbjuder vi kompletta RMM-lösningar för företag och tjänsteleverantörer. Övervaka, hantera och automatisera din IT-infrastruktur."
>
  <PageHeader 
    title="Pulseway RMM"
    subtitle="Din IT-infrastruktur, hanterad var som helst."
    bgImage={pulsewayImage}
  />

  <section class="py-24 bg-white" data-ps="src/pages/sv/pulseway.astro:s9z2x1">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8" data-ps="src/pages/sv/pulseway.astro:s9z2x2">
      <div class="grid lg:grid-cols-2 gap-16 items-center" data-ps="src/pages/sv/pulseway.astro:s9z2x3">
        <div data-ps="src/pages/sv/pulseway.astro:s9z2x4">
          <h2 class="text-3xl md:text-4xl font-black text-zinc-950 mb-6" data-ps="src/pages/sv/pulseway.astro:s9z2x5">Vad är Pulseway?</h2>
          <p class="text-lg text-zinc-600 mb-6" data-ps="src/pages/sv/pulseway.astro:s9z2x6">
            Pulseway är en mobilfokuserad Remote Monitoring and Management (RMM) -plattform som ger IT-proffs full kontroll över hela sin IT-miljö från var som helst, när som helst.
          </p>
          <div class="space-y-4" data-ps="src/pages/sv/pulseway.astro:s9z2x7">
            <div class="flex items-start gap-4" data-ps="src/pages/sv/pulseway.astro:s9z2x8">
              <div class="w-10 h-10 bg-[#F54a00]/10 rounded-lg flex items-center justify-center shrink-0" data-ps="src/pages/sv/pulseway.astro:s9z2x9">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-[#F54a00]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z" />
                </svg>
              </div>
              <div data-ps="src/pages/sv/pulseway.astro:s9z2y1">
                <h3 class="font-bold text-zinc-950" data-ps="src/pages/sv/pulseway.astro:s9z2y2">Mobil kontroll</h3>
                <p class="text-zinc-600" data-ps="src/pages/sv/pulseway.astro:s9z2y3">Ta emot omedelbara varningar och åtgärda problem direkt från din smartphone eller surfplatta.</p>
              </div>
            </div>
            <div class="flex items-start gap-4" data-ps="src/pages/sv/pulseway.astro:s9z2y4">
              <div class="w-10 h-10 bg-[#F54a00]/10 rounded-lg flex items-center justify-center shrink-0" data-ps="src/pages/sv/pulseway.astro:s9z2y5">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-[#F54a00]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                </svg>
              </div>
              <div data-ps="src/pages/sv/pulseway.astro:s9z2y6">
                <h3 class="font-bold text-zinc-950" data-ps="src/pages/sv/pulseway.astro:s9z2y7">Kraftfull automatisering</h3>
                <p class="text-zinc-600" data-ps="src/pages/sv/pulseway.astro:s9z2y8">Automatisera rutinmässiga underhållsuppgifter, patchhantering och säkerhetsuppdateringar med lätthet.</p>
              </div>
            </div>
            <div class="flex items-start gap-4" data-ps="src/pages/sv/pulseway.astro:s9z2y9">
              <div class="w-10 h-10 bg-[#F54a00]/10 rounded-lg flex items-center justify-center shrink-0" data-ps="src/pages/sv/pulseway.astro:s9z2z1">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-[#F54a00]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04 inter-2 2 0 00-1.79 1.994 11.95 11.95 0 005.458 9.235 11.952 11.952 0 005.459 9.235 2 2 0 001.79-1.994 11.955 11.955 0 015.458-9.235 11.95 11.95 0 005.458-9.235 2 2 0 00-1.79-1.994z" />
                </svg>
              </div>
              <div data-ps="src/pages/sv/pulseway.astro:s9z2z2">
                <h3 class="font-bold text-zinc-950" data-ps="src/pages/sv/pulseway.astro:s9z2z3">Endpoint-säkerhet</h3>
                <p class="text-zinc-600" data-ps="src/pages/sv/pulseway.astro:s9z2z4">Integrerat virusskydd och ransomware-skydd säkerställer att ditt företags data förblir säker.</p>
              </div>
            </div>
          </div>
        </div>
        <div class="relative" data-ps="src/pages/sv/pulseway.astro:s9z2z5">
          <img crossorigin="anonymous" src={monitoringImage} 
            alt="Pulseway kontrollpanel" 
            class="rounded-2xl shadow-2xl w-full" data-ps="src/pages/sv/pulseway.astro:s9z2z6" />
          <div class="absolute -bottom-6 -left-6 bg-orange-700 p-8 rounded-2xl text-zinc-50 shadow-xl max-w-xs" data-ps="src/pages/sv/pulseway.astro:s9z2z7">
            <p class="text-2xl font-black mb-2" data-ps="src/pages/sv/pulseway.astro:s9z2z8">100%</p>
            <p class="text-sm font-bold text-zinc-100" data-ps="src/pages/sv/pulseway.astro:s9z2z9">Synlighet över din IT-infrastruktur direkt från din telefon.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-24 bg-zinc-50" data-ps="src/pages/sv/pulseway.astro:s9z3a1">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center" data-ps="src/pages/sv/pulseway.astro:s9z3a2">
      <h2 class="text-3xl md:text-4xl font-black text-zinc-950 mb-8" data-ps="src/pages/sv/pulseway.astro:s9z3a3">Din Pulseway-partner i Finland</h2>
      <p class="text-xl text-zinc-600 mb-10" data-ps="src/pages/sv/pulseway.astro:s9z3a4">
        Archipelago Technics är en certifierad Pulseway-partner. Vi erbjuder denna IT-hanteringslösning i världsklass till företag och IT-tjänsteleverantörer i hela Finland.
      </p>
      <div class="bg-white p-12 rounded-3xl shadow-sm border border-zinc-200" data-ps="src/pages/sv/pulseway.astro:s9z3a5">
        <h3 class="text-2xl font-black text-zinc-950 mb-6" data-ps="src/pages/sv/pulseway.astro:s9z3a6">Få din lösning via oss</h3>
        <p class="text-zinc-600 mb-8" data-ps="src/pages/sv/pulseway.astro:s9z3a7">
          Oavsett om du vill hantera din egen interna IT-miljö eller agera som MSP-tjänsteleverantör för dina kunder, erbjuder vi licenser, installationsstöd och lokal expertis för att lyckas med Pulseway.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center" data-ps="src/pages/sv/pulseway.astro:s9z3a8">
          <a href="/sv/kontakt" class="px-10 py-5 bg-[#F54a00] text-zinc-950 rounded-full font-black text-lg hover:brightness-110 transition-all shadow-xl" data-ps="src/pages/sv/pulseway.astro:s9z3a9">
            Begär en demo
          </a>
          <a href="tel:+358405829704" class="px-10 py-5 border-2 border-zinc-200 text-zinc-900 rounded-full font-black text-lg hover:bg-zinc-50 transition-all" data-ps="src/pages/sv/pulseway.astro:s9z3b1">
            Ring en expert
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="py-24 bg-white" data-ps="src/pages/sv/pulseway.astro:s9z3b2">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8" data-ps="src/pages/sv/pulseway.astro:s9z3b3">
      <div class="grid md:grid-cols-3 gap-8" data-ps="src/pages/sv/pulseway.astro:s9z3b4">
        <div class="p-8 bg-zinc-50 rounded-2xl border border-zinc-100" data-ps="src/pages/sv/pulseway.astro:s9z3b5">
          <h4 class="text-xl font-black text-zinc-950 mb-4" data-ps="src/pages/sv/pulseway.astro:s9z3b6">För intern IT</h4>
          <p class="text-zinc-600" data-ps="src/pages/sv/pulseway.astro:s9z3b7">Förenkla ditt dagliga arbete och övervaka servrar, arbetsstationer och nätverksenheter från en samlad vy.</p>
        </div>
        <div class="p-8 bg-zinc-50 rounded-2xl border border-zinc-100" data-ps="src/pages/sv/pulseway.astro:s9z3b8">
          <h4 class="text-xl font-black text-zinc-950 mb-4" data-ps="src/pages/sv/pulseway.astro:s9z3b9">För tjänsteleverantörer (MSP)</h4>
          <p class="text-zinc-600" data-ps="src/pages/sv/pulseway.astro:s9z3c1">Skala din verksamhet genom att hantera flera kundmiljöer effektivt och erbjuda proaktiv support.</p>
        </div>
        <div class="p-8 bg-zinc-50 rounded-2xl border border-zinc-100" data-ps="src/pages/sv/pulseway.astro:s9z3c2">
          <h4 class="text-xl font-black text-zinc-950 mb-4" data-ps="src/pages/sv/pulseway.astro:s9z3c3">Lokal support</h4>
          <p class="text-zinc-600" data-ps="src/pages/sv/pulseway.astro:s9z3c4">Få hjälp vid behov från vårt finländska team. Vi känner till den lokala marknaden och kraven.</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
