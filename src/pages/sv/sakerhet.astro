---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHeader from '@/components/PageHeader.astro';

const title = "Cybersäkerhet & IT-skydd för Företag | Archipelago Technics";
const description = "Skydda ditt företag med omfattande cybersäkerhetslösningar. Brandväggar, virusskydd och säkerhetsutbildning för personal i Åboregionen.";
---

<BaseLayout title={title} description={description} lang="sv">
  <PageHeader title={title} description={description} />
  
  <div class="max-w-7xl mx-auto px-6 py-12" data-ps="src/pages/sv/sakerhet.astro:19nito">
    <div class="grid md:grid-cols-2 gap-12 items-center mb-24" data-ps="src/pages/sv/sakerhet.astro:19nitp">
      <div class="prose prose-invert prose-lg" data-ps="src/pages/sv/sakerhet.astro:19nitq">
        <p class="lead" data-ps="src/pages/sv/sakerhet.astro:ubcn3o">Cybersäkerhet är inte bara en teknisk fråga; det är en förutsättning för verksamheten.</p>
        <p data-ps="src/pages/sv/sakerhet.astro:ubcn3n">I en tid med ökande ransomware- och nätfiskeattacker räcker det inte längre med ett enkelt antivirusprogram. Vi erbjuder en flerskiktad försvarsstrategi som skyddar din identitet, dina data och din infrastruktur.</p>
        <p data-ps="src/pages/sv/sakerhet.astro:ubcn3m">Från proaktiv övervakning till personalutbildning – vi ser till att din organisation förblir motståndskraftig mot föränderliga digitala hot.</p>
      </div>
      <div data-ps="src/pages/sv/sakerhet.astro:19nitr">
        <img 
            crossorigin="anonymous"
            src="https://images.unsplash.com/photo-1768839721176-2fa91fdce725?auto=format&w=800&q=80" 
            srcset="https://images.unsplash.com/photo-1768839721176-2fa91fdce725?auto=format&w=400&q=80 400w, https://images.unsplash.com/photo-1768839721176-2fa91fdce725?auto=format&w=800&q=80 800w"
            class="rounded-xl shadow-2xl w-full" 
            alt="Cybersäkerhet" data-ps="src/pages/sv/sakerhet.astro:18llht" />
      </div>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6 mb-24" data-ps="src/pages/sv/sakerhet.astro:19nits">
      <div class="bg-neutral-900 border border-white/10 p-6 rounded-xl" data-ps="src/pages/sv/sakerhet.astro:beyqfc">
        <h3 class="font-bold text-lg mb-2" data-ps="src/pages/sv/sakerhet.astro:kxopk9">Endpoint-säkerhet</h3>
        <p class="text-sm text-neutral-400" data-ps="src/pages/sv/sakerhet.astro:ubcn3l">Avancerat skydd för bärbara datorer, stationära datorer och mobila enheter med hotdetektering i realtid.</p>
      </div>
      <div class="bg-neutral-900 border border-white/10 p-6 rounded-xl" data-ps="src/pages/sv/sakerhet.astro:beyqfb">
        <h3 class="font-bold text-lg mb-2" data-ps="src/pages/sv/sakerhet.astro:kxopkv">E-postskydd</h3>
        <p class="text-sm text-neutral-400" data-ps="src/pages/sv/sakerhet.astro:ubcn3k">Filtreringssystem för att blockera nätfiske, skadlig kod och skräppost innan de når din inkorg.</p>
      </div>
      <div class="bg-neutral-900 border border-white/10 p-6 rounded-xl" data-ps="src/pages/sv/sakerhet.astro:beyqfa">
        <h3 class="font-bold text-lg mb-2" data-ps="src/pages/sv/sakerhet.astro:kxopkw">Identitetshantering</h3>
        <p class="text-sm text-neutral-400" data-ps="src/pages/sv/sakerhet.astro:ubcn2y">Implementering av MFA (flerfaktorsautentisering) och Zero Trust-åtkomstkontroll.</p>
      </div>
      <div class="bg-neutral-900 border border-white/10 p-6 rounded-xl" data-ps="src/pages/sv/sakerhet.astro:beyqf9">
        <h3 class="font-bold text-lg mb-2" data-ps="src/pages/sv/sakerhet.astro:kxopkx">Säkerhetsrevisioner</h3>
        <p class="text-sm text-neutral-400" data-ps="src/pages/sv/sakerhet.astro:ubcn2x">Regelbundna sårbarhetsskanningar och bedömningar av säkerhetsläget för att hitta svaga punkter.</p>
      </div>
    </div>

    <div class="bg-primary-950/20 border border-primary-900/50 p-12 rounded-3xl" data-ps="src/pages/sv/sakerhet.astro:beyqf8">
      <div class="max-w-3xl mx-auto text-center mb-12" data-ps="src/pages/sv/sakerhet.astro:beyqf7">
        <h2 class="text-3xl font-bold mb-4" data-ps="src/pages/sv/sakerhet.astro:zf0f6m">Den mänskliga faktorn</h2>
        <p class="text-neutral-400" data-ps="src/pages/sv/sakerhet.astro:ubcn2w">Teknik är bara halva striden. Vi erbjuder utbildning i säkerhetsmedvetenhet för att göra dina anställda till din starkaste försvarslinje.</p>
      </div>
      <div class="grid md:grid-cols-3 gap-8" data-ps="src/pages/sv/sakerhet.astro:beyqf6">
        <div data-ps="src/pages/sv/sakerhet.astro:beyqf5">
          <h4 class="font-bold mb-2" data-ps="src/pages/sv/sakerhet.astro:699scm">Nätfiskesimuleringar</h4>
          <p class="text-sm text-neutral-400" data-ps="src/pages/sv/sakerhet.astro:ubcn2v">Realistiska testmejl för att träna personalen i att upptäcka och rapportera misstänkta meddelanden.</p>
        </div>
        <div data-ps="src/pages/sv/sakerhet.astro:beyqf4">
          <h4 class="font-bold mb-2" data-ps="src/pages/sv/sakerhet.astro:699scn">Säkerhetsworkshoppar</h4>
          <p class="text-sm text-neutral-400" data-ps="src/pages/sv/sakerhet.astro:ubcn2u">Praktiska sessioner som täcker lösenordshygien och säkra surfvanor.</p>
        </div>
        <div data-ps="src/pages/sv/sakerhet.astro:beyqf3">
          <h4 class="font-bold mb-2" data-ps="src/pages/sv/sakerhet.astro:699sco">Efterlevnadsutbildning</h4>
          <p class="text-sm text-neutral-400" data-ps="src/pages/sv/sakerhet.astro:ubcn2t">Säkerställa att personalen förstår GDPR och andra lagstadgade krav för datahantering.</p>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>