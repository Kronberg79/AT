---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHeader from '@/components/PageHeader.astro';

const title = "Serverunderhåll";
const description = "Sakkunnig serverunderhåll, uppdateringar och migrationer.";
---

<BaseLayout title={title} description={description} lang="sv">
  <PageHeader title={title} description={description} />
  
  <div class="max-w-7xl mx-auto px-6 py-16" data-ps="src/pages/sv/serverservice.astro:19da3j">
    <div class="grid lg:grid-cols-2 gap-12 mb-16" data-ps="src/pages/sv/serverservice.astro:19da3k">
      <div class="prose prose-lg prose-invert" data-ps="src/pages/sv/serverservice.astro:19da3l">
        <h2 class="text-3xl font-bold text-white mb-6" data-ps="src/pages/sv/serverservice.astro:edwj8g">God expertservice med års erfarenhet</h2>
        <p data-ps="src/pages/sv/serverservice.astro:wb7ht1">
          Söker du en pålitlig partner för serverunderhåll, uppdateringar eller migrationer? 
          Vi specialiserar oss på serverdrift och felsökning – snabbt, säkert och sakkunnigt. 
          Vi betjänar er ännu samma dag!
        </p>
        <p data-ps="src/pages/sv/serverservice.astro:wb7ht2">
          Välj oss när du vill säkerställa din servermiljös kontinuerliga funktion och säkerhet.
        </p>
        <div class="mt-8" data-ps="src/pages/sv/serverservice.astro:19da3m">
          <a href="/sv/kontakt" class="bg-orange-600 hover:bg-orange-700 text-white font-bold py-3 px-6 rounded-lg transition" data-ps="src/pages/sv/serverservice.astro:vlynga">
            Kontakta oss
          </a>
        </div>
      </div>
      <div data-ps="src/pages/sv/serverservice.astro:19da3n">
        <img crossorigin="anonymous" src="https://images.unsplash.com/photo-1680992046617-e2e35451bcdb?auto=format&w=800&q=80" 
          class="rounded-xl shadow-2xl w-full h-full object-cover" 
          alt="Serverunderhåll" data-ps="src/pages/sv/serverservice.astro:ygxh3n" />
      </div>
    </div>

    <div class="grid md:grid-cols-2 gap-8" data-ps="src/pages/sv/serverservice.astro:19da3o">
      <div class="bg-zinc-900 p-8 rounded-xl border border-zinc-800" data-ps="src/pages/sv/serverservice.astro:19da3p">
        <h3 class="text-2xl font-bold text-orange-500 mb-4" data-ps="src/pages/sv/serverservice.astro:t2bgg4">Underhåll och drift</h3>
        <p class="text-zinc-300 mb-4" data-ps="src/pages/sv/serverservice.astro:wb7ht3">
          Regelbundet underhåll är kritiskt för din IT-infrastrukturs driftsäkerhet. 
          Vi erbjuder heltäckande serverunderhållstjänster, som inkluderar bl.a.:
        </p>
        <ul class="list-disc list-inside text-zinc-300 space-y-2">
          <li data-ps="src/pages/sv/serverservice.astro:dmxmrj">Hårdvaru- och mjukvarukontroller</li>
          <li data-ps="src/pages/sv/serverservice.astro:dmxmri">Prestandaoptimering</li>
          <li data-ps="src/pages/sv/serverservice.astro:dmxmrh">Säkerhetsuppdateringar och backuplösningar</li>
          <li data-ps="src/pages/sv/serverservice.astro:dmxmqv">Förebyggande underhåll och felförebyggande</li>
        </ul>
      </div>

      <div class="bg-zinc-900 p-8 rounded-xl border border-zinc-800" data-ps="src/pages/sv/serverservice.astro:19da3q">
        <h3 class="text-2xl font-bold text-orange-500 mb-4" data-ps="src/pages/sv/serverservice.astro:t2bgg3">Uppdateringar och modernisering</h3>
        <p class="text-zinc-300 mb-4" data-ps="src/pages/sv/serverservice.astro:wb7ht4">
          Teknologin utvecklas snabbt – vi säkerställer att dina servrar hålls uppdaterade. 
          Vi är specialiserade på att uppdatera gamla system (som Windows Server 2008) till 
          moderna och stödda versioner.
        </p>
        <p class="text-zinc-300" data-ps="src/pages/sv/serverservice.astro:wb7htq">
          Uppdatering medför bättre prestanda, säkerhet och kompatibilitet med nya applikationer.
        </p>
      </div>

      <div class="bg-zinc-900 p-8 rounded-xl border border-zinc-800" data-ps="src/pages/sv/serverservice.astro:19da3r">
        <h3 class="text-2xl font-bold text-orange-500 mb-4" data-ps="src/pages/sv/serverservice.astro:t2bgg2">Servermigrationer</h3>
        <p class="text-zinc-300 mb-4" data-ps="src/pages/sv/serverservice.astro:wb7htr">
          Planerar ni en flytt till en ny servermiljö eller molntjänster? 
          Vi genomför servermigrationer kontrollerat och utan avbrott för affärsverksamheten.
        </p>
        <ul class="list-disc list-inside text-zinc-300 space-y-2">
          <li data-ps="src/pages/sv/serverservice.astro:dmxmqu">Nulägesanalys och planering</li>
          <li data-ps="src/pages/sv/serverservice.astro:dmxmqt">Data- och tjänsteflytt</li>
          <li data-ps="src/pages/sv/serverservice.astro:dmxmqs">Testning och ibruktagning</li>
          <li data-ps="src/pages/sv/serverservice.astro:dmxmqr">Användarstöd och guidning</li>
        </ul>
      </div>

      <div class="bg-zinc-900 p-8 rounded-xl border border-zinc-800" data-ps="src/pages/sv/serverservice.astro:19da3s">
        <h3 class="text-2xl font-bold text-orange-500 mb-4" data-ps="src/pages/sv/serverservice.astro:t2bgg1">Felsökning och akutservice</h3>
        <p class="text-zinc-300 mb-4" data-ps="src/pages/sv/serverservice.astro:wb7hts">
          Serverproblem kan orsaka betydande avbrott. Våra experter är redo att hjälpa i alla felsituationer 
          – oavsett om det gäller hårdvarufel, programkrascher eller säkerhetsproblem.
        </p>
        <p class="text-zinc-300" data-ps="src/pages/sv/serverservice.astro:wb7htt">
          Vi reagerar snabbt och återställer era system till funktionsdugligt skick.
        </p>
      </div>
    </div>
  </div>
</BaseLayout>
