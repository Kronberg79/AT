---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHeader from '@/components/PageHeader.astro';

const title = "Möt Våra IT-experter | Archipelago Technics i Åboland";
const description = "Lär känna det erfarna och dedikerade teamet bakom Archipelago Technics. Lokala IT-proffs som servar Åbo skärgård med expertis.";
---

<BaseLayout title={title} description={description} lang="sv">
  <PageHeader title={title} description={description} />
  <div class="max-w-7xl mx-auto px-6 py-12 space-y-24" data-ps="src/pages/sv/team.astro:9xqzy">
    <div class="grid md:grid-cols-2 gap-12 items-center" data-ps="src/pages/sv/team.astro:9xqzz">
      <div class="prose prose-invert prose-lg" data-ps="src/pages/sv/team.astro:9xr00">
        <p class="lead" data-ps="src/pages/sv/team.astro:u67iel">Erfarna. Dedikerade. Lokala.</p>
        <p data-ps="src/pages/sv/team.astro:u67iem">Vi är ett team av IT-proffs som brinner för teknik och kundservice. Baserade i skärgården förstår vi de unika behoven i vårt lokala samhälle.</p>
      </div>
      <div data-ps="src/pages/sv/team.astro:9xr01" class="flex flex-col gap-4">
        <img 
          src="https://cdn.pagesmith.app/eb31781e/images/ATcrew-1024-1024-1024.webp" 
          alt="Archipelago Technics Team" 
          class="rounded-xl shadow-lg w-full aspect-[4/3] object-cover" data-ps="src/pages/sv/team.astro:tlb7n7" />
      </div>
    </div>

    <section class="space-y-12" data-ps="src/pages/sv/team.astro:6ot2kl">
      <h2 class="text-3xl md:text-4xl font-bold text-center" data-ps="src/pages/sv/team.astro:avxfe5">Personal</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8" data-ps="src/pages/sv/team.astro:9xqzy">
        <div class="bg-gray-800/50 p-8 rounded-2xl border border-gray-700/50 hover:border-blue-500/50 transition-colors" data-ps="src/pages/sv/team.astro:9xqzz">
          <img 
            src="https://cdn.pagesmith.app/eb31781e/images/IMG_4582-256-256.webp" 
            alt="Kasper Kronberg" 
            class="w-32 h-32 rounded-full mx-auto mb-6 object-cover border-2 border-blue-500" data-ps="src/pages/sv/team.astro:tlb7nc" />
          <div class="text-center" data-ps="src/pages/sv/team.astro:9xr00">
            <h3 class="text-xl font-bold mb-1" data-ps="src/pages/sv/team.astro:bcz2j2">Kasper Kronberg</h3>
            <p class="text-blue-400 font-medium mb-4" data-ps="src/pages/sv/team.astro:by04ym">CEO and Founder</p>
            <div class="space-y-1 text-gray-300" data-ps="src/pages/sv/team.astro:9xr01">
              <p data-ps="src/pages/sv/team.astro:u67iei"><a href="tel:+358451108777" class="hover:text-blue-400 transition-colors" data-ps="src/pages/sv/team.astro:j1y1oe">+358 45 110 8777</a></p>
              <p data-ps="src/pages/sv/team.astro:u67iej"><a href="mailto:kasper.kronberg@a-t.fi" class="hover:text-blue-400 transition-colors" data-ps="src/pages/sv/team.astro:j1y1of">kasper.kronberg@a-t.fi</a></p>
            </div>
          </div>
        </div>

        <div class="bg-gray-800/50 p-8 rounded-2xl border border-gray-700/50 hover:border-blue-500/50 transition-colors" data-ps="src/pages/sv/team.astro:kalle-card">
          <img 
            src="https://cdn.pagesmith.app/eb31781e/images/IMG_4580-200-200.webp" 
            alt="Kalle Jonsson" 
            class="w-32 h-32 rounded-full mx-auto mb-6 object-cover border-2 border-blue-500" data-ps="src/pages/sv/team.astro:kalle-img" />
          <div class="text-center" data-ps="src/pages/sv/team.astro:kalle-info">
            <h3 class="text-xl font-bold mb-1" data-ps="src/pages/sv/team.astro:kalle-name">Kalle Jonsson</h3>
            <p class="text-blue-400 font-medium mb-4" data-ps="src/pages/sv/team.astro:kalle-role">Försäljningschef</p>
            <div class="space-y-1 text-gray-300" data-ps="src/pages/sv/team.astro:kalle-contact">
              <p data-ps="src/pages/sv/team.astro:kalle-phone"><a href="tel:+358405829767" class="hover:text-blue-400 transition-colors" data-ps="src/pages/sv/team.astro:kalle-tel">+358 40 582 9767</a></p>
              <p data-ps="src/pages/sv/team.astro:kalle-email-p"><a href="mailto:kalle.jonsson@a-t.fi" class="hover:text-blue-400 transition-colors" data-ps="src/pages/sv/team.astro:kalle-mail">kalle.jonsson@a-t.fi</a></p>
            </div>
          </div>
        </div>

        <div class="bg-gray-800/50 p-8 rounded-2xl border border-gray-700/50 hover:border-blue-500/50 transition-colors" data-ps="src/pages/sv/team.astro:edwin-card">
          <img 
            src="https://cdn.pagesmith.app/eb31781e/images/IMG_4581-256-256.webp" 
            alt="Edwin Mickelsson" 
            class="w-32 h-32 rounded-full mx-auto mb-6 object-cover border-2 border-blue-500" data-ps="src/pages/sv/team.astro:edwin-img" />
          <div class="text-center" data-ps="src/pages/sv/team.astro:edwin-info">
            <h3 class="text-xl font-bold mb-1" data-ps="src/pages/sv/team.astro:edwin-name">Edwin Mickelsson</h3>
            <p class="text-blue-400 font-medium mb-4" data-ps="src/pages/sv/team.astro:edwin-role">Servicechef</p>
            <div class="space-y-1 text-gray-300" data-ps="src/pages/sv/team.astro:edwin-contact">
              <p data-ps="src/pages/sv/team.astro:edwin-phone"><a href="tel:+358405829667" class="hover:text-blue-400 transition-colors" data-ps="src/pages/sv/team.astro:edwin-tel">+358 40 582 9667</a></p>
              <p data-ps="src/pages/sv/team.astro:edwin-email-p"><a href="mailto:edwin.mickelsson@a-t.fi" class="hover:text-blue-400 transition-colors" data-ps="src/pages/sv/team.astro:edwin-mail">edwin.mickelsson@a-t.fi</a></p>
            </div>
          </div>
        </div>

        <div class="bg-gray-800/50 p-8 rounded-2xl border border-gray-700/50 hover:border-blue-500/50 transition-colors" data-ps="src/pages/sv/team.astro:agneta-card">
          <img 
            src="https://cdn.pagesmith.app/eb31781e/images/IMG_5561-1024-1024.webp" 
            alt="Agneta Färm" 
            class="w-32 h-32 rounded-full mx-auto mb-6 object-cover border-2 border-blue-500" data-ps="src/pages/sv/team.astro:agneta-img" />
          <div class="text-center" data-ps="src/pages/sv/team.astro:agneta-info">
            <h3 class="text-xl font-bold mb-1" data-ps="src/pages/sv/team.astro:agneta-name">Agneta Färm</h3>
            <p class="text-blue-400 font-medium mb-4" data-ps="src/pages/sv/team.astro:agneta-role">Ekonomi</p>
            <div class="space-y-1 text-gray-300" data-ps="src/pages/sv/team.astro:agneta-contact">
              <p data-ps="src/pages/sv/team.astro:agneta-email-p"><a href="mailto:agneta.farm@a-t.fi" class="hover:text-blue-400 transition-colors" data-ps="src/pages/sv/team.astro:agneta-mail">agneta.farm@a-t.fi</a></p>
            </div>
          </div>
        </div>

        <div class="bg-gray-800/50 p-8 rounded-2xl border border-gray-700/50 hover:border-blue-500/50 transition-colors" data-ps="src/pages/sv/team.astro:oliver-card">
          <img 
            src="https://cdn.pagesmith.app/eb31781e/images/IMG_3910-1536-1536.webp" 
            alt="Oliver Salviander" 
            class="w-32 h-32 rounded-full mx-auto mb-6 object-cover border-2 border-blue-500" data-ps="src/pages/sv/team.astro:oliver-img" />
          <div class="text-center" data-ps="src/pages/sv/team.astro:oliver-info">
            <h3 class="text-xl font-bold mb-1" data-ps="src/pages/sv/team.astro:oliver-name">Oliver Salviander</h3>
            <p class="text-blue-400 font-medium mb-4" data-ps="src/pages/sv/team.astro:oliver-role">Underhåll</p>
            <div class="space-y-1 text-gray-300" data-ps="src/pages/sv/team.astro:oliver-contact">
              <p data-ps="src/pages/sv/team.astro:oliver-email-p"><a href="mailto:oliver.salviander@a-t.fi" class="hover:text-blue-400 transition-colors" data-ps="src/pages/sv/team.astro:oliver-mail">oliver.salviander@a-t.fi</a></p>
            </div>
          </div>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>
