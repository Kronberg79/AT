---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHeader from '@/components/PageHeader.astro';

const title = "Meet Our IT Experts | Archipelago Technics";
const description = "Meet the experienced and dedicated team behind Archipelago Technics. Local IT professionals serving the Turku archipelago.";

---

<BaseLayout 
  title="Meet Our IT Experts | Archipelago Technics" 
  description="Meet the experienced and dedicated team behind Archipelago Technics. Local IT professionals serving the Turku archipelago." 
  lang="en"
>
  <PageHeader title={title} description={description} />
  <div class="max-w-7xl mx-auto px-6 py-12 space-y-24" data-ps="src/pages/team.astro:a9sl7y">
    <div class="grid md:grid-cols-2 gap-12 items-center" data-ps="src/pages/team.astro:a9sl7z">
      <div class="prose prose-invert prose-lg" data-ps="src/pages/team.astro:a9sl80">
        <p class="lead" data-ps="src/pages/team.astro:7w0ar1">Experienced. Dedicated. Local.</p>
        <p data-ps="src/pages/team.astro:7w0ar2">We are a team of IT professionals passionate about technology and customer service. Based in the archipelago, we understand the unique needs of our local community.</p>
      </div>
      <div data-ps="src/pages/team.astro:a9sl81" class="flex flex-col gap-4">
        <img 
          src="https://cdn.pagesmith.app/eb31781e/images/ATcrew-1024-1024-1024.webp" 
          alt="Archipelago Technics Team" 
          class="rounded-xl shadow-lg w-full aspect-[4/3] object-cover" data-ps="src/pages/team.astro:jlgdf7" />
      </div>
    </div>

    <section class="space-y-12" data-ps="src/pages/team.astro:2xjsxn">
      <h2 class="text-3xl md:text-4xl font-bold text-center" data-ps="src/pages/team.astro:q5jtcj">Staff</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8" data-ps="src/pages/team.astro:a9sl7y">
        <div class="bg-gray-800/50 p-8 rounded-2xl border border-gray-700/50 hover:border-blue-500/50 transition-colors" data-ps="src/pages/team.astro:a9sl7z">
          <img 
            src="https://cdn.pagesmith.app/eb31781e/images/IMG_4582-256-256.webp" 
            alt="Kasper Kronberg" 
            class="w-32 h-32 rounded-full mx-auto mb-6 object-cover border-2 border-blue-500" data-ps="src/pages/team.astro:jlgdfc" />
          <div class="text-center" data-ps="src/pages/team.astro:a9sl80">
            <h3 class="text-xl font-bold mb-1" data-ps="src/pages/team.astro:poi67m">Kasper Kronberg</h3>
            <p class="text-blue-400 font-medium mb-4" data-ps="src/pages/team.astro:vgx3fi">CEO and Founder</p>
            <div class="space-y-1 text-gray-300" data-ps="src/pages/team.astro:a9sl81">
              <p data-ps="src/pages/team.astro:7w0aqy"><a href="tel:+358451108777" class="hover:text-blue-400 transition-colors" data-ps="src/pages/team.astro:wg91tu">+358 45 110 8777</a></p>
              <p data-ps="src/pages/team.astro:7w0aqz"><a href="mailto:kasper.kronberg@a-t.fi" class="hover:text-blue-400 transition-colors" data-ps="src/pages/team.astro:wg91tt">kasper.kronberg@a-t.fi</a></p>
            </div>
          </div>
        </div>

        <div class="bg-gray-800/50 p-8 rounded-2xl border border-gray-700/50 hover:border-blue-500/50 transition-colors" data-ps="src/pages/team.astro:kalle-card">
          <img 
            src="https://cdn.pagesmith.app/eb31781e/images/IMG_4580-200-200.webp" 
            alt="Kalle Jonsson" 
            class="w-32 h-32 rounded-full mx-auto mb-6 object-cover border-2 border-blue-500" data-ps="src/pages/team.astro:kalle-img" />
          <div class="text-center" data-ps="src/pages/team.astro:kalle-info">
            <h3 class="text-xl font-bold mb-1" data-ps="src/pages/team.astro:kalle-name">Kalle Jonsson</h3>
            <p class="text-blue-400 font-medium mb-4" data-ps="src/pages/team.astro:kalle-role">Sales Manager</p>
            <div class="space-y-1 text-gray-300" data-ps="src/pages/team.astro:kalle-contact">
              <p data-ps="src/pages/team.astro:kalle-phone"><a href="tel:+358405829767" class="hover:text-blue-400 transition-colors" data-ps="src/pages/team.astro:kalle-tel">+358 40 582 9767</a></p>
              <p data-ps="src/pages/team.astro:kalle-email-p"><a href="mailto:kalle.jonsson@a-t.fi" class="hover:text-blue-400 transition-colors" data-ps="src/pages/team.astro:kalle-mail">kalle.jonsson@a-t.fi</a></p>
            </div>
          </div>
        </div>

        <div class="bg-gray-800/50 p-8 rounded-2xl border border-gray-700/50 hover:border-blue-500/50 transition-colors" data-ps="src/pages/team.astro:edwin-card">
          <img 
            src="https://cdn.pagesmith.app/eb31781e/images/IMG_4581-256-256.webp" 
            alt="Edwin Mickelsson" 
            class="w-32 h-32 rounded-full mx-auto mb-6 object-cover border-2 border-blue-500" data-ps="src/pages/team.astro:edwin-img" />
          <div class="text-center" data-ps="src/pages/team.astro:edwin-info">
            <h3 class="text-xl font-bold mb-1" data-ps="src/pages/team.astro:edwin-name">Edwin Mickelsson</h3>
            <p class="text-blue-400 font-medium mb-4" data-ps="src/pages/team.astro:edwin-role">Maintenance Manager</p>
            <div class="space-y-1 text-gray-300" data-ps="src/pages/team.astro:edwin-contact">
              <p data-ps="src/pages/team.astro:edwin-phone"><a href="tel:+358405829667" class="hover:text-blue-400 transition-colors" data-ps="src/pages/team.astro:edwin-tel">+358 40 582 9667</a></p>
              <p data-ps="src/pages/team.astro:edwin-email-p"><a href="mailto:edwin.mickelsson@a-t.fi" class="hover:text-blue-400 transition-colors" data-ps="src/pages/team.astro:edwin-mail">edwin.mickelsson@a-t.fi</a></p>
            </div>
          </div>
        </div>

        <div class="bg-gray-800/50 p-8 rounded-2xl border border-gray-700/50 hover:border-blue-500/50 transition-colors" data-ps="src/pages/team.astro:agneta-card">
          <img 
            src="https://cdn.pagesmith.app/eb31781e/images/IMG_5561-1024-1024.webp" 
            alt="Agneta Färm" 
            class="w-32 h-32 rounded-full mx-auto mb-6 object-cover border-2 border-blue-500" data-ps="src/pages/team.astro:agneta-img" />
          <div class="text-center" data-ps="src/pages/team.astro:agneta-info">
            <h3 class="text-xl font-bold mb-1" data-ps="src/pages/team.astro:agneta-name">Agneta Färm</h3>
            <p class="text-blue-400 font-medium mb-4" data-ps="src/pages/team.astro:agneta-role">Finance</p>
            <div class="space-y-1 text-gray-300" data-ps="src/pages/team.astro:agneta-contact">
              <p data-ps="src/pages/team.astro:agneta-email-p"><a href="mailto:agneta.farm@a-t.fi" class="hover:text-blue-400 transition-colors" data-ps="src/pages/team.astro:agneta-mail">agneta.farm@a-t.fi</a></p>
            </div>
          </div>
        </div>

        <div class="bg-gray-800/50 p-8 rounded-2xl border border-gray-700/50 hover:border-blue-500/50 transition-colors" data-ps="src/pages/team.astro:oliver-card">
          <img 
            src="https://cdn.pagesmith.app/eb31781e/images/IMG_3910-1536-1536.webp" 
            alt="Oliver Salviander" 
            class="w-32 h-32 rounded-full mx-auto mb-6 object-cover border-2 border-blue-500" data-ps="src/pages/team.astro:oliver-img" />
          <div class="text-center" data-ps="src/pages/team.astro:oliver-info">
            <h3 class="text-xl font-bold mb-1" data-ps="src/pages/team.astro:oliver-name">Oliver Salviander</h3>
            <p class="text-blue-400 font-medium mb-4" data-ps="src/pages/team.astro:oliver-role">Maintenance</p>
            <div class="space-y-1 text-gray-300" data-ps="src/pages/team.astro:oliver-contact">
              <p data-ps="src/pages/team.astro:oliver-email-p"><a href="mailto:oliver.salviander@a-t.fi" class="hover:text-blue-400 transition-colors" data-ps="src/pages/team.astro:oliver-mail">oliver.salviander@a-t.fi</a></p>
            </div>
          </div>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>
